column_constraint ::= [ 'CONSTRAINT' {identifier} ] (
  'PRIMARY' 'KEY' oracle_constraint_state * |
  [ 'NOT' ] 'NULL' oracle_constraint_state * |
  'UNIQUE' oracle_constraint_state * |
  {check_constraint} oracle_constraint_state * |
  oracle_default_on_null_clause |
  {default_constraint} |
  'COLLATE' {collation_name} |
  'RESERVABLE' |
  'SORT' |
  oracle_inline_ref_constraint |
  {foreign_key_clause} oracle_constraint_state * |
  <<generatedClauseExt <<generated_clause_real>>>> |
  oracle_encryption_spec |
  oracle_identity_clause |
  oracle_annotations_clause |
  oracle_visibility
) {
  extends = "com.alecstrong.sql.psi.core.psi.impl.SqlColumnConstraintImpl"
  implements = "com.alecstrong.sql.psi.core.psi.SqlColumnConstraint"
  override = true
}

private oracle_default_on_null_clause ::= 'DEFAULT' 'ON' 'NULL'
  [ 'FOR' LP 'INSERT' ( 'ONLY' | 'AND' 'UPDATE' ) RP ] <<expr '-1'>>

generated_clause ::= [ 'GENERATED' 'ALWAYS' ] 'AS' LP <<expr '-1'>> RP [ 'VIRTUAL' | 'MATERIALIZED' ]
  [ oracle_evaluation_edition_clause ] [ oracle_unusable_editions_clause ] {
  extends = "com.alecstrong.sql.psi.core.psi.impl.SqlGeneratedClauseImpl"
  implements = "com.alecstrong.sql.psi.core.psi.SqlGeneratedClause"
  override = true
}

private oracle_evaluation_edition_clause ::= 'EVALUATE' 'USING' (
  'CURRENT' 'EDITION' |
  'EDITION' oracle_object_name_part |
  'NULL' 'EDITION'
)

private oracle_unusable_editions_clause ::= (
  'UNUSABLE' 'BEFORE' ( 'CURRENT' 'EDITION' | 'EDITION' oracle_object_name_part )
) [ 'UNUSABLE' 'BEGINNING' 'WITH' ( 'CURRENT' 'EDITION' | 'EDITION' oracle_object_name_part | 'NULL' 'EDITION' ) ] | (
  'UNUSABLE' 'BEGINNING' 'WITH' ( 'CURRENT' 'EDITION' | 'EDITION' oracle_object_name_part | 'NULL' 'EDITION' )
)

private oracle_identity_clause ::= 'GENERATED' ( 'ALWAYS' | 'BY' 'DEFAULT' [ 'ON' 'NULL' ] ) 'AS' 'IDENTITY' [ oracle_parenthesized_clause ]

private oracle_encryption_spec ::= (
  'ENCRYPT' [ 'USING' {string_literal} ] [ 'IDENTIFIED' 'BY' oracle_encryption_password ] [ 'SALT' | 'NO' 'SALT' ] |
  'DECRYPT'
)

private oracle_encryption_password ::= oracle_object_name_part | {string_literal}

private oracle_inline_ref_constraint ::= (
  'SCOPE' 'IS' oracle_schema_object_name |
  'WITH' 'ROWID'
)

private oracle_constraint_state ::= (
  oracle_visibility |
  oracle_table_using_index_clause |
  oracle_exceptions_clause |
  'ENABLE' |
  'DISABLE' |
  [ 'NOT' ] 'DEFERRABLE' |
  'INITIALLY' ( 'IMMEDIATE' | 'DEFERRED' ) |
  [ 'NOT' ] 'RELY' |
  'NORELY' |
  [ 'NO' ] 'VALIDATE' |
  'NOVALIDATE' |
  'PRECHECK' |
  'NOPRECHECK'
)

private oracle_exceptions_clause ::= 'EXCEPTIONS' 'INTO' oracle_schema_object_name

private oracle_visibility ::= 'VISIBLE' | 'INVISIBLE'

private oracle_parenthesized_clause ::= LP oracle_clause_token * RP

private oracle_clause_token ::= <<identifierExt identifier_real>> | {string_literal} | string | DIGIT | {signed_number} | COMMA | DOT | LP | RP

limit_stmt ::= oracle_row_limiting_clause | oracle_sqlite_limit_clause {
  extends = "com.alecstrong.sql.psi.core.psi.impl.SqlLimitStmtImpl"
  implements = "com.alecstrong.sql.psi.core.psi.SqlLimitStmt"
  override = true
}

private oracle_sqlite_limit_clause ::= 'LIMIT' {limiting_term} [ ( 'OFFSET' | COMMA ) {limiting_term} ]

private oracle_row_limiting_clause ::= (
  'OFFSET' {limiting_term} ( 'ROW' | 'ROWS' ) [ oracle_fetch_clause ] |
  oracle_fetch_clause
)

private oracle_fetch_clause ::= 'FETCH' oracle_row_limiting_fetch_token +

private oracle_row_limiting_fetch_token ::= (
  oracle_object_name_part |
  {string_literal} |
  string |
  DIGIT |
  {signed_number} |
  COMMA |
  DOT |
  EQ |
  '+' |
  '-' |
  '*' |
  '/' |
  '||' |
  LP |
  RP |
  'APPROX' |
  'APPROXIMATE' |
  'BY' |
  'EXACT' |
  'FIRST' |
  'NEXT' |
  'ONLY' |
  'PARAMETERS' |
  'PARTITION' |
  'PARTITIONS' |
  'PERCENT' |
  'ROW' |
  'ROWS' |
  'TARGET' |
  'TIES' |
  'TO' |
  'WITH'
)

compound_operator ::= (
  'UNION' [ 'ALL' ] |
  'INTERSECT' [ 'ALL' ] |
  'EXCEPT' [ 'ALL' ] |
  'MINUS' [ 'ALL' ]
) {
  extends = "com.alecstrong.sql.psi.core.psi.impl.SqlCompoundOperatorImpl"
  implements = "com.alecstrong.sql.psi.core.psi.SqlCompoundOperator"
  override = true
}

compound_select_stmt ::= [ {with_clause} ] {select_stmt}
  ( {compound_operator} {select_stmt} ) *
  [ 'ORDER' [ 'SIBLINGS' ] 'BY' {ordering_term} ( COMMA {ordering_term} ) * ]
  [ {limit_stmt} ]
  [ oracle_for_update_clause ] {
  mixin = "dev.s7a.sqldelight.oracle.dialects.oracle.grammar.mixins.OracleCompoundSelectStmtMixin"
  implements = "com.alecstrong.sql.psi.core.psi.SqlCompoundSelectStmt"
  override = true
}

select_stmt ::= oracle_select_query | oracle_values_query {
  extends = "com.alecstrong.sql.psi.core.psi.impl.SqlSelectStmtImpl"
  implements = "com.alecstrong.sql.psi.core.psi.SqlSelectStmt"
  override = true
}

private oracle_select_query ::= 'SELECT' [ 'DISTINCT' | 'UNIQUE' | 'ALL' ]
  <<resultColumnExt <<result_column_real>>>> ( COMMA <<resultColumnExt <<result_column_real>>>> ) *
  [ 'FROM' <<joinClauseExt <<join_clause_real>>>> ]
  [ 'WHERE' <<expr '-1'>> ]
  [ oracle_hierarchical_query_clause ]
  [ oracle_group_by_having_clause ]
  [ oracle_window_clause ]
  [ oracle_qualify_clause ]

private oracle_window_clause ::= 'WINDOW' oracle_window_definition ( COMMA oracle_window_definition ) *

private oracle_window_definition ::= oracle_window_name 'AS' oracle_window_specification

private oracle_qualify_clause ::= 'QUALIFY' oracle_clause_condition

private oracle_values_query ::= 'VALUES' {values_expression} ( COMMA {values_expression} ) *

private oracle_hierarchical_query_clause ::= (
  'CONNECT' 'BY' [ 'NOCYCLE' ] oracle_clause_condition [ 'START' 'WITH' oracle_clause_condition ] |
  'START' 'WITH' oracle_clause_condition 'CONNECT' 'BY' [ 'NOCYCLE' ] oracle_clause_condition
)

private oracle_clause_condition ::= <<expr '-1'>>

private oracle_group_by_having_clause ::= (
  'HAVING' <<expr '-1'>> {group_by} [ 'HAVING' <<expr '-1'>> ] |
  <<groupByExt <<group_by_real>>>> [ 'HAVING' <<expr '-1'>> ] |
  'HAVING' <<expr '-1'>>
)

table_or_subquery ::= oracle_graph_table_reference | oracle_graphql_table_reference | oracle_json_table_reference | oracle_xmltable_reference | oracle_inline_external_table_reference | oracle_containers_table_reference | oracle_collection_table_reference | oracle_values_table_reference | oracle_subquery_table_reference | oracle_join_to_one_table_reference | oracle_table_reference | oracle_parenthesized_table_reference {
  mixin = "dev.s7a.sqldelight.oracle.dialects.oracle.grammar.mixins.OracleTableOrSubqueryMixin"
  implements = "com.alecstrong.sql.psi.core.psi.SqlTableOrSubquery"
  override = true
}

private oracle_graph_table_reference ::= 'GRAPH_TABLE' LP oracle_graph_table_token + RP
  [ oracle_table_alias_clause ]

private oracle_graph_table_boundary ::= LP oracle_graph_table_token * RP

private oracle_graph_table_token ::= (
  oracle_graph_table_boundary |
  oracle_schema_object_name |
  {string_literal} |
  string |
  DIGIT |
  {signed_number} |
  COMMA |
  DOT |
  EQ |
  GT |
  '+' |
  '-' |
  '*' |
  '?' |
  '{' |
  '}' |
  '!=' |
  '<>' |
  '<' |
  '>=' |
  '<=' |
  'ALL' |
  'AND' |
  'AS' |
  'ASC' |
  'BY' |
  'CASE' |
  'COLUMNS' |
  'COUNT' |
  'CURRENT_DATE' |
  'CURRENT_TIMESTAMP' |
  'CURRENT_TIME' |
  'DESC' |
  'DESTINATION' |
  'ELSE' |
  'END' |
  'FALSE' |
  'GROUP' |
  'IS' |
  'JSON_ARRAYAGG' |
  'LISTAGG' |
  'MATCH' |
  'NOT' |
  'NULL' |
  'OF' |
  'OR' |
  'ORDER' |
  'PER' |
  'PROPERTY' |
  'ROW' |
  'SCN' |
  'SOURCE' |
  'STEP' |
  'THEN' |
  'TIMESTAMP' |
  'TRUE' |
  'VERTEX' |
  'WHEN' |
  'WITHIN' |
  'WHERE'
)

private oracle_graphql_table_reference ::= 'GRAPHQL' LP {string_literal} [ oracle_graphql_passing_clause ] RP
  [ oracle_table_alias_clause ]

private oracle_graphql_passing_clause ::= 'PASSING' oracle_graphql_variable_binding ( COMMA oracle_graphql_variable_binding ) *

private oracle_graphql_variable_binding ::= <<expr '-1'>> 'AS' oracle_object_name_part

oracle_json_table_reference ::= 'JSON_TABLE' LP <<expr '-1'>> [ oracle_json_format_clause ]
  COMMA oracle_json_path_expression [ oracle_json_passing_clause ] oracle_json_table_row_clause * oracle_json_table_columns_clause RP
  [ oracle_table_alias_clause ]

private oracle_json_table_row_clause ::= oracle_json_table_on_error_clause | oracle_json_table_on_empty_clause

private oracle_json_table_on_error_clause ::= ( 'NULL' | 'ERROR' ) 'ON' 'ERROR'

private oracle_json_table_on_empty_clause ::= oracle_json_scalar_error_behavior 'ON' 'EMPTY'

oracle_json_table_columns_clause ::= 'COLUMNS' LP oracle_json_table_column ( COMMA oracle_json_table_column ) * RP

oracle_json_table_column ::= (
  oracle_json_table_nested_column |
  oracle_json_table_ordinality_column |
  oracle_json_table_exists_column |
  oracle_json_table_regular_column
)

oracle_json_table_ordinality_column ::= <<columnAliasExt <<column_alias_real>>>> 'FOR' 'ORDINALITY'

oracle_json_table_regular_column ::= <<columnAliasExt <<column_alias_real>>>> oracle_json_table_datatype [ 'TRUNCATE' ]
  [ oracle_json_format_clause ] [ oracle_json_table_path_clause ] oracle_json_table_value_clause *

oracle_json_table_exists_column ::= <<columnAliasExt <<column_alias_real>>>> [ oracle_json_table_datatype ]
  'EXISTS' [ oracle_json_table_path_clause ] ( oracle_json_exists_on_error_clause | oracle_json_exists_on_empty_clause ) *

oracle_json_table_nested_column ::= 'NESTED' [ 'PATH' ] oracle_json_path_expression oracle_json_table_columns_clause

private oracle_json_table_datatype ::= oracle_object_name_part [ oracle_type_parameters ] [ 'WITH' [ 'LOCAL' ] 'TIME' 'ZONE' ]

private oracle_json_table_path_clause ::= 'PATH' oracle_json_path_expression

private oracle_json_table_value_clause ::= (
  oracle_json_query_wrapper_clause |
  oracle_json_value_on_error_clause |
  oracle_json_value_on_empty_clause |
  oracle_json_query_on_error_clause |
  oracle_json_query_on_empty_clause |
  oracle_json_on_mismatch_clause
)

oracle_xmltable_reference ::= 'XMLTABLE' LP [ oracle_xmlnamespaces_clause COMMA ] {string_literal}
  [ oracle_xml_passing_clause ] [ 'RETURNING' 'SEQUENCE' 'BY' 'REF' ] [ oracle_xmltable_columns_clause ] RP
  [ oracle_table_alias_clause ]

private oracle_xmlnamespaces_clause ::= 'XMLNAMESPACES' LP oracle_xml_namespace ( COMMA oracle_xml_namespace ) * RP

private oracle_xml_namespace ::= (
  'DEFAULT' {string_literal} |
  {string_literal} 'AS' oracle_xml_name
)

oracle_xmltable_columns_clause ::= 'COLUMNS' oracle_xmltable_column ( COMMA oracle_xmltable_column ) *

oracle_xmltable_column ::= <<columnAliasExt <<column_alias_real>>>> (
  'FOR' 'ORDINALITY' |
  oracle_xmltable_datatype [ oracle_xmltype_sequence_clause ] [ 'PATH' {string_literal} ] [ 'DEFAULT' <<expr '-1'>> ]
)

private oracle_xmltable_datatype ::= oracle_object_name_part [ oracle_type_parameters ] [ 'WITH' [ 'LOCAL' ] 'TIME' 'ZONE' ]

private oracle_xmltype_sequence_clause ::= [ 'SEQUENCE' ] 'BY' 'REF'

private oracle_inline_external_table_reference ::= 'EXTERNAL' LP LP oracle_inline_external_column_definition ( COMMA oracle_inline_external_column_definition ) * RP oracle_inline_external_table_properties RP
  [ oracle_table_alias_clause ]

private oracle_inline_external_column_definition ::= oracle_object_name_part oracle_inline_external_column_type {column_constraint} *

private oracle_inline_external_column_type ::= oracle_object_name_part [ oracle_type_parameters ] ( oracle_object_name_part [ oracle_type_parameters ] ) *

private oracle_inline_external_table_properties ::= 'TYPE' [ oracle_object_name_part ]
  oracle_inline_external_table_property *

private oracle_inline_external_table_property ::= (
  'DEFAULT' 'DIRECTORY' oracle_object_name_part |
  'ACCESS' 'PARAMETERS' oracle_external_table_boundary |
  'LOCATION' oracle_external_table_boundary |
  oracle_external_table_reject_limit_clause |
  oracle_external_table_token
)

private oracle_containers_table_reference ::= ( 'CONTAINERS' | 'SHARDS' ) LP [ <<databaseNameExt <<database_name_real>>>> DOT ]
  <<tableNameExt <<table_name_real>>>> RP [ oracle_table_alias_clause ]

private oracle_collection_table_reference ::= (
  'TABLE' LP <<expr '-1'>> RP |
  'THE' LP <<compoundSelectStmtExt <<compound_select_stmt_real>>>> RP
) [ LP '+' RP ] [ oracle_table_alias_clause ]

oracle_values_table_reference ::= LP 'VALUES'
  <<valuesExpressionExt <<values_expression_real>>>> ( COMMA <<valuesExpressionExt <<values_expression_real>>>> ) *
  RP [ oracle_table_alias_with_columns_clause ]

private oracle_table_alias_with_columns_clause ::= oracle_table_alias_clause [ LP <<columnAliasExt <<column_alias_real>>>> ( COMMA <<columnAliasExt <<column_alias_real>>>> ) * RP ]

private oracle_table_reference ::= oracle_only_table_reference | oracle_plain_table_reference

private oracle_join_to_one_table_reference ::= oracle_table_reference 'JOIN' 'TO' 'ONE' LP oracle_jto_join_list RP

private oracle_jto_join_list ::= oracle_jto_join_entry ( COMMA? oracle_jto_join_entry ) *

private oracle_jto_join_entry ::= [ oracle_jto_join_spec ] oracle_jto_table_with_optional_on_clause

private oracle_jto_join_spec ::= ( 'INNER' | 'LEFT' [ 'OUTER' ] | 'OUTER' ) 'JOIN'

private oracle_jto_table_with_optional_on_clause ::= oracle_plain_table_reference [ 'ON' <<expr '-1'>> ]

private oracle_plain_table_reference ::= [ <<databaseNameExt <<database_name_real>>>> DOT ]
  <<tableNameExt <<table_name_real>>>> [ oracle_dblink_clause ] [ oracle_partition_extension_clause ] [ oracle_hierarchies_clause ] [ oracle_sample_clause ] [ oracle_modified_external_table_clause ] [ oracle_flashback_query_clause ] [ oracle_table_transform_clause ] [ oracle_table_alias_clause ] [ oracle_indexed_by_clause ]

private oracle_hierarchies_clause ::= 'HIERARCHIES' LP oracle_object_name_part ( COMMA oracle_object_name_part ) * RP

private oracle_modified_external_table_clause ::= 'EXTERNAL' 'MODIFY' ( oracle_modified_external_table_boundary | oracle_modified_external_table_token + )

private oracle_modified_external_table_boundary ::= LP oracle_modified_external_table_token * RP

private oracle_modified_external_table_token ::= (
  oracle_modified_external_table_boundary |
  oracle_external_table_reject_limit_clause |
  oracle_external_table_token |
  'BADFILE' |
  'DISCARDFILE' |
  'LOGFILE'
)

private oracle_external_table_reject_limit_clause ::= 'REJECT' 'LIMIT' ( {signed_number} | 'UNLIMITED' )

private oracle_only_table_reference ::= 'ONLY' LP ( oracle_only_named_table_reference | oracle_only_subquery_table_reference ) RP
  [ oracle_sample_clause ] [ oracle_flashback_query_clause ] [ oracle_table_transform_clause ] [ oracle_table_alias_clause ]

private oracle_only_named_table_reference ::= [ <<databaseNameExt <<database_name_real>>>> DOT ]
  <<tableNameExt <<table_name_real>>>> [ oracle_dblink_clause ] [ oracle_partition_extension_clause ]

private oracle_only_subquery_table_reference ::= LP <<compoundSelectStmtExt <<compound_select_stmt_real>>>> RP

private oracle_flashback_query_clause ::= (
  oracle_flashback_versions_clause |
  oracle_flashback_as_of_clause |
  oracle_flashback_versions_period_clause |
  oracle_flashback_as_of_period_clause
)

private oracle_flashback_versions_clause ::= 'VERSIONS' 'BETWEEN' ( 'SCN' | 'TIMESTAMP' )
  oracle_flashback_boundary 'AND' oracle_flashback_boundary [ oracle_flashback_as_of_clause ]

private oracle_flashback_as_of_clause ::= 'AS' 'OF' ( 'SCN' | 'TIMESTAMP' ) <<expr '-1'>>

private oracle_flashback_versions_period_clause ::= 'VERSIONS' 'PERIOD' 'FOR' oracle_object_name_part
  'BETWEEN' oracle_flashback_boundary 'AND' oracle_flashback_boundary

private oracle_flashback_as_of_period_clause ::= 'AS' 'OF' 'PERIOD' 'FOR' oracle_object_name_part <<expr '-1'>>

private oracle_flashback_boundary ::= 'MINVALUE' | 'MAXVALUE' | <<expr '-1'>>

private oracle_table_transform_clause ::= oracle_pivot_clause | oracle_unpivot_clause | oracle_row_pattern_clause

private oracle_pivot_clause ::= 'PIVOT' [ 'XML' ] LP
  oracle_pivot_aggregate ( COMMA oracle_pivot_aggregate ) *
  oracle_pivot_for_clause
  oracle_pivot_in_clause
  RP

private oracle_pivot_aggregate ::= oracle_aggregate_function_name LP [ oracle_function_argument ( COMMA oracle_function_argument ) * ] RP [ [ 'AS' ] oracle_object_name_part ]

private oracle_pivot_for_clause ::= 'FOR' oracle_pivot_column_group

private oracle_pivot_column_group ::= oracle_object_name_part | LP oracle_object_name_part ( COMMA oracle_object_name_part ) * RP

private oracle_pivot_in_clause ::= 'IN' LP (
  <<compoundSelectStmtExt <<compound_select_stmt_real>>>> |
  'ANY' ( COMMA 'ANY' ) * |
  oracle_pivot_in_entry ( COMMA oracle_pivot_in_entry ) *
) RP

private oracle_pivot_in_entry ::= ( LP <<expr '-1'>> ( COMMA <<expr '-1'>> ) * RP | <<expr '-1'>> ) [ [ 'AS' ] oracle_object_name_part ]

private oracle_unpivot_clause ::= 'UNPIVOT' [ ( 'INCLUDE' | 'EXCLUDE' ) 'NULLS' ] LP
  oracle_pivot_column_group
  oracle_pivot_for_clause
  oracle_unpivot_in_clause
  RP

private oracle_unpivot_in_clause ::= 'IN' LP oracle_unpivot_in_entry ( COMMA oracle_unpivot_in_entry ) * RP

private oracle_unpivot_in_entry ::= oracle_pivot_column_group [ 'AS' oracle_unpivot_literal_group ]

private oracle_unpivot_literal_group ::= oracle_unpivot_literal | LP oracle_unpivot_literal ( COMMA oracle_unpivot_literal ) * RP

private oracle_unpivot_literal ::= {string_literal} | string | DIGIT | {signed_number}

oracle_row_pattern_clause ::= 'MATCH_RECOGNIZE' LP
  [ oracle_row_pattern_partition_by_clause ]
  [ oracle_row_pattern_order_by_clause ]
  [ oracle_row_pattern_measures_clause ]
  [ oracle_row_pattern_rows_per_match_clause ]
  [ oracle_row_pattern_skip_to_clause ]
  'PATTERN' LP oracle_row_pattern RP
  [ oracle_row_pattern_subset_clause ]
  'DEFINE' oracle_row_pattern_definition ( COMMA oracle_row_pattern_definition ) *
  RP

private oracle_row_pattern_partition_by_clause ::= 'PARTITION' 'BY' oracle_row_pattern_operand ( COMMA oracle_row_pattern_operand ) *

private oracle_row_pattern_order_by_clause ::= 'ORDER' 'BY' <<orderingTermExt <<ordering_term_real>>>> ( COMMA <<orderingTermExt <<ordering_term_real>>>> ) *

oracle_row_pattern_measures_clause ::= 'MEASURES' oracle_row_pattern_measure_column ( COMMA oracle_row_pattern_measure_column ) *

oracle_row_pattern_measure_column ::= [ 'RUNNING' | 'FINAL' ] oracle_row_pattern_operand [ [ 'AS' ] <<columnAliasExt <<column_alias_real>>>> ]

private oracle_row_pattern_rows_per_match_clause ::= (
  'ONE' 'ROW' 'PER' 'MATCH' |
  'ALL' 'ROWS' 'PER' 'MATCH' [ 'SHOW' 'EMPTY' 'MATCHES' | 'OMIT' 'EMPTY' 'MATCHES' | 'WITH' 'UNMATCHED' 'ROWS' ]
)

private oracle_row_pattern_skip_to_clause ::= 'AFTER' 'MATCH' 'SKIP' (
  'PAST' 'LAST' 'ROW' |
  'TO' 'NEXT' 'ROW' |
  'TO' [ 'FIRST' | 'LAST' ] oracle_object_name_part
)

private oracle_row_pattern_subset_clause ::= 'SUBSET' oracle_row_pattern_subset_item ( COMMA oracle_row_pattern_subset_item ) *

private oracle_row_pattern_subset_item ::= oracle_object_name_part EQ LP oracle_object_name_part ( COMMA oracle_object_name_part ) * RP

private oracle_row_pattern_definition ::= oracle_object_name_part 'AS' <<expr '-1'>>

private oracle_row_pattern_operand ::= oracle_schema_object_name | {string_literal} | DIGIT | {signed_number}

private oracle_row_pattern ::= oracle_row_pattern_term ( '|' oracle_row_pattern_term ) *

private oracle_row_pattern_term ::= oracle_row_pattern_token +

private oracle_row_pattern_token ::= oracle_row_pattern_atom [ oracle_row_pattern_quantifier ]

private oracle_row_pattern_atom ::= oracle_row_pattern_permute | oracle_row_pattern_exclusion | oracle_row_pattern_group | oracle_object_name_part

private oracle_row_pattern_permute ::= 'PERMUTE' LP oracle_row_pattern_token ( COMMA oracle_row_pattern_token ) + RP

private oracle_row_pattern_exclusion ::= '{' '-' oracle_row_pattern '-' '}'

private oracle_row_pattern_group ::= LP [ oracle_row_pattern ] RP

private oracle_row_pattern_quantifier ::= ( '+' | '*' | '?' | oracle_row_pattern_bounded_quantifier ) [ '?' ]

private oracle_row_pattern_bounded_quantifier ::= (
  '{' DIGIT '}' |
  '{' DIGIT COMMA '}' |
  '{' COMMA DIGIT '}' |
  '{' DIGIT COMMA DIGIT '}'
)

private oracle_sample_clause ::= 'SAMPLE' [ 'BLOCK' ] LP <<expr '-1'>> RP [ 'SEED' LP <<expr '-1'>> RP ]

private oracle_table_alias_clause ::= [ 'AS' ] <<tableAliasExt <<table_alias_real>>>>

private oracle_indexed_by_clause ::= (
  'INDEXED' 'BY' <<indexNameExt <<index_name_real>>>> |
  'NOT' 'INDEXED'
)

private oracle_parenthesized_table_reference ::= LP (
  <<joinClauseExt <<join_clause_real>>>> |
  <<tableOrSubqueryExt <<table_or_subquery_real>>>> ( COMMA <<tableOrSubqueryExt <<table_or_subquery_real>>>> ) *
) RP

private oracle_subquery_table_reference ::= [ 'LATERAL' ] LP <<compoundSelectStmtExt <<compound_select_stmt_real>>>> [ oracle_subquery_restriction_clause ] RP [ oracle_table_transform_clause ] [ oracle_table_alias_clause ]

join_operator ::= (
  COMMA |
  'CROSS' 'APPLY' |
  'OUTER' 'APPLY' |
  [ oracle_join_partition_clause ] [ 'NATURAL' ] oracle_join_type 'JOIN'
) {
  extends = "com.alecstrong.sql.psi.core.psi.impl.SqlJoinOperatorImpl"
  implements = "com.alecstrong.sql.psi.core.psi.SqlJoinOperator"
  override = true
}

private oracle_join_partition_clause ::= 'PARTITION' 'BY' LP <<expr '-1'>> ( COMMA <<expr '-1'>> ) * RP

private oracle_join_type ::= (
  ( 'LEFT' | 'RIGHT' | 'FULL' ) [ 'OUTER' ] |
  'INNER' |
  'CROSS'
)

private oracle_for_update_clause ::= 'FOR' 'UPDATE'
  [ 'OF' oracle_for_update_column ( COMMA oracle_for_update_column ) * ]
  [ oracle_for_update_wait_clause ]

private oracle_for_update_column ::= [ oracle_object_name_part DOT [ oracle_object_name_part DOT ] ] oracle_object_name_part

private oracle_for_update_wait_clause ::= (
  'NOWAIT' |
  'WAIT' ( {signed_number} | DIGIT | 'FOREVER' ) [ 'SECONDS' | 'MILLISECONDS' | 'MICROSECONDS' ] |
  'SKIP' 'LOCKED'
)

ordering_term ::= <<expr '-1'>> [ 'COLLATE' {collation_name} ] [ 'ASC' | 'DESC' ] [ 'NULLS' ( 'FIRST' | 'LAST' ) ] {
  extends = "com.alecstrong.sql.psi.core.psi.impl.SqlOrderingTermImpl"
  implements = "com.alecstrong.sql.psi.core.psi.SqlOrderingTerm"
  override = true
}

group_by ::= 'GROUP' 'BY' oracle_group_by_elements {
  extends = "com.alecstrong.sql.psi.core.psi.impl.SqlGroupByImpl"
  implements = "com.alecstrong.sql.psi.core.psi.SqlGroupBy"
  override = true
}

private oracle_group_by_elements ::= 'ALL' | oracle_grouping_element ( COMMA oracle_grouping_element ) *

private oracle_grouping_element ::= (
  oracle_rollup_cube_clause |
  oracle_grouping_sets_clause |
  oracle_composite_grouping |
  <<expr '-1'>>
)

private oracle_rollup_cube_clause ::= ( 'ROLLUP' | 'CUBE' ) LP oracle_grouping_expression_list RP

private oracle_grouping_sets_clause ::= 'GROUPING' 'SETS' LP oracle_grouping_set ( COMMA oracle_grouping_set ) * RP

private oracle_grouping_set ::= oracle_rollup_cube_clause | LP [ oracle_grouping_expression_list ] RP | oracle_grouping_expression_list

private oracle_composite_grouping ::= LP oracle_grouping_expression_list RP

private oracle_grouping_expression_list ::= oracle_grouping_expression ( COMMA oracle_grouping_expression ) *

private oracle_grouping_expression ::= oracle_composite_grouping | <<expr '-1'>>

insert_stmt ::= [ {with_clause} ]
  ( 'INSERT' 'OR' 'REPLACE' | 'REPLACE' | 'INSERT' 'OR' 'ROLLBACK' | 'INSERT' 'OR' 'ABORT' | 'INSERT' 'OR' 'FAIL' | 'INSERT' 'OR' 'IGNORE' | 'INSERT' )
  ( oracle_single_table_insert | oracle_multi_table_insert ) {
  mixin="dev.s7a.sqldelight.oracle.dialects.oracle.grammar.mixins.OracleInsertStmtMixin"
  implements="com.alecstrong.sql.psi.core.psi.SqlInsertStmt"
  override = true
  pin = 2
}

private oracle_single_table_insert ::=
  'INTO' oracle_insert_target_table
  [ oracle_partition_extension_clause ] [ 'AS' <<tableAliasExt <<table_alias_real>>>> ]
  [ LP {column_name} ( COMMA {column_name} ) * RP ] oracle_insert_stmt_values

private oracle_insert_target_table ::= (
  'ONLY' LP [ <<databaseNameExt <<database_name_real>>>> DOT ] <<tableNameExt <<table_name_real>>>> [ oracle_dblink_clause ] RP |
  [ <<databaseNameExt <<database_name_real>>>> DOT ] <<tableNameExt <<table_name_real>>>> [ oracle_dblink_clause ]
)

private oracle_insert_stmt_values ::= (
  'VALUES' ( {bind_expr} | {values_expression} ( COMMA {values_expression} ) * ) |
  oracle_insert_set_clause |
  {compound_select_stmt} [ oracle_by_name_position_clause ] |
  'DEFAULT' 'VALUES'
) [ oracle_returning_clause ] [ oracle_wait_clause ] [ oracle_error_logging_clause ]

private oracle_insert_set_clause ::= 'SET' (
  oracle_insert_set_assignment_list |
  oracle_insert_set_row ( COMMA oracle_insert_set_row ) *
)

private oracle_insert_set_row ::= LP oracle_insert_set_assignment_list RP

private oracle_insert_set_assignment_list ::= oracle_insert_set_assignment ( COMMA oracle_insert_set_assignment ) *

private oracle_insert_set_assignment ::= {column_name} EQ ( 'DEFAULT' | <<expr '-1'>> )

private oracle_by_name_position_clause ::= 'BY' ( 'NAME' | 'POSITION' )

private oracle_multi_table_insert ::= ( 'ALL' | 'FIRST' ) oracle_multi_table_insert_clause + {compound_select_stmt}

private oracle_multi_table_insert_clause ::= (
  oracle_multi_table_insert_into_clause |
  'WHEN' <<expr '-1'>> 'THEN' oracle_multi_table_insert_into_clause + |
  'ELSE' oracle_multi_table_insert_into_clause +
)

private oracle_multi_table_insert_into_clause ::= 'INTO' oracle_insert_target_table
  [ oracle_partition_extension_clause ]
  [ LP {column_name} ( COMMA {column_name} ) * RP ]
  [ 'VALUES' LP oracle_multi_table_insert_value ( COMMA oracle_multi_table_insert_value ) * RP ]

private oracle_multi_table_insert_value ::= 'DEFAULT' | <<expr '-1'>>

update_stmt ::= oracle_update_stmt {
  mixin = "dev.s7a.sqldelight.oracle.dialects.oracle.grammar.mixins.OracleUpdateStmtMixin"
  implements = "com.alecstrong.sql.psi.core.psi.SqlUpdateStmt"
  override = true
  pin = 2
}

update_stmt_limited ::= oracle_update_stmt {
  mixin = "dev.s7a.sqldelight.oracle.dialects.oracle.grammar.mixins.OracleUpdateStmtLimitedMixin"
  implements = "com.alecstrong.sql.psi.core.psi.SqlUpdateStmtLimited"
  override = true
  pin = 2
}

private oracle_update_stmt ::= [ {with_clause} ] 'UPDATE' {qualified_table_name}
  'SET' oracle_update_set_clause ( COMMA oracle_update_set_clause ) *
  [ oracle_from_using_clause ]
  [ oracle_dml_where_clause ]
  [ oracle_wait_clause ]
  [ oracle_returning_clause ]
  [ oracle_error_logging_clause ]

private oracle_update_set_clause ::= (
  {column_name} EQ oracle_update_set_expr |
  LP {column_name} ( COMMA {column_name} ) * RP EQ LP ( <<compoundSelectStmtExt <<compound_select_stmt_real>>>> | oracle_update_set_expr ( COMMA oracle_update_set_expr ) * ) RP |
  'VALUE' LP <<tableAliasExt <<table_alias_real>>>> RP EQ {setter_expression}
)

private oracle_update_set_expr ::= 'DEFAULT' | {setter_expression}

delete_stmt ::= oracle_delete_stmt {
  mixin = "dev.s7a.sqldelight.oracle.dialects.oracle.grammar.mixins.OracleDeleteStmtMixin"
  implements = "com.alecstrong.sql.psi.core.psi.SqlDeleteStmt"
  override = true
  pin = 2
}

delete_stmt_limited ::= oracle_delete_stmt {
  mixin = "dev.s7a.sqldelight.oracle.dialects.oracle.grammar.mixins.OracleDeleteStmtLimitedMixin"
  implements = "com.alecstrong.sql.psi.core.psi.SqlDeleteStmtLimited"
  override = true
  pin = 2
}

private oracle_delete_stmt ::= [ {with_clause} ] 'DELETE' [ 'FROM' ] {qualified_table_name}
  [ oracle_dml_where_clause ]
  [ oracle_returning_clause ]
  [ oracle_error_logging_clause ]

private oracle_dml_where_clause ::= 'WHERE' ( 'CURRENT' 'OF' oracle_object_name_part | <<expr '-1'>> )

oracle_from_using_clause ::= 'FROM' oracle_from_using_source ( COMMA oracle_from_using_source ) *

private oracle_from_using_source ::= <<tableOrSubqueryExt <<table_or_subquery_real>>>> | <<joinClauseExt <<join_clause_real>>>>

private oracle_wait_clause ::= 'NOWAIT' | 'WAIT' ( 'FOREVER' | {signed_number} [ 'SECONDS' | 'MILLISECONDS' | 'MICROSECONDS' ] )

private oracle_returning_clause ::= ( 'RETURN' | 'RETURNING' ) oracle_returning_expr ( COMMA oracle_returning_expr ) * 'INTO' oracle_returning_target ( COMMA oracle_returning_target ) *

private oracle_returning_expr ::= [ 'OLD' | 'NEW' ] <<expr '-1'>>

private oracle_returning_target ::= {bind_expr} | oracle_schema_object_name

qualified_table_name ::= (
  'ONLY' LP [ <<databaseNameExt <<database_name_real>>>> DOT ] <<tableNameExt <<table_name_real>>>> [ oracle_dblink_clause ] RP |
  [ <<databaseNameExt <<database_name_real>>>> DOT ] <<tableNameExt <<table_name_real>>>> [ oracle_dblink_clause ]
) [ oracle_partition_extension_clause ] [ <<tableAliasExt <<table_alias_real>>>> ]
  [ 'INDEXED' 'BY' <<indexNameExt <<index_name_real>>>> | 'NOT' 'INDEXED' ] {
  extends = "com.alecstrong.sql.psi.core.psi.impl.SqlQualifiedTableNameImpl"
  implements = "com.alecstrong.sql.psi.core.psi.SqlQualifiedTableName"
  override = true
}

table_alias ::= !oracle_table_alias_stop_keyword ( <<identifierExt <<identifier_real>>>> | string ) {
  mixin = "dev.s7a.sqldelight.oracle.dialects.oracle.grammar.mixins.OracleTableAliasMixin"
  implements = [
    "com.alecstrong.sql.psi.core.psi.SqlTableAlias";
    "com.alecstrong.sql.psi.core.psi.NamedElement";
    "com.alecstrong.sql.psi.core.psi.AliasElement";
    "com.alecstrong.sql.psi.core.psi.SqlCompositeElement"
  ]
  override = true
}

private oracle_table_alias_stop_keyword ::= (
  'CONNECT' |
  'FOR' |
  'GROUP' |
  'HAVING' |
  'INDEXED' |
  'MINUS' |
  'NOT' |
  'ORDER' |
  'QUALIFY' |
  'START' |
  'WHERE' |
  'WINDOW'
)

with_clause ::= 'WITH' (
  oracle_plsql_declaration + [ oracle_with_clause_item ( COMMA oracle_with_clause_item ) * ] |
  oracle_with_clause_item ( COMMA oracle_with_clause_item ) *
) {
  mixin = "dev.s7a.sqldelight.oracle.dialects.oracle.grammar.mixins.OracleWithClauseMixin"
  implements = "com.alecstrong.sql.psi.core.psi.SqlWithClause"
  override = true
}

private oracle_with_clause_item ::= oracle_subquery_factoring_clause | oracle_subav_factoring_clause

private oracle_plsql_declaration ::= oracle_plsql_function_declaration | oracle_plsql_procedure_declaration

private oracle_plsql_function_declaration ::= 'FUNCTION' oracle_object_name_part
  [ oracle_plsql_parameter_list ] 'RETURN' oracle_type_name oracle_plsql_unit_property *
  ( 'AS' | 'IS' ) oracle_inline_plsql_source_token * 'END' [ oracle_object_name_part ] ';'

private oracle_plsql_procedure_declaration ::= 'PROCEDURE' oracle_object_name_part
  [ oracle_plsql_parameter_list ] oracle_plsql_unit_property *
  ( 'AS' | 'IS' ) oracle_inline_plsql_source_token * 'END' [ oracle_object_name_part ] ';'

private oracle_inline_plsql_source_token ::= (
  oracle_inline_plsql_block_end |
  oracle_object_name_part |
  {string_literal} |
  string |
  DIGIT |
  {signed_number} |
  COMMA |
  DOT |
  EQ |
  GT |
  LP |
  RP |
  ':' |
  '+' |
  '-' |
  '*' |
  '/' |
  ';' |
  'BEGIN' |
  'DEFAULT' |
  'ELSE' |
  'ELSIF' |
  'FOR' |
  'IF' |
  'IN' |
  'INOUT' |
  'LOOP' |
  'NULL' |
  'NOCOPY' |
  'OUT' |
  'RETURN' |
  'THEN'
)

private oracle_inline_plsql_block_end ::= 'END' ( 'IF' | 'LOOP' ) ';'

private oracle_subquery_factoring_clause ::= {cte_table_name} 'AS' LP {with_clause_auxiliary_stmt} RP
  [ oracle_search_clause ] [ oracle_cycle_clause ]

private oracle_subav_factoring_clause ::= oracle_object_name_part 'ANALYTIC' 'VIEW' 'AS' oracle_subav_clause

private oracle_subav_clause_token ::= (
  oracle_subav_clause |
  oracle_object_name_part |
  {string_literal} |
  string |
  DIGIT |
  {signed_number} |
  COMMA |
  DOT |
  EQ |
  '+' |
  '-' |
  '*' |
  '/' |
  '||' |
  'ADD' |
  'AND' |
  'ANALYTIC' |
  'AS' |
  'BETWEEN' |
  'FACT' |
  'FILTER' |
  'HIERARCHIES' |
  'HIERARCHY' |
  'MEASURES' |
  'OFFSET' |
  'OVER' |
  'TO' |
  'USING' |
  'VIEW'
)

private oracle_subav_clause ::= LP oracle_subav_clause_token * RP

private oracle_search_clause ::= 'SEARCH' ( 'DEPTH' | 'BREADTH' ) 'FIRST' 'BY'
  oracle_search_ordering ( COMMA oracle_search_ordering ) * 'SET' oracle_object_name_part

private oracle_search_ordering ::= oracle_object_name_part [ 'ASC' | 'DESC' ] [ 'NULLS' ( 'FIRST' | 'LAST' ) ]

private oracle_cycle_clause ::= 'CYCLE' oracle_object_name_part ( COMMA oracle_object_name_part ) *
  'SET' oracle_object_name_part 'TO' oracle_cycle_value 'DEFAULT' oracle_cycle_value

private oracle_cycle_value ::= oracle_object_name_part | {string_literal} | string | DIGIT | {signed_number}

table_constraint ::= [ 'CONSTRAINT' {identifier} ] (
  ( 'PRIMARY' 'KEY' | 'UNIQUE' ) [ {index_name} ] LP {indexed_column} ( COMMA {indexed_column} ) * RP oracle_constraint_state * |
  {check_constraint} oracle_constraint_state * |
  oracle_out_of_line_ref_constraint |
  'FOREIGN' 'KEY' LP {column_name} ( COMMA {column_name} ) * RP {foreign_key_clause} oracle_constraint_state *
) {
  extends = "com.alecstrong.sql.psi.core.psi.impl.SqlTableConstraintImpl"
  implements = "com.alecstrong.sql.psi.core.psi.SqlTableConstraint"
  override = true
}

private oracle_out_of_line_ref_constraint ::= (
  'SCOPE' 'FOR' LP oracle_schema_object_name RP 'IS' oracle_schema_object_name |
  'REF' LP oracle_schema_object_name RP 'WITH' 'ROWID'
)

create_table_stmt ::= 'CREATE' (
  [ oracle_table_kind ] 'TABLE' [ 'IF' 'NOT' 'EXISTS' ] [ {database_name} DOT ] {table_name} [ oracle_create_table_sharing_clause ] oracle_create_relational_table |
  [ oracle_table_kind ] 'JSON' 'COLLECTION' 'TABLE' [ 'IF' 'NOT' 'EXISTS' ] [ {database_name} DOT ] {table_name} [ oracle_create_table_sharing_clause ] oracle_create_json_collection_table
) oracle_create_table_top_level_clause * {
  extends = "com.alecstrong.sql.psi.core.psi.impl.SqlCreateTableStmtImpl"
  implements = "com.alecstrong.sql.psi.core.psi.SqlCreateTableStmt"
  mixin = "dev.s7a.sqldelight.oracle.dialects.oracle.grammar.mixins.OracleCreateTableStmtMixin"
  elementTypeClass = "com.alecstrong.sql.psi.core.psi.mixins.CreateTableElementType"
  stubClass = "com.alecstrong.sql.psi.core.psi.SchemaContributorStub"
  override = true
  pin = 6
}

private oracle_create_relational_table ::= (
  oracle_create_xmltype_table |
  oracle_create_object_table |
  LP {column_def} ( COMMA {column_def} ) * ( COMMA oracle_create_table_element ) * RP [ oracle_annotations_clause ] [ oracle_on_commit_clause ] oracle_create_table_property * |
  [ oracle_annotations_clause ] [ oracle_on_commit_clause ] oracle_create_table_as_property * 'AS' {compound_select_stmt}
)

private oracle_create_xmltype_table ::= 'OF' 'XMLTYPE'
  oracle_xmltype_table_property *
  oracle_create_table_property *

private oracle_xmltype_table_property ::= (
  oracle_xmlschema_spec |
  oracle_xmltype_storage |
  oracle_xmltype_virtual_columns |
  oracle_object_id_clause |
  oracle_oid_index_clause
)

private oracle_xmlschema_spec ::= [ 'XMLSCHEMA' ( string | {string_literal} ) ] 'ELEMENT' ( string | {string_literal} )
  [ 'STORE' 'ALL' 'VARRAYS' 'AS' ( 'LOBS' | 'TABLES' ) ]
  oracle_xmlschema_permission *

private oracle_xmlschema_permission ::= ( 'ALLOW' | 'DISALLOW' ) ( 'NONSCHEMA' | 'ANYSCHEMA' | 'NO' oracle_object_name_part | oracle_object_name_part )

private oracle_xmltype_storage ::= 'STORE' (
  'AS' (
    'OBJECT' 'RELATIONAL' |
    [ 'SECUREFILE' | 'BASICFILE' ] (
      'CLOB' |
      [ [ 'NOT' ] 'TRANSPORTABLE' ] 'BINARY' 'XML'
    ) [ oracle_xmltype_storage_target ]
  ) |
  'ALL' 'VARRAYS' 'AS' ( 'LOBS' | 'TABLES' )
)

private oracle_xmltype_storage_target ::= (
  oracle_column_property_boundary |
  !'BLOCKCHAIN' !'CACHE' !'CLUSTERING' !'COLUMN' !'COMPRESS' !'DEFAULT' !'DISABLE' !'ENABLE'
    !'FLASHBACK' !'FOR' !'HASHING' !'ILM' !'INDEXING' !'INMEMORY' !'JSON' !'LOB'
    !'LOGGING' !'MEMOPTIMIZE' !'NESTED' !'NO' !'NOCACHE' !'NOCOMPRESS' !'NOLOGGING'
    !'NOPARALLEL' !'NOROWDEPENDENCIES' !'NOT' !'OIDINDEX' !'ORGANIZATION' !'PARALLEL'
    !'PARENT' !'PARTITION' !'PCTFREE' !'PCTUSED' !'READ' !'REFRESH' !'RESULT_CACHE'
    !'ROW' !'ROWDEPENDENCIES' !'SEGMENT' !'STORAGE' !'STORE' !'SUBPARTITION' !'SYNCHRONOUS'
    !'TABLESPACE' !'VARRAY' !'VIRTUAL' !'WITH' !'XMLTYPE'
    oracle_object_name_part [ oracle_column_property_boundary ]
)

private oracle_xmltype_virtual_columns ::= 'VIRTUAL' 'COLUMNS' LP
  oracle_xmltype_virtual_column ( COMMA oracle_xmltype_virtual_column ) * RP

private oracle_xmltype_virtual_column ::= oracle_object_name_part 'AS' LP <<expr '-1'>> RP

private oracle_object_id_clause ::= 'WITH' 'OBJECT' 'ID' LP oracle_object_name_part ( COMMA oracle_object_name_part ) * RP

private oracle_create_object_table ::= 'OF' oracle_schema_object_name
  [ oracle_object_table_substitution ]
  oracle_object_table_property *
  oracle_create_table_property *

private oracle_object_table_substitution ::= ( 'NOT' )? 'SUBSTITUTABLE' 'AT' 'ALL' 'LEVELS'

private oracle_object_table_property ::= (
  oracle_object_identifier_clause |
  oracle_oid_index_clause |
  oracle_create_table_element
)

private oracle_object_identifier_clause ::= 'OBJECT' 'IDENTIFIER' 'IS' ( 'PRIMARY' 'KEY' | 'SYSTEM' 'GENERATED' )

private oracle_oid_index_clause ::= 'OIDINDEX' [ oracle_object_name_part ] [ LP oracle_segment_attribute_clause * RP ]

private oracle_create_json_collection_table ::= [ 'WITH' 'ETAG' ]
  [ LP oracle_json_collection_table_element ( COMMA oracle_json_collection_table_element ) * RP ]
  oracle_create_table_property *

private oracle_json_collection_table_element ::= oracle_json_collection_expression_column | {table_constraint}

private oracle_json_collection_expression_column ::= oracle_object_name_part
  [ oracle_json_collection_expression_type ]
  [ 'GENERATED' 'ALWAYS' ]
  'AS' LP <<expr '-1'>> RP
  [ 'VIRTUAL' ]
  [ oracle_visibility ]

private oracle_json_collection_expression_type ::= (
  oracle_numeric_type |
  oracle_character_type |
  oracle_binary_type |
  oracle_datetime_type |
  oracle_interval_type |
  oracle_named_type
)

private oracle_create_table_element ::= {table_constraint} | oracle_supplemental_logging_props | oracle_period_definition

private oracle_period_definition ::= 'PERIOD' 'FOR' oracle_object_name_part LP {column_name} COMMA {column_name} RP

private oracle_supplemental_logging_props ::= 'SUPPLEMENTAL' 'LOG' (
  'GROUP' oracle_object_name_part LP oracle_supplemental_log_column ( COMMA oracle_supplemental_log_column ) * RP [ 'ALWAYS' ] |
  'DATA' LP oracle_supplemental_id_key ( COMMA oracle_supplemental_id_key ) * RP 'COLUMNS'
)

private oracle_supplemental_log_column ::= {column_name} [ 'NO' 'LOG' ]

private oracle_supplemental_id_key ::= 'ALL' | 'PRIMARY' 'KEY' | 'UNIQUE' | 'FOREIGN' 'KEY'

private oracle_table_kind ::= oracle_table_scope | 'SHARDED' | 'DUPLICATED' | [ 'IMMUTABLE' ] 'BLOCKCHAIN' | 'IMMUTABLE'

private oracle_table_scope ::= ( 'GLOBAL' | 'PRIVATE' ) 'TEMPORARY' | 'TEMP' | 'TEMPORARY'

private oracle_create_table_sharing_clause ::= 'SHARING' EQ ( 'METADATA' | 'DATA' | 'EXTENDED' 'DATA' | 'NONE' )

private oracle_on_commit_clause ::= 'ON' 'COMMIT' (
  ( 'DELETE' | 'PRESERVE' ) 'ROWS' |
  ( 'DROP' | 'PRESERVE' ) 'DEFINITION'
)

private oracle_create_table_top_level_clause ::= (
  'MEMOPTIMIZE' 'FOR' ( 'READ' | 'WRITE' ) |
  'PARENT' [ {database_name} DOT ] {table_name} |
  'REFRESH' 'INTERVAL' {signed_number} ( 'SECOND' | 'MINUTE' | 'HOUR' ) |
  'SYNCHRONOUS'
)

private oracle_create_table_property ::= (
  oracle_default_collation_clause |
  oracle_table_compression |
  oracle_deferred_segment_creation |
  oracle_segment_attribute_clause |
  oracle_result_cache_clause |
  oracle_read_only_clause |
  oracle_row_movement_clause |
  oracle_logical_replication_clause |
  oracle_table_flashback_archive_clause |
  oracle_column_properties |
  oracle_attribute_clustering_clause |
  oracle_table_organization_clause |
  oracle_table_enable_disable_clause |
  oracle_ilm_clause |
  oracle_ledger_table_clause |
  oracle_table_partitioning_clause |
  oracle_for_staging_clause |
  'CACHE' |
  'NOCACHE' |
  oracle_parallel_clause |
  'ROWDEPENDENCIES' |
  'NOROWDEPENDENCIES' |
  [ 'NO' ] 'ROW' 'ARCHIVAL' |
  'INMEMORY' oracle_alter_table_property_token * |
  'NO' 'INMEMORY' |
  'INDEXING' ( 'ON' | 'OFF' )
)

private oracle_create_table_as_property ::= (
  oracle_default_collation_clause |
  oracle_table_compression |
  oracle_deferred_segment_creation |
  oracle_segment_attribute_clause |
  oracle_result_cache_clause |
  oracle_read_only_clause |
  oracle_row_movement_clause |
  oracle_logical_replication_clause |
  oracle_table_flashback_archive_clause |
  oracle_column_properties |
  oracle_attribute_clustering_clause |
  oracle_table_organization_clause |
  oracle_table_enable_disable_clause |
  oracle_ilm_clause |
  oracle_ledger_table_clause |
  oracle_table_partitioning_clause |
  oracle_for_staging_clause |
  oracle_parallel_clause |
  [ 'NO' ] 'ROW' 'ARCHIVAL' |
  oracle_create_table_as_inmemory_clause |
  'NO' 'INMEMORY' |
  'INDEXING' ( 'ON' | 'OFF' )
)

private oracle_create_table_as_inmemory_clause ::= 'INMEMORY'
  [ 'MEMCOMPRESS' [ 'FOR' ( 'DML' | 'QUERY' [ 'LOW' | 'HIGH' ] | 'CAPACITY' [ 'LOW' | 'HIGH' ] ) ] ]

private oracle_for_staging_clause ::= [ 'NOT' ] 'FOR' 'STAGING'

private oracle_default_collation_clause ::= 'DEFAULT' 'COLLATION' {collation_name}

private oracle_table_partitioning_clause ::= 'PARTITION' 'BY' (
  oracle_consistent_hash_partitions |
  oracle_directory_based_partitions |
  oracle_composite_range_partitions |
  oracle_composite_list_partitions |
  oracle_composite_hash_partitions |
  oracle_reference_partitioning |
  oracle_system_partitioning |
  oracle_range_partitions |
  oracle_list_partitions |
  oracle_hash_partitions
) {
  pin = 1
}

private oracle_range_partitions ::= 'RANGE' LP oracle_partition_key ( COMMA oracle_partition_key ) * RP
  [ 'INTERVAL' LP <<expr '-1'>> RP [ 'STORE' 'IN' LP oracle_tablespace_name_list RP ] ]
  LP oracle_range_partition_definition ( COMMA oracle_range_partition_definition ) * RP

private oracle_list_partitions ::= 'LIST' LP oracle_partition_key ( COMMA oracle_partition_key ) * RP
  [ 'AUTOMATIC' [ 'STORE' 'IN' LP oracle_tablespace_name_list RP ] ]
  LP oracle_list_partition_definition ( COMMA oracle_list_partition_definition ) * RP

private oracle_hash_partitions ::= 'HASH' LP oracle_partition_key ( COMMA oracle_partition_key ) * RP (
  LP oracle_hash_partition_definition ( COMMA oracle_hash_partition_definition ) * RP |
  'PARTITIONS' {signed_number} [ 'STORE' 'IN' LP oracle_tablespace_name_list RP ]
)

private oracle_consistent_hash_partitions ::= 'CONSISTENT' 'HASH' LP oracle_partition_key ( COMMA oracle_partition_key ) * RP
  [ 'PARTITIONS' 'AUTO' ] 'TABLESPACE' 'SET' oracle_object_name_part

private oracle_directory_based_partitions ::= 'DIRECTORY' LP oracle_partition_key ( COMMA oracle_partition_key ) * RP
  LP oracle_directory_partition_definition ( COMMA oracle_directory_partition_definition ) * RP

private oracle_directory_partition_definition ::= 'PARTITION' [ oracle_object_name_part ] oracle_partition_table_description *

private oracle_composite_range_partitions ::= 'RANGE' LP oracle_partition_key ( COMMA oracle_partition_key ) * RP
  oracle_subpartition_by_clause
  LP oracle_range_partition_with_subpartitions ( COMMA oracle_range_partition_with_subpartitions ) * RP

private oracle_composite_list_partitions ::= 'LIST' LP oracle_partition_key ( COMMA oracle_partition_key ) * RP
  oracle_subpartition_by_hash_clause
  LP oracle_list_partition_with_subpartitions ( COMMA oracle_list_partition_with_subpartitions ) * RP

private oracle_composite_hash_partitions ::= 'HASH' LP oracle_partition_key ( COMMA oracle_partition_key ) * RP
  oracle_subpartition_by_list_clause
  LP oracle_hash_partition_with_subpartitions ( COMMA oracle_hash_partition_with_subpartitions ) * RP

private oracle_reference_partitioning ::= 'REFERENCE' LP oracle_object_name_part RP
  [ LP oracle_reference_partition_definition ( COMMA oracle_reference_partition_definition ) * RP ]

private oracle_system_partitioning ::= 'SYSTEM' (
  'PARTITIONS' {signed_number} |
  [ LP oracle_reference_partition_definition ( COMMA oracle_reference_partition_definition ) * RP ]
)

private oracle_subpartition_by_clause ::= oracle_subpartition_by_range_clause | oracle_subpartition_by_list_clause | oracle_subpartition_by_hash_clause

private oracle_subpartition_by_range_clause ::= 'SUBPARTITION' 'BY' 'RANGE' LP oracle_partition_key ( COMMA oracle_partition_key ) * RP
  [ 'SUBPARTITION' 'TEMPLATE' LP oracle_range_subpartition_definition ( COMMA oracle_range_subpartition_definition ) * RP ]

private oracle_subpartition_by_list_clause ::= 'SUBPARTITION' 'BY' 'LIST' LP oracle_partition_key ( COMMA oracle_partition_key ) * RP
  [ 'SUBPARTITION' 'TEMPLATE' LP oracle_list_subpartition_definition ( COMMA oracle_list_subpartition_definition ) * RP ]

private oracle_subpartition_by_hash_clause ::= 'SUBPARTITION' 'BY' 'HASH' LP oracle_partition_key ( COMMA oracle_partition_key ) * RP
  [
    'SUBPARTITION' 'TEMPLATE' LP oracle_hash_subpartition_definition ( COMMA oracle_hash_subpartition_definition ) * RP |
    'SUBPARTITIONS' {signed_number} [ 'STORE' 'IN' LP oracle_tablespace_name_list RP ]
  ]

private oracle_partition_key ::= {column_name} | LP <<expr '-1'>> RP

private oracle_range_partition_definition ::= 'PARTITION' [ oracle_object_name_part ] 'VALUES' 'LESS' 'THAN' LP oracle_range_partition_value ( COMMA oracle_range_partition_value ) * RP oracle_partition_table_description *

private oracle_range_partition_with_subpartitions ::= 'PARTITION' [ oracle_object_name_part ] 'VALUES' 'LESS' 'THAN' LP oracle_range_partition_value ( COMMA oracle_range_partition_value ) * RP
  oracle_partition_table_description * [ LP oracle_subpartition_definition ( COMMA oracle_subpartition_definition ) * RP ]

private oracle_range_partition_value ::= 'MAXVALUE' | <<expr '-1'>>

private oracle_list_partition_definition ::= 'PARTITION' [ oracle_object_name_part ] 'VALUES' LP ( oracle_list_partition_values | 'DEFAULT' ) RP oracle_partition_table_description *

private oracle_list_partition_with_subpartitions ::= 'PARTITION' [ oracle_object_name_part ] 'VALUES' LP ( oracle_list_partition_values | 'DEFAULT' ) RP
  oracle_partition_table_description * [ LP oracle_subpartition_definition ( COMMA oracle_subpartition_definition ) * RP ]

private oracle_list_partition_values ::= oracle_list_partition_value ( COMMA oracle_list_partition_value ) *

private oracle_list_partition_value ::= <<expr '-1'>>

private oracle_hash_partition_definition ::= 'PARTITION' [ oracle_object_name_part ] oracle_partition_table_description *

private oracle_hash_partition_with_subpartitions ::= 'PARTITION' [ oracle_object_name_part ] oracle_partition_table_description *
  [ LP oracle_subpartition_definition ( COMMA oracle_subpartition_definition ) * RP ]

private oracle_reference_partition_definition ::= 'PARTITION' [ oracle_object_name_part ] oracle_partition_table_description *

private oracle_subpartition_definition ::= oracle_range_subpartition_definition | oracle_list_subpartition_definition | oracle_hash_subpartition_definition

private oracle_range_subpartition_definition ::= 'SUBPARTITION' [ oracle_object_name_part ] 'VALUES' 'LESS' 'THAN' LP oracle_range_partition_value ( COMMA oracle_range_partition_value ) * RP oracle_partition_table_description *

private oracle_list_subpartition_definition ::= 'SUBPARTITION' [ oracle_object_name_part ] 'VALUES' LP ( oracle_list_partition_values | 'DEFAULT' ) RP oracle_partition_table_description *

private oracle_hash_subpartition_definition ::= 'SUBPARTITION' [ oracle_object_name_part ] oracle_partition_table_description *

private oracle_partition_table_description ::= oracle_read_only_clause | 'INDEXING' ( 'ON' | 'OFF' ) | oracle_segment_attribute_clause | oracle_table_compression

private oracle_tablespace_name_list ::= oracle_object_name_part ( COMMA oracle_object_name_part ) *

private oracle_deferred_segment_creation ::= 'SEGMENT' 'CREATION' ( 'IMMEDIATE' | 'DEFERRED' )

private oracle_read_only_clause ::= 'READ' ( 'ONLY' | 'WRITE' )

private oracle_row_movement_clause ::= ( 'ENABLE' | 'DISABLE' ) 'ROW' 'MOVEMENT'

private oracle_logical_replication_clause ::= (
  'DISABLE' 'LOGICAL' 'REPLICATION' |
  'ENABLE' 'LOGICAL' 'REPLICATION' (
    'ALL' 'KEYS' |
    'ALLOW' 'NOVALIDATE' 'KEYS' |
    [ 'NO' ] 'PARTIAL' 'JSON'
  ) *
)

private oracle_table_flashback_archive_clause ::= (
  'BLOCKCHAIN' 'FLASHBACK' 'ARCHIVE' [ oracle_object_name_part ] |
  'FLASHBACK' 'ARCHIVE' [ oracle_object_name_part ] |
  'NO' 'FLASHBACK' 'ARCHIVE'
)

private oracle_attribute_clustering_clause ::= 'CLUSTERING'
  [ oracle_schema_object_name ]
  [ 'JOIN' oracle_schema_object_name ( COMMA oracle_schema_object_name ) * ]
  'BY' [ 'LINEAR' | 'INTERLEAVED' ] 'ORDER' LP oracle_clustering_column_group ( COMMA oracle_clustering_column_group ) * RP
  oracle_clustering_when_clause *
  [ 'WITH' 'MATERIALIZED' 'ZONEMAP' ]

private oracle_clustering_when_clause ::= ( 'YES' | 'NO' ) 'ON' ( 'LOAD' | 'DATA' 'MOVEMENT' )

private oracle_clustering_column_group ::= oracle_schema_object_name | LP oracle_schema_object_name ( COMMA oracle_schema_object_name ) * RP

private oracle_column_properties ::= (
  oracle_object_type_col_properties |
  oracle_nested_table_col_properties |
  oracle_varray_col_properties |
  oracle_lob_partition_storage |
  oracle_lob_storage_clause |
  oracle_xmltype_column_properties |
  oracle_json_storage_clause
)

private oracle_object_type_col_properties ::= 'COLUMN' oracle_schema_object_name oracle_substitutable_column_clause

private oracle_substitutable_column_clause ::= (
  'ELEMENT' 'IS' 'OF' ( 'TYPE' )? LP [ 'ONLY' ] oracle_schema_object_name RP |
  [ 'NOT' ] 'SUBSTITUTABLE' 'AT' 'ALL' 'LEVELS'
)

private oracle_nested_table_col_properties ::= 'NESTED' 'TABLE' ( oracle_schema_object_name | 'COLUMN_VALUE' )
  [ oracle_substitutable_column_clause ]
  [ 'LOCAL' | 'GLOBAL' ]
  'STORE' 'AS' oracle_object_name_part
  [ oracle_column_property_boundary ]
  [ oracle_nested_table_return_clause ]

private oracle_nested_table_return_clause ::= 'RETURN' [ 'AS' ] ( 'LOCATOR' | 'VALUE' )

private oracle_varray_col_properties ::= 'VARRAY' oracle_schema_object_name (
  [ oracle_substitutable_column_clause ] oracle_varray_storage_clause |
  oracle_substitutable_column_clause
)

private oracle_varray_storage_clause ::= 'STORE' 'AS' [ 'SECUREFILE' | 'BASICFILE' ] 'LOB' [ oracle_column_property_storage_target ]

private oracle_lob_storage_clause ::= 'LOB' LP oracle_schema_object_name ( COMMA oracle_schema_object_name ) * RP
  'STORE' 'AS' oracle_lob_storage_option +

private oracle_lob_storage_option ::= 'SECUREFILE' | 'BASICFILE' | oracle_lob_storage_target

private oracle_lob_storage_target ::= (
  oracle_column_property_boundary |
  !'BLOCKCHAIN' !'CACHE' !'CLUSTERING' !'COLUMN' !'COMPRESS' !'DEFAULT' !'DISABLE' !'ENABLE'
    !'FLASHBACK' !'FOR' !'HASHING' !'ILM' !'INDEXING' !'INMEMORY' !'JSON' !'LOB'
    !'LOGGING' !'MEMOPTIMIZE' !'NESTED' !'NO' !'NOCACHE' !'NOCOMPRESS' !'NOLOGGING'
    !'NOPARALLEL' !'NOROWDEPENDENCIES' !'NOT' !'OIDINDEX' !'ORGANIZATION' !'PARALLEL'
    !'PARENT' !'PARTITION' !'PCTFREE' !'PCTUSED' !'READ' !'REFRESH' !'RESULT_CACHE'
    !'ROW' !'ROWDEPENDENCIES' !'SEGMENT' !'STORAGE' !'STORE' !'SUBPARTITION' !'SYNCHRONOUS'
    !'TABLESPACE' !'VARRAY' !'VIRTUAL' !'WITH' !'XMLTYPE'
    oracle_object_name_part [ oracle_column_property_boundary ]
)

private oracle_column_property_storage_target ::= oracle_column_property_boundary | oracle_object_name_part [ oracle_column_property_boundary ]

private oracle_lob_partition_storage ::= 'LOB' LP oracle_schema_object_name RP 'STORE' 'AS'
  ( 'PARTITION' | 'SUBPARTITION' ) oracle_object_name_part oracle_column_property_boundary

private oracle_xmltype_column_properties ::= 'XMLTYPE' 'COLUMN' oracle_schema_object_name
  ( oracle_xmlschema_spec | oracle_xmltype_storage | oracle_column_property_boundary ) *

private oracle_json_storage_clause ::= (
  'JSON' 'COLUMN' oracle_schema_object_name 'STORE' 'AS'
    ( 'TEXT' | 'BLOB' | 'CLOB' | 'JSON' ) [ oracle_column_property_boundary ] |
  'JSON' LP oracle_schema_object_name ( COMMA oracle_schema_object_name ) * RP
    'STORE' 'AS' [ oracle_object_name_part ] [ oracle_column_property_boundary ]
)

private oracle_column_property_boundary ::= LP oracle_column_property_token * RP

private oracle_column_property_token ::= (
  oracle_column_property_boundary |
  oracle_segment_attribute_clause |
  oracle_schema_object_name |
  {string_literal} |
  string |
  DIGIT |
  {signed_number} |
  COMMA |
  DOT |
  EQ |
  'ALLOW' |
  'AUTO' |
  'BASICFILE' |
  'CACHE' |
  'CHUNK' |
  'COLUMN' |
  'COMPRESS' |
  'DEDUPLICATE' |
  'DECRYPT' |
  'DEFAULT' |
  'DISABLE' |
  'DISALLOW' |
  'DUPLICATE' |
  'ENABLE' |
  'ENCRYPT' |
  'FILESYSTEM_LIKE_LOGGING' |
  'FREEPOOLS' |
  'HIGH' |
  'IN' |
  'KEEP_DUPLICATES' |
  'LOB' |
  'LOW' |
  'MAX' |
  'MEDIUM' |
  'MIN' |
  'NOCACHE' |
  'NOCOMPRESS' |
  'NODEDUPLICATE' |
  'NOLOGGING' |
  'NONE' |
  'OUT' |
  'PCTVERSION' |
  'READS' |
  'RETENTION' |
  'ROW' |
  'SECUREFILE' |
  'STORAGE'
)

private oracle_table_organization_clause ::= 'ORGANIZATION' (
  'HEAP' oracle_segment_attribute_clause * oracle_table_compression * |
  'INDEX' oracle_segment_attribute_clause * oracle_index_organization_property * |
  'EXTERNAL' oracle_external_table_clause
)

private oracle_external_table_clause ::= oracle_external_table_boundary [ 'REJECT' 'LIMIT' ( {signed_number} | 'UNLIMITED' ) ]

private oracle_external_table_boundary ::= LP oracle_external_table_token * RP

private oracle_external_table_token ::= (
  oracle_external_table_boundary |
  {string_literal} |
  string |
  DIGIT |
  {signed_number} |
  COMMA |
  DOT |
  EQ |
  'ACCESS' |
  'BY' |
  'DEFAULT' |
  'DELIMITED' |
  'DIRECTORY' |
  'LOCATION' |
  'NEWLINE' |
  'PARAMETERS' |
  'PREPROCESSOR' |
  'RECORDS' |
  'TYPE' |
  oracle_schema_object_name
)

private oracle_index_organization_property ::= (
  'MAPPING' 'TABLE' |
  'NOMAPPING' |
  'PCTTHRESHOLD' {signed_number} |
  oracle_index_organized_compression |
  [ 'INCLUDING' {column_name} ] 'OVERFLOW' oracle_segment_attribute_clause *
)

private oracle_index_organized_compression ::= (
  'COMPRESS' [ 'ADVANCED' [ 'LOW' ] | {signed_number} ] |
  'NOCOMPRESS'
)

private oracle_table_enable_disable_clause ::= ( 'ENABLE' | 'DISABLE' ) [ 'VALIDATE' | 'NOVALIDATE' ] (
  'UNIQUE' LP {column_name} ( COMMA {column_name} ) * RP |
  'PRIMARY' 'KEY' |
  'CONSTRAINT' oracle_object_name_part
) [ oracle_table_using_index_clause ] [ 'CASCADE' ] [ ( 'KEEP' | 'DROP' ) 'INDEX' ]

private oracle_table_using_index_clause ::= 'USING' 'INDEX' (
  oracle_index_attribute + |
  oracle_schema_object_name
)

private oracle_ilm_clause ::= 'ILM' (
  'ADD' 'POLICY' oracle_ilm_policy_clause |
  ( 'DELETE' | 'ENABLE' | 'DISABLE' ) 'POLICY' oracle_object_name_part |
  'DELETE_ALL' |
  'ENABLE_ALL' |
  'DISABLE_ALL'
)

private oracle_ilm_policy_clause ::= (
  oracle_ilm_compression_policy |
  oracle_ilm_tiering_policy |
  oracle_ilm_inmemory_policy
)

private oracle_ilm_compression_policy ::= (
  oracle_table_compression ( 'SEGMENT' | 'GROUP' ) oracle_ilm_policy_condition |
  ( 'ROW' 'STORE' 'COMPRESS' 'ADVANCED' | 'COLUMN' 'STORE' 'COMPRESS' 'FOR' 'QUERY' ) 'ROW' 'AFTER' oracle_ilm_time_period 'OF' 'NO' 'MODIFICATION'
)

private oracle_ilm_tiering_policy ::= 'TIER' 'TO' oracle_object_name_part
  [ 'READ' 'ONLY' ] [ 'SEGMENT' | 'GROUP' ] [ oracle_ilm_policy_condition ]

private oracle_ilm_inmemory_policy ::= (
  'SET' 'INMEMORY' oracle_alter_table_property_token * |
  'MODIFY' 'INMEMORY' oracle_alter_table_property_token + |
  'NO' 'INMEMORY'
) [ 'SEGMENT' ] oracle_ilm_policy_condition

private oracle_ilm_policy_condition ::= (
  'AFTER' oracle_ilm_time_period 'OF' ( 'NO' 'ACCESS' | 'NO' 'MODIFICATION' | 'CREATION' ) |
  'ON' oracle_schema_object_name
)

private oracle_ilm_time_period ::= {signed_number} ( 'DAY' | 'DAYS' | 'MONTH' | 'MONTHS' | 'YEAR' | 'YEARS' )

private oracle_ledger_table_clause ::= (
  'NO' 'DROP' [ 'UNTIL' {signed_number} 'DAYS' 'IDLE' ] |
  'NO' 'DELETE' ( 'LOCKED' | 'UNTIL' {signed_number} 'DAYS' 'AFTER' 'INSERT' [ 'LOCKED' ] ) |
  oracle_blockchain_hash_clause
)

private oracle_blockchain_hash_clause ::=
  'HASHING' 'USING' oracle_ledger_clause_value [ oracle_blockchain_row_version_user_chain_clause ] [ 'VERSION' oracle_ledger_clause_value ]

private oracle_blockchain_row_version_user_chain_clause ::=
  'WITH' 'ROW' 'VERSION' [ 'AND' 'USER' 'CHAIN' ] oracle_object_name_part LP {column_name} ( COMMA {column_name} ) * RP

private oracle_ledger_clause_value ::= {string_literal} | string | oracle_object_name_part

private oracle_result_cache_clause ::= 'RESULT_CACHE' LP (
  'MODE' ( 'DEFAULT' | 'FORCE' ) [ COMMA 'STANDBY' ( 'ENABLE' | 'DISABLE' ) ] |
  'STANDBY' ( 'ENABLE' | 'DISABLE' ) [ COMMA 'MODE' ( 'DEFAULT' | 'FORCE' ) ]
) RP

private oracle_segment_attribute_clause ::= (
  ( 'TABLESPACE' [ 'SET' ] oracle_object_name_part ) |
  oracle_logging_clause |
  oracle_storage_clause |
  'PCTFREE' {signed_number} |
  'PCTUSED' {signed_number} |
  'INITRANS' {signed_number}
)

private oracle_logging_clause ::= 'LOGGING' | 'NOLOGGING' | 'FILESYSTEM_LIKE_LOGGING'

private oracle_storage_clause ::= 'STORAGE' LP oracle_storage_parameter + RP

private oracle_storage_parameter ::= (
  ( 'INITIAL' | 'NEXT' | 'MAXSIZE' ) oracle_size_value |
  'MINEXTENTS' {signed_number} |
  'MAXEXTENTS' ( {signed_number} | 'UNLIMITED' ) |
  'PCTINCREASE' {signed_number} |
  'FREELISTS' {signed_number} |
  'FREELIST' 'GROUPS' {signed_number} |
  'OPTIMAL' [ oracle_size_value | 'NULL' ] |
  'BUFFER_POOL' ( 'KEEP' | 'RECYCLE' | 'DEFAULT' ) |
  'FLASH_CACHE' ( 'KEEP' | 'NONE' | 'DEFAULT' ) |
  'CELL_FLASH_CACHE' ( 'KEEP' | 'NONE' | 'DEFAULT' ) |
  'ENCRYPT'
)

private oracle_size_value ::= oracle_size_clause

private oracle_table_compression ::= (
  'COMPRESS' [
    'ADVANCED' [ 'LOW' | 'HIGH' ] |
    'BASIC' |
    'FOR' ( 'OLTP' | ( 'QUERY' | 'ARCHIVE' ) [ 'LOW' | 'HIGH' ] ) |
    {signed_number}
  ] |
  'ROW' 'STORE' 'COMPRESS' [ 'BASIC' | 'ADVANCED' ] |
  'COLUMN' 'STORE' 'COMPRESS' [ 'FOR' [ 'MEMSPEED' ] ( 'QUERY' | 'ARCHIVE' ) [ 'LOW' | 'HIGH' ] ] [ [ 'NO' ] 'ROW' 'LEVEL' 'LOCKING' ] |
  'NOCOMPRESS'
)

private oracle_parallel_clause ::= 'NOPARALLEL' | 'PARALLEL' [ DIGIT | {signed_number} ]

alter_table_stmt ::= 'ALTER' 'TABLE' [ 'IF' 'EXISTS' ] [ {database_name} DOT ] {table_name} {alter_table_rules} ( COMMA {alter_table_rules} ) * {
  extends = "com.alecstrong.sql.psi.core.psi.impl.SqlAlterTableStmtImpl"
  implements = "com.alecstrong.sql.psi.core.psi.SqlAlterTableStmt"
  elementTypeClass = "dev.s7a.sqldelight.oracle.dialects.oracle.grammar.mixins.AlterTableElementType"
  stubClass = "com.alecstrong.sql.psi.core.psi.mixins.AlterTableStmtStub"
  override = true
  pin = 1
}

alter_table_rules ::= (
  alter_table_set_subpartition_template |
  alter_table_partition_maintenance |
  alter_table_iot_clause |
  alter_table_add_clustering |
  alter_table_add_supplemental_logging |
  alter_table_add_hashing |
  alter_table_add_columns |
  alter_table_add_constraint |
  alter_table_add_period |
  alter_table_add_column |
  alter_table_annotations |
  alter_table_become_immutable |
  alter_table_enable_disable |
  alter_table_result_cache |
  alter_table_flashback_archive |
  alter_table_logical_replication |
  alter_table_ilm |
  alter_table_memoptimize |
  alter_table_records_per_block |
  alter_table_upgrade |
  alter_table_default_collation |
  alter_table_rekey |
  alter_table_for_staging |
  alter_table_modify_clustering |
  alter_table_drop_clustering |
  alter_table_external_properties |
  alter_table_modify_xmltype_storage |
  alter_table_modify_lob_storage |
  alter_table_modify_varray_storage |
  alter_table_modify_default_attributes |
  alter_table_modify_constraint |
  alter_table_modify_column_substitutable |
  alter_table_modify_column_annotations |
  alter_table_modify_collection_retrieval |
  alter_table_modify_columns |
  alter_table_modify_column |
  alter_table_drop_period |
  alter_table_rename_constraint |
  alter_table_rename_table |
  alter_table_drop_supplemental_logging |
  alter_table_drop_constraint |
  alter_table_drop_column |
  alter_table_set_unused_column |
  alter_table_rename_column |
  alter_table_oracle_properties
) {
  extends = "com.alecstrong.sql.psi.core.psi.impl.SqlAlterTableRulesImpl"
  implements = "com.alecstrong.sql.psi.core.psi.SqlAlterTableRules"
  override = true
}

alter_table_add_column ::= 'ADD' [ 'COLUMN' ] {column_def} {
  extends = "com.alecstrong.sql.psi.core.psi.impl.SqlAlterTableAddColumnImpl"
  implements = "com.alecstrong.sql.psi.core.psi.SqlAlterTableAddColumn"
  override = true
  pin = 1
}

alter_table_add_columns ::= 'ADD' [ 'COLUMN' ] LP {column_def} ( COMMA {column_def} ) * RP {
  mixin = "dev.s7a.sqldelight.oracle.dialects.oracle.grammar.mixins.AlterTableAddColumnsMixin"
}

alter_table_add_constraint ::= 'ADD' {table_constraint} {
  mixin = "dev.s7a.sqldelight.oracle.dialects.oracle.grammar.mixins.AlterTableAddConstraintMixin"
}

private alter_table_add_period ::= 'ADD' 'PERIOD' 'FOR' oracle_object_name_part LP {column_name} COMMA {column_name} RP

alter_table_modify_columns ::= 'MODIFY' [ 'COLUMN' ] LP {column_def} ( COMMA {column_def} ) * RP {
  mixin = "dev.s7a.sqldelight.oracle.dialects.oracle.grammar.mixins.AlterTableModifyColumnsMixin"
}

alter_table_modify_column ::= 'MODIFY' [ 'COLUMN' ] {column_def} {
  mixin = "dev.s7a.sqldelight.oracle.dialects.oracle.grammar.mixins.AlterTableModifyColumnMixin"
  pin = 1
}

private alter_table_annotations ::= oracle_annotations_clause

private alter_table_modify_column_annotations ::= 'MODIFY' [ 'COLUMN' ] {column_name} oracle_annotations_clause

private alter_table_enable_disable ::= oracle_table_enable_disable_clause | oracle_alter_table_enable_disable_clause

private oracle_alter_table_enable_disable_clause ::= ( 'ENABLE' | 'DISABLE' )
  ( 'TABLE' 'LOCK' | 'ALL' 'TRIGGERS' | 'CONTAINER_MAP' | 'CONTAINERS_DEFAULT' )

private alter_table_result_cache ::= oracle_result_cache_clause

private alter_table_flashback_archive ::= oracle_table_flashback_archive_clause

private alter_table_logical_replication ::= oracle_logical_replication_clause

private alter_table_ilm ::= oracle_ilm_clause

private alter_table_memoptimize ::= [ 'NO' ] 'MEMOPTIMIZE' 'FOR' ( 'READ' | 'WRITE' )

private alter_table_records_per_block ::= ( 'MINIMIZE' | 'NOMINIMIZE' ) 'RECORDS_PER_BLOCK'

private alter_table_upgrade ::= 'UPGRADE' [ [ 'NOT' ] 'INCLUDING' 'DATA' ]

private alter_table_default_collation ::= oracle_default_collation_clause

private alter_table_rekey ::= 'REKEY' oracle_encryption_spec

private alter_table_for_staging ::= oracle_for_staging_clause

private alter_table_add_clustering ::= 'ADD' oracle_attribute_clustering_clause

private alter_table_add_supplemental_logging ::= 'ADD' oracle_supplemental_logging_props

private alter_table_modify_clustering ::= 'MODIFY' oracle_attribute_clustering_clause

private alter_table_drop_clustering ::= 'DROP' 'CLUSTERING'

private alter_table_external_properties ::= oracle_external_table_property +

private oracle_external_table_property ::= (
  'DEFAULT' 'DIRECTORY' oracle_object_name_part |
  'ACCESS' 'PARAMETERS' oracle_external_table_boundary |
  'LOCATION' oracle_external_table_boundary |
  oracle_external_table_reject_limit_clause
)

private alter_table_modify_collection_retrieval ::= 'MODIFY' 'NESTED' 'TABLE' oracle_object_name_part 'RETURN' 'AS' ( 'LOCATOR' | 'VALUE' )

private alter_table_modify_column_substitutable ::= 'MODIFY' [ 'COLUMN' ] oracle_schema_object_name oracle_substitutable_column_clause

private alter_table_modify_xmltype_storage ::= 'MODIFY' 'XMLTYPE' 'COLUMN' oracle_object_name_part oracle_alter_table_property_token *

private alter_table_modify_lob_storage ::= 'MODIFY' 'LOB' LP oracle_schema_object_name ( COMMA oracle_schema_object_name ) * RP
  oracle_alter_table_property_token *

private alter_table_modify_varray_storage ::= 'MODIFY' 'VARRAY' oracle_schema_object_name (
  'STORE' 'AS' [ 'SECUREFILE' | 'BASICFILE' ] 'LOB' [ oracle_column_property_storage_target ] |
  oracle_column_property_boundary
)

private alter_table_modify_default_attributes ::= 'MODIFY' 'DEFAULT' 'ATTRIBUTES'
  [ 'FOR' ( 'PARTITION' | 'SUBPARTITION' ) oracle_object_name_part ]
  oracle_alter_table_property_token *

private alter_table_set_subpartition_template ::= 'SET' 'SUBPARTITION' 'TEMPLATE'
  LP [ oracle_subpartition_definition ( COMMA oracle_subpartition_definition ) * ] RP

private alter_table_iot_clause ::= (
  'ADD' 'OVERFLOW' oracle_segment_attribute_clause * |
  'OVERFLOW' oracle_iot_storage_clause + |
  'MAPPING' 'TABLE' ( oracle_allocate_extent_clause | oracle_deallocate_unused_clause ) +
)

private oracle_iot_storage_clause ::= oracle_segment_attribute_clause | oracle_allocate_extent_clause | oracle_deallocate_unused_clause | oracle_shrink_clause

private oracle_allocate_extent_clause ::= 'ALLOCATE' 'EXTENT' [ LP 'SIZE' oracle_size_clause RP ]

private oracle_deallocate_unused_clause ::= 'DEALLOCATE' 'UNUSED' [ 'KEEP' oracle_size_clause ]

private oracle_shrink_clause ::= 'SHRINK' 'SPACE' [ 'COMPACT' | 'CASCADE' ]

private alter_table_partition_maintenance ::= (
  ( 'ADD' | 'DROP' | 'TRUNCATE' | 'MOVE' | 'SPLIT' | 'MERGE' | 'EXCHANGE' | 'COALESCE' | 'MODIFY' | 'RENAME' )
  ( 'PARTITION' | 'SUBPARTITION' )
  oracle_alter_table_property_token *
)

private alter_table_add_hashing ::= 'ADD' oracle_blockchain_hash_clause

private alter_table_become_immutable ::= 'MODIFY' 'IMMUTABLE'
  oracle_ledger_table_clause *
  [ 'USE' <<expr '-1'>> 'FOR' 'ROW' 'CREATION' 'TIME' ]

private alter_table_drop_period ::= 'DROP' 'PERIOD' 'FOR' oracle_object_name_part

private alter_table_modify_constraint ::= 'MODIFY' 'CONSTRAINT' oracle_object_name_part oracle_constraint_state * [ 'CASCADE' ]

private alter_table_rename_constraint ::= 'RENAME' 'CONSTRAINT' oracle_object_name_part 'TO' oracle_object_name_part

private alter_table_rename_table ::= 'RENAME' 'TO' oracle_object_name_part

private alter_table_drop_supplemental_logging ::= 'DROP' 'SUPPLEMENTAL' 'LOG' (
  'GROUP' oracle_object_name_part |
  'DATA' LP oracle_supplemental_id_key ( COMMA oracle_supplemental_id_key ) * RP 'COLUMNS'
)

alter_table_drop_constraint ::= 'DROP' (
  'CONSTRAINT' {identifier} |
  'PRIMARY' 'KEY' |
  'UNIQUE' LP {column_name} ( COMMA {column_name} ) * RP
) [ 'CASCADE' ] [ ( 'KEEP' | 'DROP' ) 'INDEX' ] [ 'ONLINE' ] {
  pin = 2
}

alter_table_drop_column ::= 'DROP' [ 'COLUMN' ] {column_name} [ 'CASCADE' 'CONSTRAINTS' ] {
  mixin = "dev.s7a.sqldelight.oracle.dialects.oracle.grammar.mixins.AlterTableDropColumnMixin"
  pin = 1
}

private alter_table_set_unused_column ::= 'SET' 'UNUSED' [ 'COLUMN' ] ( {column_name} | LP {column_name} ( COMMA {column_name} ) * RP ) [ 'CASCADE' 'CONSTRAINTS' ] [ 'ONLINE' ]

alter_table_rename_column ::= 'RENAME' [ 'COLUMN' ] {column_name} 'TO' {column_alias} {
  mixin = "dev.s7a.sqldelight.oracle.dialects.oracle.grammar.mixins.AlterTableRenameColumnMixin"
  pin = 1
}

private alter_table_oracle_properties ::= oracle_alter_table_property_token +

