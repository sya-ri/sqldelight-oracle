private oracle_subquery_restriction_clause ::= 'WITH'
  ( [ 'CASCADED' | 'LOCAL' ] 'CHECK' 'OPTION' [ 'CONSTRAINT' oracle_object_name_part ] |
    'READ' 'ONLY' [ 'CONSTRAINT' oracle_object_name_part ] )

private alter_view_stmt ::= 'ALTER' 'VIEW' [ 'IF' 'EXISTS' ] [ {database_name} DOT ] {view_name} oracle_alter_view_clause {
  pin = 2
}

private oracle_alter_view_clause ::= (
  'ADD' oracle_alter_view_constraint |
  'MODIFY' ( oracle_alter_view_modify_constraint | LP oracle_alter_view_column_annotation ( COMMA oracle_alter_view_column_annotation ) * RP ) |
  oracle_alter_view_drop_constraint |
  ( 'COMPILE' | 'RECOMPILE' ) |
  'READ' ( 'ONLY' | 'WRITE' ) |
  'EDITIONABLE' |
  'NONEDITIONABLE' |
  oracle_annotations_clause
)

private oracle_alter_view_constraint ::= [ 'CONSTRAINT' oracle_object_name_part ] (
  ( 'PRIMARY' 'KEY' | 'UNIQUE' ) LP oracle_object_name_part ( COMMA oracle_object_name_part ) * RP oracle_constraint_state *
)

private oracle_alter_view_modify_constraint ::= 'CONSTRAINT' oracle_object_name_part ( 'RELY' | 'NORELY' )

private oracle_alter_view_column_annotation ::= oracle_object_name_part oracle_annotations_clause

private oracle_alter_view_drop_constraint ::= 'DROP' (
  'CONSTRAINT' oracle_object_name_part |
  'PRIMARY' 'KEY' |
  'UNIQUE' LP oracle_object_name_part ( COMMA oracle_object_name_part ) * RP
)

