create_index_stmt ::= 'CREATE' [ 'JSON' ] [ oracle_index_kind ] 'INDEX' [ 'IF' 'NOT' 'EXISTS' ] [ {database_name} DOT ] {index_name}
  [ oracle_index_ilm_clause ] 'ON' ( oracle_cluster_index_clause | oracle_table_index_clause ) [ oracle_annotations_clause ] oracle_index_post_attribute * {
  extends = "com.alecstrong.sql.psi.core.psi.impl.SqlCreateIndexStmtImpl"
  implements = "com.alecstrong.sql.psi.core.psi.SqlCreateIndexStmt"
  elementTypeClass = "com.alecstrong.sql.psi.core.psi.mixins.CreateIndexElementType"
  stubClass = "com.alecstrong.sql.psi.core.psi.SchemaContributorStub"
  override = true
}

drop_index_stmt ::= 'DROP' 'INDEX' [ 'IF' 'EXISTS' ] [ {database_name} DOT ] {index_name}
  [ 'ONLINE' ] [ 'FORCE' ] [ oracle_index_post_attribute ] {
  extends = "com.alecstrong.sql.psi.core.psi.impl.SqlDropIndexStmtImpl"
  implements = "com.alecstrong.sql.psi.core.psi.SqlDropIndexStmt"
  override = true
  pin = 2
}

private oracle_index_kind ::= 'UNIQUE' | 'BITMAP' | 'MULTIVALUE' | 'SPARSE' | 'DENSE' | 'VECTOR' | 'HYBRID' 'VECTOR'

private oracle_cluster_index_clause ::= 'CLUSTER' {table_name} oracle_index_attribute *

private oracle_table_index_clause ::= [ {database_name} DOT ] {table_name} [ oracle_object_name_part ]
  LP {indexed_column} ( COMMA {indexed_column} ) * RP oracle_index_attribute *

private oracle_index_ilm_clause ::= 'ILM' oracle_index_boundary_token *

private oracle_index_post_attribute ::= 'USABLE' | 'UNUSABLE' | ( 'DEFERRED' | 'IMMEDIATE' ) 'INVALIDATION'

alter_index_stmt ::= 'ALTER' 'INDEX' [ 'IF' 'EXISTS' ] oracle_schema_object_name oracle_alter_index_clause + {
  pin = 2
}

private oracle_alter_index_clause ::= oracle_alter_index_rebuild_clause

private oracle_alter_index_rebuild_clause ::= 'REBUILD'
  [ ( 'PARTITION' | 'SUBPARTITION' ) oracle_object_name_part ]
  oracle_index_attribute *

private oracle_index_attribute ::= (
  oracle_visibility |
  oracle_vector_index_attribute |
  oracle_domain_index_clause |
  oracle_index_partition_clause |
  oracle_index_parameters_clause |
  oracle_index_storage_clause |
  'REVERSE' |
  'ONLINE' |
  'TABLESPACE' oracle_index_tablespace_name |
  'NOLOGGING' |
  'LOGGING' |
  'UNUSABLE' |
  'USABLE' |
  'COMPUTE' 'STATISTICS' |
  ( 'SORT' | 'NOSORT' ) |
  'COMPRESS' [ 'ADVANCED' [ 'LOW' | 'HIGH' ] | {signed_number} ] |
  'NOCOMPRESS' |
  'INDEXING' ( 'FULL' | 'PARTIAL' ) |
  'PARALLEL' [ DIGIT | oracle_object_name_part ] |
  'NOPARALLEL' |
  'PCTFREE' {signed_number} |
  'INITRANS' {signed_number} |
  'MAXTRANS' {signed_number} |
  'FROM' oracle_index_boundary_token + |
  'WHERE' oracle_index_boundary_token +
)

private oracle_index_tablespace_name ::= {identifier} | string | 'DEFAULT'

private oracle_domain_index_clause ::= 'INDEXTYPE' 'IS' oracle_schema_object_name
  [ 'LOCAL' oracle_index_boundary_token * ] [ oracle_index_parameters_clause ] [ 'PARALLEL' [ DIGIT | oracle_object_name_part ] ]

private oracle_index_parameters_clause ::= 'PARAMETERS' LP oracle_index_boundary_token * RP

private oracle_index_storage_clause ::= 'STORAGE' LP oracle_index_storage_token * RP {
  pin = 1
}

private oracle_index_storage_token ::= (
  oracle_index_storage_parenthesized_clause |
  oracle_size_clause |
  oracle_object_name_part |
  {string_literal} |
  string |
  DIGIT |
  {signed_number} |
  COMMA |
  DOT |
  EQ |
  'BUFFER_POOL' |
  'CELL_FLASH_CACHE' |
  'ENCRYPT' |
  'FLASH_CACHE' |
  'FREELIST' |
  'FREELISTS' |
  'GROUPS' |
  'INITIAL' |
  'KEEP' |
  'MAXEXTENTS' |
  'MINEXTENTS' |
  'NEXT' |
  'NONE' |
  'OPTIMAL' |
  'PCTINCREASE' |
  'RECYCLE'
)

private oracle_index_storage_parenthesized_clause ::= LP oracle_index_storage_token * RP

private oracle_index_partition_clause ::= (
  'GLOBAL' oracle_index_boundary_token * |
  'LOCAL' oracle_index_boundary_token * |
  'PARTITION' oracle_index_boundary_token * |
  'SUBPARTITION' oracle_index_boundary_token *
)

private oracle_index_boundary_token ::= (
  oracle_index_storage_clause |
  oracle_dimension_reference |
  oracle_plsql_source_token |
  oracle_parenthesized_clause |
  oracle_size_clause |
  'ADD' |
  'AFTER' |
  'ALL' |
  'ALTER' |
  'AUTOMATIC' |
  'BY' |
  'COLUMNS' |
  'CREATE' |
  'DELETE' |
  'EVALUATE' |
  'GROUP' |
  'HASH' |
  'HIGH' |
  'ILM' |
  'IN' |
  'INDEXING' |
  'INTERVAL' |
  'LESS' |
  'LIST' |
  'LOW' |
  'MAXVALUE' |
  'MODIFY' |
  'NOT' |
  'NULL' |
  'OPTIMIZE' |
  'PARTITION' |
  'PCTFREE' |
  'POLICY' |
  'RANGE' |
  'SEGMENT' |
  'STORAGE' |
  'SUBPARTITION' |
  'THAN' |
  'TIER' |
  'TO' |
  'UNUSABLE' |
  'VALUES'
)

private oracle_vector_index_attribute ::= (
  'INCLUDE' LP oracle_vector_parameter_value_token * RP |
  'GLOBAL' |
  'ORGANIZATION' [ 'INMEMORY' ] 'NEIGHBOR' ( 'GRAPH' | 'PARTITIONS' ) |
  'DISTANCE' oracle_object_name_part |
  'WITH' 'TARGET' 'ACCURACY' ( {signed_number} | DIGIT | oracle_object_name_part ) |
  oracle_vector_parameters_clause |
  'QUANTIZATION' oracle_object_name_part 'COMPRESSION' 'RATIO' ( {signed_number} | DIGIT | oracle_object_name_part ) |
  ( 'DUPLICATE' 'ALL' | 'DISTRIBUTE' oracle_vector_index_boundary_token * ) |
  'PARALLEL' [ DIGIT | oracle_object_name_part ] |
  'LOCAL'
)

private oracle_vector_parameters_clause ::= 'PARAMETERS' LP oracle_vector_index_parameter_token * RP {
  pin = 1
}

private oracle_vector_index_parameter_token ::= (
  oracle_vector_parameter_value_token |
  'ACCURACY' |
  'EFCONSTRUCTION' |
  'HNSW' |
  'IVF' |
  'MIN_VECTORS_PER_PARTITION' |
  'NEIGHBOR' |
  'NEIGHBORS' |
  'OFFLOAD_CREDENTIAL_NAME' |
  'OFFLOAD_URL' |
  'PARTITIONS' |
  'SAMPLES_PER_PARTITION' |
  'TYPE'
)

private oracle_vector_parameter_value_token ::= (
  oracle_dimension_reference |
  oracle_object_name_part |
  {string_literal} |
  string |
  DIGIT |
  {signed_number} |
  COMMA |
  DOT |
  EQ
)

private oracle_vector_index_boundary_token ::= (
  oracle_dimension_reference |
  oracle_plsql_source_token |
  oracle_parenthesized_clause |
  'AUTO' |
  'BY' |
  'PARTITION' |
  'RANGE' |
  'ROWID' |
  'SUBPARTITION'
)

create_view_stmt ::= 'CREATE' [ 'OR' 'REPLACE' ] [ 'FORCE' | 'NO' 'FORCE' ]
  [ 'EDITIONING' | 'EDITIONABLE' [ 'EDITIONING' ] | 'NONEDITIONABLE' ] [ 'JSON' 'COLLECTION' ] 'VIEW'
  [ 'IF' 'NOT' 'EXISTS' ] [ {database_name} DOT ] {view_name} [ oracle_view_sharing_clause ]
  [ oracle_view_column_clause | oracle_xmltype_view_clause | oracle_object_view_clause ]
  [ 'DEFAULT' 'COLLATION' oracle_object_name_part ] [ 'BEQUEATH' ( 'CURRENT_USER' | 'DEFINER' ) ]
  [ oracle_annotations_clause ] 'AS' {compound_select_stmt} [ 'BEQUEATH' ( 'CURRENT_USER' | 'DEFINER' ) ]
  [ oracle_subquery_restriction_clause ]
  [ 'CONTAINER_MAP' | 'CONTAINERS_DEFAULT' ] {
  mixin = "dev.s7a.sqldelight.oracle.dialects.oracle.grammar.mixins.OracleCreateViewStmtMixin"
  implements = "com.alecstrong.sql.psi.core.psi.TableElement"
  elementTypeClass = "com.alecstrong.sql.psi.core.psi.mixins.CreateViewElementType"
  stubClass = "com.alecstrong.sql.psi.core.psi.SchemaContributorStub"
  override = true
  pin = 6
}

private oracle_view_sharing_clause ::= 'SHARING' EQ ( 'METADATA' | 'DATA' | 'EXTENDED' 'DATA' | 'NONE' )

private oracle_view_column_clause ::= LP oracle_view_column_token * RP

private oracle_view_column_group ::= LP oracle_view_column_token * RP

private oracle_view_column_token ::= (
  oracle_view_column_group |
  oracle_object_name_part |
  {string_literal} |
  string |
  DIGIT |
  {signed_number} |
  COMMA |
  DOT |
  EQ |
  'ANNOTATIONS' |
  'CONSTRAINT' |
  'DISABLE' |
  'ENABLE' |
  'INVISIBLE' |
  'NOVALIDATE' |
  'UNIQUE' |
  'PRIMARY' 'KEY' |
  'REFERENCES' |
  'RELY' |
  'VISIBLE' |
  'VALIDATE'
)

private oracle_object_view_clause ::= 'OF' oracle_schema_object_name oracle_object_view_option *

private oracle_object_view_option ::= (
  'WITH' 'OBJECT' ( 'IDENTIFIER' | 'ID' | 'OID' ) oracle_view_object_identifier_clause |
  'UNDER' oracle_schema_object_name |
  oracle_view_column_clause
)

private oracle_xmltype_view_clause ::= 'OF' 'XMLTYPE'
  [ 'XMLSCHEMA' ( string | {string_literal} ) ] [ 'ELEMENT' ( string | {string_literal} ) ]
  [ 'WITH' 'OBJECT' ( 'IDENTIFIER' | 'ID' ) oracle_view_object_identifier_clause ]

private oracle_view_object_identifier_clause ::= 'DEFAULT' | LP oracle_view_object_identifier_token * RP

private oracle_view_object_identifier_token ::= (
  oracle_object_name_part |
  {string_literal} |
  string |
  DIGIT |
  {signed_number} |
  COMMA |
  DOT
)

private oracle_annotations_clause ::= 'ANNOTATIONS' LP oracle_annotation ( COMMA oracle_annotation ) * RP

private oracle_annotation ::= [ oracle_annotation_operation ] oracle_annotation_name [ oracle_annotation_value ]

private oracle_annotation_operation ::= (
  'ADD' [ 'IF' 'NOT' 'EXISTS' ] |
  'DROP' [ 'IF' 'EXISTS' ] |
  'REPLACE'
)

private oracle_annotation_name ::= oracle_object_name_part | string | {string_literal}

private oracle_annotation_value ::= oracle_object_name_part | string | {string_literal} | DIGIT | {signed_number}

create_domain_stmt ::= 'CREATE' [ 'USECASE' | 'FLEXIBLE' ] 'DOMAIN' [ 'IF' 'NOT' 'EXISTS' ] oracle_domain_name
  'AS' oracle_domain_body_token + {
  pin = 3
}

alter_domain_stmt ::= 'ALTER' [ 'USECASE' ] 'DOMAIN' [ 'IF' 'EXISTS' ] oracle_domain_name
  oracle_domain_body_token + {
  pin = 3
}

drop_domain_stmt ::= 'DROP' [ 'USECASE' ] 'DOMAIN' [ 'IF' 'EXISTS' ] oracle_domain_name
  [ 'FORCE' [ 'PRESERVE' ] ] {
  pin = 3
}

private oracle_domain_boundary ::= LP oracle_domain_body_token * RP

private oracle_domain_body_token ::= (
  oracle_domain_boundary |
  oracle_annotations_clause |
  oracle_type_name |
  oracle_object_name_part |
  {string_literal} |
  string |
  DIGIT |
  {signed_number} |
  COMMA |
  DOT |
  EQ |
  '+' |
  '-' |
  '*' |
  '/' |
  '||' |
  '!=' |
  '<>' |
  '>' |
  '<' |
  '>=' |
  '<=' |
  'ADD' |
  'AND' |
  'AS' |
  'CASE' |
  'CHECK' |
  'CHOOSE' |
  'COLLATE' |
  'CONSTRAINT' |
  'DEFAULT' |
  'DEFERRABLE' |
  'DEFERRED' |
  'DISABLE' |
  'DISPLAY' |
  'DROP' |
  'ELSE' |
  'ENABLE' |
  'ENUM' |
  'FROM' |
  'IN' |
  'IMMEDIATE' |
  'INITIALLY' |
  'MODIFY' |
  'NOT' |
  'NULL' |
  'ON' |
  'OR' |
  'ORDER' |
  'STRICT' |
  'THEN' |
  'USING' |
  'VALUE' |
  'WHEN'
