private oracle_mle_env_clause ::= (
  ( 'ADD' | 'ALTER' ) 'IMPORTS' LP oracle_mle_import ( COMMA oracle_mle_import ) * RP |
  'DROP' 'IMPORTS' LP oracle_mle_import_name ( COMMA oracle_mle_import_name ) * RP |
  'SET' 'LANGUAGE' 'OPTIONS' {string_literal} |
  'COMPILE'
)

private oracle_context_clause ::= (
  'INITIALIZED' ( 'EXTERNALLY' | 'GLOBALLY' ) |
  'ACCESSED' 'GLOBALLY'
)

private oracle_mle_env_create_clause ::= (
  'CLONE' oracle_schema_object_name |
  'IMPORTS' LP oracle_mle_import ( COMMA oracle_mle_import ) * RP |
  'LANGUAGE' 'OPTIONS' {string_literal}
)

private oracle_mle_import ::= oracle_mle_import_name 'MODULE' oracle_schema_object_name

private oracle_mle_import_name ::= {string_literal} | string | oracle_object_name_part

private oracle_mle_module_create_clause ::= (
  'LANGUAGE' 'JAVASCRIPT' |
  'VERSION' ( {string_literal} | string | oracle_object_name_part ) |
  'USING' oracle_mle_module_source_clause |
  'AS' oracle_mle_module_source_token +
)

private oracle_mle_module_source_clause ::= (
  ( 'CLOB' | 'BLOB' ) LP oracle_mle_module_source_boundary_token * RP |
  'BFILE' oracle_mle_module_source_boundary_token +
)

private oracle_mle_module_clause ::= oracle_mle_module_boundary_token +

private oracle_mle_module_boundary_token ::= (
  oracle_plsql_source_token |
  oracle_parenthesized_clause |
  'SET' |
  'METADATA' |
  'USING' |
  'CLOB' |
  'SELECT' |
  'JSON'
)

private oracle_mle_module_source_token ::= (
  oracle_plsql_source_token |
  oracle_parenthesized_clause |
  'CONST' |
  'EXPORT' |
  'FUNCTION' |
  'IMPORT' |
  'LET' |
  'VAR'
)

private oracle_mle_module_source_boundary_token ::= (
  oracle_dimension_reference |
  oracle_object_name_part |
  {string_literal} |
  string |
  DIGIT |
  {signed_number} |
  COMMA |
  DOT |
  EQ |
  'BFILE' |
  'BLOB' |
  'CLOB' |
  'DIRECTORY' |
  'FROM' |
  'SELECT'
)

