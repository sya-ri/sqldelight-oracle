  pin = 3
}

drop_pmem_filestore_stmt ::= 'DROP' 'PMEM' 'FILESTORE' oracle_object_name_part [ oracle_pmem_filestore_contents_clause ] {
  pin = 3
}

create_pmem_filestore_stmt ::= 'CREATE' 'PMEM' 'FILESTORE' oracle_object_name_part
  oracle_pmem_filestore_boundary_token + {
}

alter_pmem_filestore_stmt ::= 'ALTER' 'PMEM' 'FILESTORE' oracle_object_name_part oracle_pmem_filestore_clause + {
  pin = 3
}

private oracle_flashback_archive_clause ::= (
  'SET' 'DEFAULT' |
  ( 'ADD' | 'MODIFY' | 'REMOVE' ) 'TABLESPACE' oracle_object_name_part [ oracle_flashback_archive_quota ] |
  'MODIFY' 'RETENTION' oracle_flashback_archive_retention |
  'PURGE' ( 'ALL' | 'BEFORE' ( 'SCN' | 'TIMESTAMP' ) oracle_flashback_archive_boundary_token + ) |
  [ 'NO' ] 'OPTIMIZE' 'DATA'
)

private oracle_flashback_archive_quota ::= 'QUOTA' ( oracle_size_clause | 'UNLIMITED' )

private oracle_flashback_archive_retention ::= {signed_number} ( 'DAY' | 'MONTH' | 'YEAR' )

private oracle_flashback_archive_boundary_token ::= oracle_plsql_source_token | 'SYSTIMESTAMP'

private oracle_join_group_column ::= oracle_schema_object_name LP oracle_object_name_part RP

private oracle_assertion_expression ::= LP oracle_assertion_token * RP

private oracle_assertion_token ::= (
  oracle_assertion_expression |
  oracle_dimension_reference |
  oracle_object_name_part |
  {string_literal} |
  string |
  DIGIT |
  {signed_number} |
  COMMA |
  DOT |
  EQ |
  'ALL' |
  'AND' |
  'BETWEEN' |
  'EXISTS' |
  'FROM' |
  'IN' |
  'IS' |
  'NOT' |
  'NULL' |
  'OR' |
  'SATISFY' |
  'SELECT' |
  'WHERE'
)

private oracle_assertion_constraint_state ::= (
  [ 'NOT' ] 'DEFERRABLE' |
  'INITIALLY' ( 'IMMEDIATE' | 'DEFERRED' ) |
  'ENABLE' |
  'DISABLE' |
  'VALIDATE' |
  'NOVALIDATE'
)

private oracle_directive_action ::= 'UPDATE' | 'INSERT' | 'SELECT'

private oracle_directive_processing_clause ::= (
  ( 'BEFORE' | 'AFTER' ) 'OBJECT' |
  'ON' 'COMMIT'
)

private oracle_directive_enable_option ::= 'ENABLE' | 'DISABLE' | 'VALIDATE' | 'NOVALIDATE'

private oracle_directive_using_token ::= (
  oracle_assertion_token |
  oracle_parenthesized_clause |
  'BEGIN' |
  'END' |
  'EXPRESSION' |
  'FUNCTION' |
  'JSON' |
  'SQL'
)

private oracle_java_create_clause ::= (
  'NAMED' ( string | {string_literal} ) |
  'SCHEMA' oracle_object_name_part |
  'SHARING' EQ ( 'METADATA' | 'NONE' ) |
  'AUTHID' ( 'CURRENT_USER' | 'DEFINER' ) |
  'RESOLVER' oracle_parenthesized_clause |
  'USING' oracle_java_using_clause |
  'AS' oracle_java_source_token +
)

private oracle_java_using_clause ::= (
  'BFILE' oracle_mle_module_source_boundary_token + |
  ( 'CLOB' | 'BLOB' ) LP oracle_mle_module_source_boundary_token * RP
)

private oracle_java_source_token ::= (
  oracle_mle_module_source_token |
  oracle_parenthesized_clause |
  'CLASS' |
  'PUBLIC' |
  'STATIC' |
  'VOID'
)

private oracle_logical_partition_definition ::= 'PARTITION' [ oracle_object_name_part ] 'VALUES' 'LESS' 'THAN'
  oracle_logical_partition_boundary

private oracle_logical_partition_boundary ::= LP oracle_logical_partition_token * RP

private oracle_logical_partition_token ::= (
  oracle_object_name_part |
  {string_literal} |
  string |
  DIGIT |
  {signed_number} |
  COMMA |
  DOT |
  'MAXVALUE'
)

private oracle_lockdown_profile_clause ::= ( 'ENABLE' | 'DISABLE' ) (
  'FEATURE' 'ALL' 'EXCEPT' EQ oracle_parenthesized_clause |
  'FEATURE' oracle_lockdown_target |
  'OPTION' oracle_lockdown_target |
  'STATEMENT' oracle_lockdown_assignment [ 'CLAUSE' oracle_lockdown_assignment ] [ 'OPTION' oracle_lockdown_assignment ] [ 'VALUE' oracle_lockdown_assignment ] |
  oracle_lockdown_boundary_token +
) [ 'USERS' EQ ( 'ALL' | 'COMMON' | 'LOCAL' ) ]

private oracle_lockdown_target ::= (
  'ALL' [ 'EXCEPT' EQ oracle_parenthesized_clause ] |
  EQ oracle_parenthesized_clause
)

private oracle_lockdown_assignment ::= EQ oracle_parenthesized_clause

private oracle_lockdown_boundary_token ::= (
  oracle_plsql_source_token |
  'ALL' |
  'CLAUSE' |
  'EXCEPT' |
  'FEATURE' |
  'MAXVALUE' |
  'MINVALUE' |
  'OPTION' |
  'STATEMENT' |
  'USERS' |
  'VALUE'
)

private oracle_pmem_filestore_contents_clause ::= (
  'FORCE' 'INCLUDING' 'CONTENTS' |
  ( 'INCLUDING' | 'EXCLUDING' ) 'CONTENTS'
)

drop_profile_stmt ::= 'DROP' 'PROFILE' oracle_object_name_part [ 'CASCADE' ] {
  pin = 2
}

alter_profile_stmt ::= 'ALTER' 'PROFILE' oracle_object_name_part 'LIMIT' oracle_profile_limit + [ oracle_container_clause ] {
  pin = 2
}

alter_resource_cost_stmt ::= 'ALTER' 'RESOURCE' 'COST' oracle_resource_cost + {
  pin = 3
}

drop_rollback_segment_stmt ::= 'DROP' 'ROLLBACK' 'SEGMENT' oracle_object_name_part {
  pin = 3
}

create_rollback_segment_stmt ::= 'CREATE' [ 'PUBLIC' ] 'ROLLBACK' 'SEGMENT' oracle_rollback_segment_name
  oracle_rollback_segment_create_token * {
}

alter_rollback_segment_stmt ::= 'ALTER' 'ROLLBACK' 'SEGMENT' oracle_object_name_part oracle_rollback_segment_clause {
  pin = 3
}

private oracle_rollback_segment_name ::= {identifier} | string

private oracle_rollback_segment_create_token ::= (
  oracle_rollback_segment_storage_token |
  oracle_rollback_segment_storage_clause |
  'PUBLIC' |
  'STORAGE' |
  'TABLESPACE'
)

private oracle_pmem_filestore_clause ::= (
  'ADD' oracle_pmem_filestore_boundary_token + |
  'DROP' oracle_pmem_filestore_boundary_token + |
  'RESIZE' oracle_pmem_filestore_boundary_token + |
  oracle_pmem_filestore_boundary_token
)

private oracle_pmem_filestore_boundary_token ::= (
  oracle_plsql_source_token |
  oracle_size_clause |
  'AUTOEXTEND' |
  'BACKINGFILE' |
  'BLOCKSIZE' |
  'MAXSIZE' |
  'MOUNTPOINT' |
  'NEXT' |
  'ON' |
  'SIZE'
)

private oracle_profile_limit ::= 'PRIVATE_SGA' oracle_private_sga_limit_value | oracle_profile_parameter oracle_profile_limit_value

private oracle_profile_parameter ::= (
  'COMPOSITE_LIMIT' |
  'SESSIONS_PER_USER' |
  'CPU_PER_SESSION' |
  'CPU_PER_CALL' |
  'LOGICAL_READS_PER_SESSION' |
  'LOGICAL_READS_PER_CALL' |
  'IDLE_TIME' |
  'CONNECT_TIME' |
  'FAILED_LOGIN_ATTEMPTS' |
  'PASSWORD_LIFE_TIME' |
  'PASSWORD_REUSE_TIME' |
  'PASSWORD_REUSE_MAX' |
  'PASSWORD_LOCK_TIME' |
  'PASSWORD_GRACE_TIME' |
  'PASSWORD_VERIFY_FUNCTION' |
  'PASSWORD_ROLLOVER_TIME' |
  'INACTIVE_ACCOUNT_TIME'
)

private oracle_profile_limit_value ::= (
  {signed_number} |
  oracle_size_clause |
  oracle_schema_object_name |
  'DEFAULT' |
  'UNLIMITED' |
  'NULL'
)

private oracle_private_sga_limit_value ::= (
  {signed_number} oracle_size_unit |
  oracle_size_clause |
  'DEFAULT' |
  'UNLIMITED'
)

private oracle_resource_cost ::= oracle_resource_cost_parameter {signed_number}

private oracle_resource_cost_parameter ::= (
  'CPU_PER_SESSION' |
  'CONNECT_TIME' |
  'LOGICAL_READS_PER_SESSION' |
  'PRIVATE_SGA'
)

private oracle_rollback_segment_clause ::= (
  'ONLINE' |
  'OFFLINE' |
  'SHRINK' [ 'TO' oracle_size_clause ] |
  oracle_rollback_segment_storage_keyword oracle_rollback_segment_storage_clause
)

private oracle_rollback_segment_storage_clause ::= LP oracle_rollback_segment_storage_token * RP

private oracle_rollback_segment_storage_keyword ::= 'STORAGE' | <<identifierExt identifier_real>>

private oracle_rollback_segment_storage_token ::= (
  oracle_plsql_source_token |
  oracle_size_clause |
  'BUFFER_POOL' |
  'CACHE' |
  'DEFAULT' |
  'FLASH_CACHE' |
  'FREELISTS' |
  'GROUPS' |
  'INITIAL' |
  'KEEP' |
  'MAXEXTENTS' |
  'MINEXTENTS' |
  'NEXT' |
  'NONE' |
  'OPTIMAL' |
  'PCTINCREASE' |
  'RECYCLE'
)

