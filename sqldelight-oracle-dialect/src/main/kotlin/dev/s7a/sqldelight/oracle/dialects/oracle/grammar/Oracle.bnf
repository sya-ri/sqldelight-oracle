private oracle_public_qualifier ::= 'PUBLIC' | '"PUBLIC"'

private oracle_synonym_sharing_clause ::= 'SHARING' EQ ( 'METADATA' | 'NONE' )

oracle_local_synonym_target ::= oracle_object_name_part !DOT [ '@' oracle_database_link_reference ]

oracle_synonym_target ::= oracle_schema_object_name [ '@' oracle_database_link_reference ]

private oracle_qualified_schema_object_name ::= oracle_object_name_part DOT oracle_object_name_part

private oracle_database_link_reference ::= oracle_object_name_part ( DOT oracle_object_name_part ) *

private oracle_mv_log_clause ::= (
  'FORCE' |
  'ADD' oracle_mv_log_augmentation |
  ( 'INCLUDING' | 'EXCLUDING' ) 'NEW' 'VALUES' |
  'PURGE' oracle_mv_log_purge_clause |
  'FOR' ( 'FAST' | 'SYNCHRONOUS' ) 'REFRESH' |
  'MOVE' oracle_mv_log_boundary_token * |
  'ALLOCATE' 'EXTENT' [ oracle_parenthesized_clause ] |
  'DEALLOCATE' 'UNUSED' [ 'KEEP' oracle_size_value ] |
  'SHRINK' 'SPACE' [ 'COMPACT' ] |
  ( 'CACHE' | 'NOCACHE' ) |
  ( 'LOGGING' | 'NOLOGGING' | 'FILESYSTEM_LIKE_LOGGING' ) |
  'PARALLEL' [ DIGIT | oracle_object_name_part ] |
  'NOPARALLEL' |
  'PCTFREE' DIGIT |
  'PCTUSED' DIGIT |
  'INITRANS' DIGIT |
  'TABLESPACE' oracle_schema_object_name
)

private oracle_mv_log_augmentation ::= (
  'ROWID' |
  'SEQUENCE' |
  'OBJECT' 'ID' |
  'PRIMARY' 'KEY' |
  LP oracle_object_name_part ( COMMA oracle_object_name_part ) * RP
)

private oracle_mv_log_purge_clause ::= (
  ( 'IMMEDIATE' [ 'SYNCHRONOUS' | 'ASYNCHRONOUS' ] ) |
  [ 'START' 'WITH' oracle_mv_log_datetime_expr ] oracle_mv_log_purge_schedule
)

private oracle_mv_log_purge_schedule ::= (
  'NEXT' oracle_mv_log_datetime_expr |
  'REPEAT' 'INTERVAL' oracle_mv_log_interval_expr
)

private oracle_mv_log_datetime_expr ::= ( !'NEXT' !'REPEAT' oracle_mv_log_boundary_token ) +

private oracle_mv_log_interval_expr ::= oracle_mv_log_boundary_token +

private oracle_zonemap_clause ::= (
  'TABLESPACE' oracle_schema_object_name |
  'SCALE' DIGIT |
  'PCTFREE' DIGIT |
  'PCTUSED' DIGIT |
  'CACHE' |
  'NOCACHE' |
  'REFRESH' oracle_zonemap_refresh_option + |
  ( 'ENABLE' | 'DISABLE' ) 'PRUNING' |
  'COMPILE' |
  'REBUILD' |
  'UNUSABLE'
)

private oracle_create_zonemap_clause ::= (
  oracle_zonemap_on_table_clause |
  oracle_zonemap_as_subquery_clause |
  oracle_zonemap_clause
)

private oracle_zonemap_on_table_clause ::= 'ON' oracle_schema_object_name
  LP oracle_object_name_part ( COMMA oracle_object_name_part ) * RP

private oracle_zonemap_as_subquery_clause ::= [ LP oracle_object_name_part ( COMMA oracle_object_name_part ) * RP ] 'AS' oracle_zonemap_query_token +

private oracle_zonemap_refresh_option ::= (
  'FAST' |
  'COMPLETE' |
  'FORCE' |
  'ON' ( 'DEMAND' | 'COMMIT' | 'LOAD' [ 'DATA' 'MOVEMENT' ] | 'DATA' 'MOVEMENT' )
)

private oracle_zonemap_query_token ::= (
  oracle_dimension_reference |
  oracle_plsql_source_token |
  oracle_parenthesized_clause |
  'BY' |
  'FROM' |
  'GROUP' |
  'JOIN' |
  'LEFT' |
  'MAX' |
  'MIN' |
  'ON' |
  'OUTER' |
  'ROWID' |
  'SELECT' |
  'SYS_OP_ZONE_ID' |
  'WHERE'
)

private oracle_mv_log_boundary_token ::= oracle_plsql_source_token | '+' | '-' | '*' | '/' | 'AT' | 'DAY' | 'HOUR' | 'MINUTE' | 'MONTH' | 'SECOND' | 'TABLESPACE' | 'YEAR'

