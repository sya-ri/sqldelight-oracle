  'TABLESPACE' oracle_object_name_part [ oracle_flashback_archive_quota ] [ 'RETENTION' oracle_flashback_archive_retention ]
  [ [ 'NO' ] 'OPTIMIZE' 'DATA' ] {
}

private oracle_cluster_clause ::= (
  'SIZE' oracle_size_clause |
  'CACHE' |
  'NOCACHE' |
  'ALLOCATE' 'EXTENT' oracle_cluster_boundary_token * |
  'DEALLOCATE' 'UNUSED' [ 'KEEP' oracle_size_clause ] |
  'MODIFY' 'PARTITION' oracle_object_name_part 'ALLOCATE' 'EXTENT' oracle_cluster_boundary_token * |
  oracle_cluster_boundary_token
)

private oracle_cluster_column_definition ::= oracle_object_name_part type_name [ 'COLLATE' {collation_name} ] [ 'SORT' ]

private oracle_create_cluster_clause ::= (
  oracle_create_cluster_storage_clause |
  oracle_segment_attribute_clause |
  'SIZE' oracle_cluster_size_clause |
  'INDEX' |
  'TABLESPACE' oracle_object_name_part |
  [ 'SINGLE' 'TABLE' ] 'HASHKEYS' {signed_number} [ 'HASH' 'IS' oracle_cluster_hash_expr ] |
  oracle_parallel_clause |
  'NOROWDEPENDENCIES' |
  'ROWDEPENDENCIES' |
  'CACHE' |
  'NOCACHE' |
  oracle_cluster_range_partitions
)

private oracle_cluster_size_clause ::= {signed_number} [ oracle_size_unit ]

private oracle_create_cluster_storage_clause ::= 'STORAGE' LP oracle_cluster_boundary_token * RP

private oracle_cluster_hash_expr ::= ( !'SIZE' !'TABLESPACE' !'PARALLEL' !'NOPARALLEL' !'NOROWDEPENDENCIES' !'ROWDEPENDENCIES' !'CACHE' !'NOCACHE' !'PARTITION' oracle_cluster_hash_token ) +

private oracle_cluster_hash_token ::= oracle_plsql_source_token | '+' | '-' | '*' | '/'

private oracle_cluster_range_partitions ::= 'PARTITION' 'BY' 'RANGE' LP oracle_cluster_partition_key ( COMMA oracle_cluster_partition_key ) * RP
  LP oracle_range_partition_definition ( COMMA oracle_range_partition_definition ) * RP

private oracle_cluster_partition_key ::= oracle_object_name_part | LP oracle_cluster_hash_expr RP

private oracle_database_link_clause ::= (
  'CONNECT' (
    'TO' oracle_object_name_part 'IDENTIFIED' 'BY' oracle_authentication_value [ oracle_dblink_authentication ] |
    'TO' 'CURRENT_USER' |
    'WITH' oracle_object_name_part
  ) |
  oracle_dblink_authentication
)

private oracle_create_database_link_clause ::= oracle_database_link_clause | 'USING' oracle_database_link_connect_string

private oracle_database_link_connect_string ::= oracle_schema_object_name | {string_literal} | string

private oracle_dblink_authentication ::= 'AUTHENTICATED' (
  'BY' oracle_object_name_part 'IDENTIFIED' 'BY' oracle_authentication_value |
  'WITH' oracle_object_name_part
)

private oracle_indextype_clause ::= (
  'COMPILE' |
  ( 'ADD' | 'DROP' ) 'OPERATOR' oracle_schema_object_name [ LP oracle_type_name ( COMMA oracle_type_name ) * RP ] |
  'USING' oracle_indextype_boundary_token + |
  'WITH' 'LOCAL' 'PARTITION' oracle_indextype_boundary_token *
)

private oracle_indextype_operator_signature ::= oracle_schema_object_name LP oracle_type_name ( COMMA oracle_type_name ) * RP

private oracle_create_indextype_clause ::= (
  'WITH' 'LOCAL' [ 'RANGE' ] 'PARTITION' |
  oracle_storage_table_clause |
  oracle_indextype_array_dml_clause
)

private oracle_indextype_array_dml_clause ::= 'WITH' 'ARRAY' 'DML' LP
  oracle_indextype_array_dml_arg ( COMMA oracle_indextype_array_dml_arg ) * RP

private oracle_indextype_array_dml_arg ::= oracle_type_name 'AS' oracle_schema_object_name

private oracle_operator_clause ::= (
  'COMPILE' |
  'ADD' oracle_operator_binding |
  'DROP' oracle_operator_binding_signature [ 'FORCE' ]
)

private oracle_outline_clause ::= (
  'REBUILD' |
  'RENAME' 'TO' oracle_object_name_part |
  'CHANGE' 'CATEGORY' 'TO' oracle_object_name_part |
  'ENABLE' |
  'DISABLE'
)

private oracle_create_operator_clause ::= (
  oracle_operator_binding |
  oracle_operator_binding_clause
)

private oracle_operator_binding ::= oracle_operator_binding_signature 'RETURN' oracle_type_name oracle_operator_binding_clause *

private oracle_operator_binding_signature ::= 'BINDING' LP oracle_type_name ( COMMA oracle_type_name ) * RP

private oracle_operator_binding_clause ::= (
  'ANCILLARY' 'TO' oracle_schema_object_name [ LP oracle_type_name ( COMMA oracle_type_name ) * RP ] |
  'WITH' ( 'INDEX' | 'SCAN' | 'COLUMN' ) 'CONTEXT' |
  'COMPUTE' 'ANCILLARY' 'DATA' |
  'USING' oracle_schema_object_name
)

private oracle_create_outline_clause ::= (
  'FROM' [ 'PUBLIC' | 'PRIVATE' ] oracle_schema_object_name |
  'FOR' 'CATEGORY' oracle_object_name_part |
  'ON' oracle_outline_statement_token +
)

private oracle_schema_element ::= {create_table_stmt} | {create_view_stmt} | grant_stmt

private oracle_outline_statement_token ::= (
  oracle_dimension_reference |
  oracle_plsql_source_token |
  oracle_parenthesized_clause |
  'CREATE' |
  'DELETE' |
  'FROM' |
  'INSERT' |
  'INTO' |
  'SELECT' |
  'UPDATE' |
  'WHERE'
)

private oracle_cluster_boundary_token ::= (
  oracle_plsql_source_token |
  oracle_size_clause |
  'FREEPOOLS' |
  'INITRANS' |
  'MAXEXTENTS' |
  'MINEXTENTS' |
  'NEXT' |
  'PARALLEL' |
  'PCTFREE' |
  'PCTINCREASE' |
  'PCTUSED' |
  'STORAGE'
)

private oracle_indextype_boundary_token ::= (
  oracle_plsql_source_token |
  oracle_type_name |
  'ARRAY' |
  'DML' |
  'LOCAL' |
  'PARTITION' |
  'STORAGE' |
  'TABLE'
)

private oracle_operator_boundary_token ::= (
  oracle_plsql_source_token |
  oracle_type_name |
  'BINDING' |
  'CONTEXT' |
