private oracle_json_duality_create_modifier ::= 'OR' 'REPLACE' | 'FORCE' | 'NOFORCE' | 'NO' 'FORCE' | 'EDITIONABLE' | 'NONEDITIONABLE'

private oracle_json_duality_replication_clause ::= ( 'ENABLE' | 'DISABLE' ) 'LOGICAL' 'REPLICATION'

private oracle_json_duality_definition_token ::= (
  oracle_dimension_reference |
  oracle_plsql_source_token |
  oracle_parenthesized_clause |
  'CHECK' |
  'DELETE' |
  'DUALITY' |
  'ETAG' |
  'FORCE' |
  'FROM' |
  'INSERT' |
  'JSON' |
  'KEY' |
  'LOGICAL' |
  'NOCHECK' |
  'NODELETE' |
