  extends = "com.alecstrong.sql.psi.core.psi.impl.SqlTypeNameImpl"
  implements = "com.alecstrong.sql.psi.core.psi.SqlTypeName"
  override = true
}

extension_expr ::= oracle_text_literal | oracle_floating_point_literal | oracle_boolean_literal_expr | oracle_boolean_not_expr | oracle_boolean_test_expr | oracle_extract_datetime_expr | oracle_character_function_expr | oracle_object_method_expr | oracle_object_attribute_expr | oracle_datetime_conversion_expr | oracle_number_conversion_expr | oracle_interval_conversion_expr | oracle_user_function_expr | oracle_collection_function_expr | oracle_object_reference_function_expr | oracle_oml_function_expr | oracle_ordered_aggregate_expr | oracle_analytic_function_expr | oracle_aggregate_function_expr | oracle_datetime_literal | oracle_interval_literal | oracle_pseudocolumn_expr | oracle_operator_expr | oracle_condition_expr | oracle_multiset_expr | oracle_collate_expr | oracle_cursor_expr | oracle_validate_conversion_expr | oracle_type_conversion_expr | oracle_sql_json_expr | oracle_xml_expr | oracle_vector_expr | oracle_type_constructor_expr | oracle_bind_placeholder_expr {
  extends = "com.alecstrong.sql.psi.core.psi.impl.SqlExtensionExprImpl"
  implements = "com.alecstrong.sql.psi.core.psi.SqlExtensionExpr"
  override = true
}

private oracle_text_literal ::= ( 'N' | 'n' ) {string_literal}

private oracle_floating_point_literal ::= (
  'BINARY_FLOAT_NAN' |
  'BINARY_FLOAT_INFINITY' |
  'BINARY_DOUBLE_NAN' |
  'BINARY_DOUBLE_INFINITY' |
  {signed_number} ( 'f' | 'F' | 'd' | 'D' )
)

private oracle_boolean_literal_expr ::= 'TRUE' | 'FALSE' | 'UNKNOWN'

private oracle_boolean_not_expr ::= 'NOT' <<expr '-1'>>

private oracle_boolean_test_expr ::= LP <<expr '-1'>> 'IS' [ 'NOT' ] ( 'TRUE' | 'FALSE' | 'UNKNOWN' ) RP

private oracle_extract_datetime_expr ::= 'EXTRACT' LP oracle_datetime_field 'FROM' <<expr '-1'>> RP

private oracle_datetime_field ::= (
  'YEAR' | 'MONTH' | 'DAY' | 'HOUR' | 'MINUTE' | 'SECOND' |
  'TIMEZONE_HOUR' | 'TIMEZONE_MINUTE' | 'TIMEZONE_REGION' | 'TIMEZONE_ABBR' | 'TIMEZONE_OFFSET'
)

private oracle_character_function_expr ::= oracle_replace_expr | oracle_regexp_count_expr | oracle_regexp_instr_expr | oracle_translate_using_expr | oracle_trim_expr

private oracle_replace_expr ::= 'REPLACE' LP <<expr '-1'>> COMMA <<expr '-1'>> [ COMMA <<expr '-1'>> ] RP

private oracle_regexp_count_expr ::= 'REGEXP_COUNT' LP <<expr '-1'>> COMMA <<expr '-1'>>
  [ COMMA <<expr '-1'>> [ COMMA <<expr '-1'>> ] ] RP

private oracle_regexp_instr_expr ::= 'REGEXP_INSTR' LP <<expr '-1'>> COMMA <<expr '-1'>>
  [ COMMA <<expr '-1'>> [ COMMA <<expr '-1'>> [ COMMA <<expr '-1'>> [ COMMA <<expr '-1'>> [ COMMA <<expr '-1'>> ] ] ] ] ] RP

private oracle_translate_using_expr ::= 'TRANSLATE' LP <<expr '-1'>> 'USING' ( 'CHAR_CS' | 'NCHAR_CS' ) RP

private oracle_trim_expr ::= 'TRIM' LP [ 'LEADING' | 'TRAILING' | 'BOTH' ] [ <<expr '-1'>> ] 'FROM' <<expr '-1'>> RP

private oracle_datetime_conversion_expr ::= ( 'TO_DATE' | 'TO_TIMESTAMP' | 'TO_TIMESTAMP_TZ' ) LP <<expr '-1'>> 'DEFAULT' <<expr '-1'>> 'ON' 'CONVERSION' 'ERROR'
  [ COMMA <<expr '-1'>> [ COMMA <<expr '-1'>> ] ] RP

private oracle_number_conversion_expr ::= ( 'TO_NUMBER' | 'TO_BINARY_DOUBLE' | 'TO_BINARY_FLOAT' ) LP <<expr '-1'>> 'DEFAULT' <<expr '-1'>> 'ON' 'CONVERSION' 'ERROR'
  [ COMMA <<expr '-1'>> [ COMMA <<expr '-1'>> ] ] RP

private oracle_interval_conversion_expr ::= ( 'TO_DSINTERVAL' | 'TO_YMINTERVAL' ) LP <<expr '-1'>> 'DEFAULT' <<expr '-1'>> 'ON' 'CONVERSION' 'ERROR' RP

private oracle_user_function_expr ::= (
  oracle_qualified_user_function_name [ oracle_dblink_clause ] LP [ oracle_user_function_argument ( COMMA oracle_user_function_argument ) * ] RP |
  oracle_object_name_part oracle_dblink_clause LP [ oracle_user_function_argument ( COMMA oracle_user_function_argument ) * ] RP |
  oracle_object_name_part LP oracle_user_function_named_arguments RP
)

private oracle_qualified_user_function_name ::= oracle_schema_object_name DOT oracle_object_name_part

private oracle_user_function_named_arguments ::= (
  oracle_user_function_named_argument ( COMMA oracle_user_function_argument ) * |
  oracle_user_function_argument COMMA oracle_user_function_named_arguments
)

private oracle_user_function_argument ::= oracle_user_function_named_argument | <<expr '-1'>>

private oracle_user_function_named_argument ::= oracle_schema_object_name EQ GT <<expr '-1'>>

private oracle_object_method_expr ::= oracle_object_access_method_receiver DOT oracle_object_method_invocation

private oracle_object_access_method_receiver ::= oracle_type_constructor_expr | oracle_user_function_expr | oracle_schema_object_name | LP <<expr '-1'>> RP

private oracle_object_attribute_receiver ::= oracle_sql_json_expr | oracle_object_access_method_receiver

private oracle_object_method_invocation ::= oracle_object_name_part LP [ oracle_user_function_argument ( COMMA oracle_user_function_argument ) * ] RP

private oracle_object_attribute_expr ::= oracle_object_attribute_receiver DOT oracle_object_attribute_part ( DOT oracle_object_attribute_part ) *

private oracle_object_attribute_part ::= oracle_object_name_part

private oracle_collection_function_expr ::= (
  oracle_collect_expr |
  oracle_simple_collection_function_name LP <<expr '-1'>> RP |
  'POWERMULTISET_BY_CARDINALITY' LP <<expr '-1'>> COMMA <<expr '-1'>> RP |
  'SYS_CONNECT_BY_PATH' LP <<expr '-1'>> COMMA <<expr '-1'>> RP
)

private oracle_simple_collection_function_name ::= 'CARDINALITY' | 'POWERMULTISET' | 'SET'

private oracle_collect_expr ::= 'COLLECT' LP [ 'DISTINCT' | 'UNIQUE' ] <<expr '-1'>> [ 'ORDER' 'BY' <<orderingTermExt <<ordering_term_real>>>> ( COMMA <<orderingTermExt <<ordering_term_real>>>> ) * ] RP

private oracle_object_reference_function_expr ::= (
  ( 'REF' | 'DEREF' | 'VALUE' ) LP <<expr '-1'>> RP |
  'MAKE_REF' LP <<expr '-1'>> COMMA <<expr '-1'>> ( COMMA <<expr '-1'>> ) * RP
)

private oracle_oml_function_expr ::= oracle_oml_function_name LP oracle_oml_argument_clause RP [ oracle_over_clause ]

private oracle_oml_function_name ::= (
  'PREDICTION' | 'PREDICTION_BOUNDS' | 'PREDICTION_COST' | 'PREDICTION_DETAILS' | 'PREDICTION_PROBABILITY' | 'PREDICTION_SET' |
  'CLUSTER_DETAILS' | 'CLUSTER_DISTANCE' | 'CLUSTER_ID' | 'CLUSTER_PROBABILITY' | 'CLUSTER_SET' |
  'FEATURE_COMPARE' | 'FEATURE_DETAILS' | 'FEATURE_ID' | 'FEATURE_SET' | 'FEATURE_VALUE' |
  'ORA_DM_PARTITION_NAME' | oracle_object_name_part
)

private oracle_oml_argument_clause ::= oracle_feature_compare_argument_clause | oracle_oml_model_clause | oracle_oml_analytic_clause

private oracle_feature_compare_argument_clause ::= oracle_schema_object_name oracle_mining_attribute_clause 'AND' oracle_mining_attribute_clause

private oracle_oml_model_clause ::= oracle_schema_object_name oracle_oml_model_option * oracle_mining_attribute_clause

private oracle_oml_model_option ::= COMMA <<expr '-1'>> | 'COST' ( 'MODEL' | 'MATRIX' oracle_schema_object_name ) | 'ORDER' 'BY' <<orderingTermExt <<ordering_term_real>>>> ( COMMA <<orderingTermExt <<ordering_term_real>>>> ) *

private oracle_oml_analytic_clause ::= [ oracle_oml_target_clause ] oracle_oml_model_option * [ oracle_oml_into_clause ] oracle_mining_attribute_clause

private oracle_oml_target_clause ::= ( 'FOR' <<expr '-1'>> | 'OF' 'ANOMALY' ) oracle_oml_detail_ordering *

private oracle_oml_into_clause ::= 'INTO' <<expr '-1'>> oracle_oml_detail_ordering *

private oracle_oml_detail_ordering ::= 'DESC' | 'ASC' | 'ABS'

private oracle_mining_attribute_clause ::= 'USING' ( '*' | oracle_mining_attribute ( COMMA oracle_mining_attribute ) * )

private oracle_mining_attribute ::= ( oracle_object_name_part DOT '*' | <<expr '-1'>> ) [ [ 'AS' ] oracle_object_name_part ]

private oracle_analytic_function_expr ::= oracle_function_invocation ( oracle_keep_clause [ oracle_over_clause ] | oracle_over_clause )

private oracle_function_invocation ::= oracle_object_name_part LP [ oracle_function_argument ( COMMA oracle_function_argument ) * ] RP

private oracle_function_argument ::= '*' | ( 'DISTINCT' | 'UNIQUE' | 'ALL' ) <<expr '-1'>> | <<expr '-1'>>

private oracle_aggregate_function_expr ::= oracle_aggregate_function_name LP [ oracle_function_argument ( COMMA oracle_function_argument ) * ] RP [ oracle_filter_clause ] [ oracle_over_clause ]

private oracle_aggregate_function_name ::= (
  'APPROX_COUNT' | 'APPROX_COUNT_DISTINCT' | 'APPROX_MEDIAN' | 'APPROX_SUM' |
  'AVG' | 'BIT_AND_AGG' | 'BIT_OR_AGG' | 'BIT_XOR_AGG' | 'BOOLEAN_AND_AGG' | 'BOOLEAN_OR_AGG' | 'CHECKSUM' |
  'CORR' | 'COUNT' | 'COVAR_POP' | 'COVAR_SAMP' | 'KURTOSIS_POP' | 'KURTOSIS_SAMP' |
  'MAX' | 'MEDIAN' | 'MIN' | 'SKEWNESS_POP' | 'SKEWNESS_SAMP' |
  'STDDEV' | 'STDDEV_POP' | 'STDDEV_SAMP' | 'SUM' | 'VARIANCE' | 'VAR_POP' | 'VAR_SAMP'
)

private oracle_ordered_aggregate_expr ::= ( oracle_approx_percentile_expr | oracle_percentile_expr | oracle_listagg_expr ) [ oracle_filter_clause ] [ oracle_over_clause ]

private oracle_approx_percentile_expr ::=
  'APPROX_PERCENTILE' LP <<expr '-1'>> [ 'DETERMINISTIC' ] [ COMMA <<expr '-1'>> ] RP oracle_within_group_clause

private oracle_percentile_expr ::= ( 'PERCENTILE_CONT' | 'PERCENTILE_DISC' ) LP <<expr '-1'>> RP oracle_within_group_clause

private oracle_listagg_expr ::=
  'LISTAGG' LP [ 'ALL' | 'DISTINCT' ] <<expr '-1'>> [ COMMA <<expr '-1'>> ] [ oracle_listagg_overflow_clause ] RP oracle_within_group_clause

private oracle_listagg_overflow_clause ::= 'ON' 'OVERFLOW' ( 'ERROR' | 'TRUNCATE' [ <<expr '-1'>> ] [ ( 'WITH' | 'WITHOUT' ) 'COUNT' ] )

private oracle_within_group_clause ::= 'WITHIN' 'GROUP' LP 'ORDER' 'BY' <<orderingTermExt <<ordering_term_real>>>> ( COMMA <<orderingTermExt <<ordering_term_real>>>> ) * RP

private oracle_keep_clause ::= 'KEEP' LP 'DENSE_RANK' ( 'FIRST' | 'LAST' ) 'ORDER' 'BY' <<orderingTermExt <<ordering_term_real>>>> ( COMMA <<orderingTermExt <<ordering_term_real>>>> ) * RP

private oracle_filter_clause ::= 'FILTER' LP 'WHERE' <<expr '-1'>> RP

private oracle_over_clause ::= 'OVER' ( oracle_window_name | oracle_window_specification )

private oracle_window_specification ::= LP [ oracle_window_name ] [ oracle_query_partition_clause ] [ oracle_analytic_order_by_clause ] [ oracle_windowing_clause ] RP

private oracle_window_name ::= oracle_object_name_part

private oracle_query_partition_clause ::= 'PARTITION' 'BY' <<expr '-1'>> ( COMMA <<expr '-1'>> ) *

private oracle_analytic_order_by_clause ::= 'ORDER' 'BY' <<orderingTermExt <<ordering_term_real>>>> ( COMMA <<orderingTermExt <<ordering_term_real>>>> ) *

private oracle_windowing_clause ::= ( 'ROWS' | 'RANGE' | 'GROUPS' ) ( oracle_window_between_clause | oracle_window_bound ) [ oracle_window_exclusion_clause ]

private oracle_window_between_clause ::= 'BETWEEN' oracle_window_bound 'AND' oracle_window_bound

private oracle_window_bound ::= 'UNBOUNDED' ( 'PRECEDING' | 'FOLLOWING' ) | 'CURRENT' 'ROW' | <<expr '-1'>> ( 'PRECEDING' | 'FOLLOWING' )

private oracle_window_exclusion_clause ::= 'EXCLUDE' ( 'CURRENT' 'ROW' | 'GROUP' | 'TIES' | 'NO' 'OTHERS' )

private oracle_xml_expr ::= (
  oracle_xmlelement_expr |
  oracle_xmlagg_expr |
  oracle_xmlcast_expr |
  oracle_xmlforest_expr |
  oracle_xmlparse_expr |
  oracle_xmlpi_expr |
  oracle_xmlquery_expr |
  oracle_xmlroot_expr |
  oracle_xmlserialize_expr |
  oracle_xmlexists_expr |
  oracle_simple_xml_function_expr
)

private oracle_xmlelement_expr ::= 'XMLELEMENT' LP [ oracle_xml_escaping_clause ] oracle_xmlelement_name ( COMMA oracle_xml_element_content ) * RP

private oracle_xml_escaping_clause ::= 'ENTITYESCAPING' | 'NOENTITYESCAPING'

private oracle_xmlelement_name ::= [ 'NAME' ] oracle_xml_name

private oracle_xml_element_content ::= oracle_xmlattributes_expr | <<expr '-1'>> [ oracle_xml_content_alias ]

private oracle_xml_content_alias ::= [ 'AS' ] oracle_xml_alias_name | 'AS' 'EVALNAME' <<expr '-1'>>

private oracle_xml_alias_name ::= {string_literal} | string | oracle_object_name_part

private oracle_xmlattributes_expr ::= 'XMLATTRIBUTES' LP oracle_xml_attribute ( COMMA oracle_xml_attribute ) * RP

private oracle_xml_attribute ::= <<expr '-1'>> [ 'AS' oracle_xml_name ]

private oracle_xmlagg_expr ::= 'XMLAGG' LP <<expr '-1'>> [ 'ORDER' 'BY' <<orderingTermExt <<ordering_term_real>>>> ( COMMA <<orderingTermExt <<ordering_term_real>>>> ) * ] RP

private oracle_xmlcast_expr ::= 'XMLCAST' LP <<expr '-1'>> 'AS' oracle_type_name RP

private oracle_xmlforest_expr ::= 'XMLFOREST' LP oracle_xml_element_content ( COMMA oracle_xml_element_content ) * RP

private oracle_xmlparse_expr ::= 'XMLPARSE' LP ( 'DOCUMENT' | 'CONTENT' ) <<expr '-1'>> [ 'WELLFORMED' ] RP

private oracle_xmlpi_expr ::= 'XMLPI' LP [ 'NAME' ] oracle_xml_name [ COMMA <<expr '-1'>> ] RP

private oracle_xmlquery_expr ::= 'XMLQUERY' LP {string_literal} [ oracle_xml_passing_clause ] 'RETURNING' 'CONTENT' [ 'NULL' 'ON' 'EMPTY' ] RP

private oracle_xmlexists_expr ::= 'XMLEXISTS' LP {string_literal} [ oracle_xml_passing_clause ] RP

private oracle_xmlroot_expr ::= 'XMLROOT' LP <<expr '-1'>> COMMA 'VERSION' oracle_xmlroot_version [ COMMA 'STANDALONE' oracle_xmlroot_standalone ] RP

private oracle_xmlroot_version ::= 'NO' 'VALUE' | <<expr '-1'>>

private oracle_xmlroot_standalone ::= 'NO' 'VALUE' | 'YES' | 'NO'

private oracle_xmlserialize_expr ::= 'XMLSERIALIZE' LP ( 'DOCUMENT' | 'CONTENT' ) <<expr '-1'>> [ 'AS' oracle_type_name ] oracle_xmlserialize_option * RP

private oracle_simple_xml_function_expr ::= oracle_simple_xml_function_name LP [ <<expr '-1'>> ( COMMA <<expr '-1'>> ) * ] RP

private oracle_simple_xml_function_name ::= (
  'DEPTH' |
  'EXISTSNODE' |
  'EXTRACT' |
  'EXTRACTVALUE' |
  'PATH' |
  'SYS_DBURIGEN' |
  'SYS_XMLAGG' |
  'SYS_XMLGEN' |
  'XMLCDATA' |
  'XMLCOLATTVAL' |
  'XMLCOMMENT' |
  'XMLCONCAT' |
  'XMLDIFF' |
  'XMLISVALID' |
  'XMLPATCH' |
  'XMLSEQUENCE' |
  'XMLTRANSFORM'
)

private oracle_xmlserialize_option ::= (
  'VERSION' {string_literal} |
  'ENCODING' {string_literal} |
  'NO' 'INDENT' |
  'INDENT' [ 'SIZE' EQ DIGIT ] |
