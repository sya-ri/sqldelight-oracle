savepoint_stmt ::= 'SAVEPOINT' {savepoint_name} {
  extends = "com.alecstrong.sql.psi.core.psi.impl.SqlSavepointStmtImpl"
  implements = "com.alecstrong.sql.psi.core.psi.SqlSavepointStmt"
  override = true
  pin = 1
}

set_transaction_stmt ::= 'SET' 'TRANSACTION' (
  oracle_transaction_mode [ 'NAME' {string_literal} ] |
  'NAME' {string_literal}
) {
  pin = 2
}

private oracle_transaction_mode ::= (
  'READ' ( 'ONLY' | 'WRITE' ) |
  'ISOLATION' 'LEVEL' ( 'SERIALIZABLE' | 'READ' 'COMMITTED' ) |
  'USE' 'ROLLBACK' 'SEGMENT' oracle_object_name_part
)

set_constraints_stmt ::= 'SET' ( 'CONSTRAINT' | 'CONSTRAINTS' )
  ( 'ALL' | oracle_schema_object_name ( COMMA oracle_schema_object_name ) * ) ( 'IMMEDIATE' | 'DEFERRED' ) {
  pin = 2
}

set_role_stmt ::= 'SET' 'ROLE' (
  oracle_role_setting ( COMMA oracle_role_setting ) * |
  'ALL' [ 'EXCEPT' oracle_object_name_part ( COMMA oracle_object_name_part ) * ] |
  'NONE'
) {
  pin = 2
}

private oracle_role_setting ::= oracle_object_name_part [ 'IDENTIFIED' 'BY' oracle_role_password ]

private oracle_role_password ::= oracle_object_name_part

set_use_data_grants_only_stmt ::= 'SET' 'USE' 'DATA' 'GRANTS' 'ONLY' 'ON' oracle_schema_object_name [ 'ENABLED' | 'DISABLED' ] {
  pin = 5
}

alter_session_stmt ::= 'ALTER' 'SESSION' oracle_alter_session_clause {
  pin = 2
}

private oracle_alter_session_clause ::= (
  'ADVISE' ( 'COMMIT' | 'ROLLBACK' | 'NOTHING' ) |
  'CLOSE' 'DATABASE' 'LINK' oracle_object_name_part |
  ( 'ENABLE' | 'DISABLE' ) 'COMMIT' 'IN' 'PROCEDURE' |
  ( 'ENABLE' | 'DISABLE' ) 'GUARD' |
  ( 'ENABLE' | 'DISABLE' | 'FORCE' ) 'PARALLEL' ( 'DML' | 'DDL' | 'QUERY' ) [ 'PARALLEL' {signed_number} ] |
  'ENABLE' 'RESUMABLE' [ 'TIMEOUT' {signed_number} ] [ 'NAME' {string_literal} ] |
  'DISABLE' 'RESUMABLE' |
  ( 'ENABLE' | 'DISABLE' ) 'SHARD' 'DDL' |
  'SYNC' 'WITH' 'PRIMARY' |
  oracle_alter_session_set_clause
)

private oracle_alter_session_set_clause ::= 'SET' (
  'EDITION' EQ oracle_object_name_part |
  'CONTAINER' EQ oracle_object_name_part [ 'SERVICE' EQ oracle_object_name_part ] |
  'ROW' 'ARCHIVAL' 'VISIBILITY' EQ ( 'ACTIVE' | 'ALL' ) |
  'DEFAULT' 'COLLATION' EQ ( oracle_object_name_part | 'NONE' ) |
  oracle_parameter_assignment +
)

alter_system_stmt ::= 'ALTER' 'SYSTEM' oracle_alter_system_clause {
  pin = 2
}

private oracle_alter_system_clause ::= (
  oracle_archive_log_clause |
  'CHECKPOINT' [ 'GLOBAL' | 'LOCAL' ] |
  'CHECK' 'DATAFILES' [ 'GLOBAL' | 'LOCAL' ] |
  ( 'ENABLE' | 'DISABLE' ) 'DISTRIBUTED' 'RECOVERY' |
  'FLUSH' oracle_flush_target |
  oracle_end_session_clause |
  'SWITCH' 'LOGFILE' |
  ( 'SUSPEND' | 'RESUME' ) |
  ( 'QUIESCE' 'RESTRICTED' | 'UNQUIESCE' ) |
  'START' 'ROLLING' ( 'MIGRATION' | 'PATCH' ) |
  'STOP' 'ROLLING' ( 'MIGRATION' | 'PATCH' ) |
  ( 'ENABLE' | 'DISABLE' ) 'RESTRICTED' 'SESSION' |
  'SHUTDOWN' 'DISPATCHER' oracle_object_name_part |
  'REGISTER' |
  'SET' oracle_alter_system_set_clause + |
  'RESET' oracle_alter_system_reset_clause + |
  'RELOCATE' 'CLIENT' {string_literal} |
  oracle_cancel_sql_clause
)

private oracle_archive_log_clause ::= 'ARCHIVE' 'LOG' (
  'ALL' |
  'CHANGE' {signed_number} |
  'CURRENT' |
  'GROUP' {signed_number} |
  'LOGFILE' {string_literal} [ 'TO' {string_literal} ] |
  'NEXT' |
  'SEQUENCE' {signed_number}
)

private oracle_flush_target ::= (
  'BUFFER_CACHE' |
  'FLASH_CACHE' |
  'GLOBAL' 'CONTEXT' |
  'REDO' |
  'SHARED_POOL'
)

private oracle_end_session_clause ::= (
  'DISCONNECT' 'SESSION' {string_literal} [ 'POST_TRANSACTION' ] |
  'KILL' 'SESSION' {string_literal}
) [ 'IMMEDIATE' | 'FORCE' | 'NOREPLAY' ] [ 'TIMEOUT' {signed_number} ]

private oracle_cancel_sql_clause ::= 'CANCEL' 'SQL' {string_literal}

private oracle_alter_system_set_clause ::= (
  oracle_parameter_assignment |
  'USE_STORED_OUTLINES' EQ ( 'TRUE' | 'FALSE' | oracle_object_name_part ) |
  'GLOBAL_TOPIC_ENABLED' EQ ( 'TRUE' | 'FALSE' )
)

private oracle_alter_system_reset_clause ::= oracle_object_name_part oracle_parameter_scope_clause *

private oracle_parameter_assignment ::= oracle_object_name_part EQ oracle_parameter_value ( COMMA oracle_parameter_value ) *
  [ 'COMMENT' EQ {string_literal} ] [ 'DEFERRED' ] [ oracle_container_clause ] oracle_parameter_scope_clause *

private oracle_parameter_scope_clause ::= (
  'SCOPE' EQ ( 'MEMORY' | 'SPFILE' | 'BOTH' ) |
  'SID' EQ ( {string_literal} | string )
)

private oracle_parameter_value ::= {string_literal} | {signed_number} | oracle_object_name_part | 'TRUE' | 'FALSE' | 'LOCAL' | 'DBTIMEZONE'

administer_key_management_stmt ::= 'ADMINISTER' 'KEY' 'MANAGEMENT' (
  oracle_administer_key_management_set_clause |
  oracle_keystore_management_clause |
  oracle_key_management_clause |
  oracle_secret_management_clause |
  oracle_zero_downtime_software_patching_clause
) {
  pin = 3
}

private oracle_keystore_management_clause ::= (
  'CREATE' [ 'LOCAL' ] [ 'AUTO_LOGIN' ] 'KEYSTORE' [ oracle_key_management_value ] [ 'FROM' 'KEYSTORE' oracle_key_management_value ] oracle_identified_by |
  'BACKUP' 'KEYSTORE' [ 'USING' oracle_key_management_value ] [ oracle_identified_by ] [ 'TO' oracle_key_management_value ] |
  'ALTER' 'KEYSTORE' 'PASSWORD' oracle_identified_by 'SET' oracle_key_management_password oracle_with_backup_clause |
  'MERGE' 'KEYSTORE' oracle_key_management_value 'AND' 'KEYSTORE' oracle_key_management_value oracle_identified_by
    'INTO' 'NEW' 'KEYSTORE' oracle_key_management_value oracle_identified_by |
  'MERGE' 'KEYSTORE' oracle_key_management_value 'INTO' 'EXISTING' 'KEYSTORE' oracle_key_management_value oracle_identified_by
    [ oracle_with_backup_clause ] |
  'ISOLATE' 'KEYSTORE' oracle_identified_by 'FROM' 'ROOT' 'KEYSTORE' [ 'FORCE' 'KEYSTORE' ] oracle_identified_by oracle_with_backup_clause |
  'UNITE' 'KEYSTORE' oracle_identified_by 'WITH' 'ROOT' 'KEYSTORE' [ 'FORCE' 'KEYSTORE' ] oracle_identified_by oracle_with_backup_clause
)

private oracle_administer_key_management_set_clause ::= 'SET' (
  'KEYSTORE' ( 'OPEN' | 'CLOSE' ) [ oracle_identified_by ] [ oracle_container_clause ] |
  [ 'ENCRYPTION' ] 'KEY' [ oracle_key_identifier_value ] [ 'USING' 'TAG' oracle_key_management_value ]
    [ oracle_using_algorithm_clause ] [ 'FORCE' 'KEYSTORE' ] oracle_identified_by
    [ ( 'MIGRATE' | 'REVERSE' 'MIGRATE' ) 'USING' oracle_key_management_password ] [ oracle_with_backup_clause ] [ oracle_container_clause ] |
  'TAG' oracle_key_management_value 'FOR' oracle_key_management_value [ 'FORCE' 'KEYSTORE' ] oracle_identified_by [ oracle_with_backup_clause ]
)

private oracle_key_management_clause ::= (
  'CREATE' 'KEY' [ 'USING' 'TAG' oracle_key_management_value ] oracle_identified_by [ oracle_with_backup_clause ] [ oracle_container_clause ] |
  'USE' 'KEY' oracle_key_management_value oracle_identified_by [ oracle_with_backup_clause ] [ oracle_container_clause ] |
  'EXPORT' 'KEYS' [ 'WITH' 'SECRET' oracle_key_management_value ] 'TO' oracle_key_management_value oracle_identified_by
    [ oracle_with_identifier_clause ] [ oracle_container_clause ] |
  'IMPORT' 'KEYS' [ 'WITH' 'SECRET' oracle_key_management_value ] 'FROM' oracle_key_management_value oracle_identified_by
    [ oracle_with_backup_clause ] [ oracle_container_clause ] |
  ( 'MOVE' | 'UPLOAD' | 'DOWNLOAD' ) 'KEYS' [ 'WITH' 'IDENTIFIER' oracle_identifier_list ] [ oracle_identified_by ] [ oracle_container_clause ]
)

private oracle_secret_management_clause ::= (
  ( 'ADD' | 'UPDATE' ) 'SECRET' oracle_key_management_value 'FOR' 'CLIENT' oracle_key_management_value
    [ 'USING' 'TAG' oracle_key_management_value ] oracle_identified_by [ oracle_with_backup_clause ] |
  'DELETE' 'SECRET' 'FOR' 'CLIENT' oracle_key_management_value oracle_identified_by [ oracle_with_backup_clause ] |
  ( 'ADD' | 'UPDATE' ) 'SECRET' 'SEPS' oracle_key_management_value 'FOR' 'CLIENT' oracle_key_management_value
    [ 'USING' 'TAG' oracle_key_management_value ] oracle_identified_by [ oracle_with_backup_clause ] |
  'DELETE' 'SECRET' 'SEPS' 'FOR' 'CLIENT' oracle_key_management_value oracle_identified_by [ oracle_with_backup_clause ]
)

private oracle_zero_downtime_software_patching_clause ::= 'SWITCHOVER' [ 'TO' ] 'LIBRARY' oracle_key_management_value 'FOR' 'ALL' 'CONTAINERS'

private oracle_identified_by ::= 'IDENTIFIED' 'BY' ( 'EXTERNAL' 'STORE' | oracle_key_management_password )

private oracle_with_backup_clause ::= 'WITH' 'BACKUP' [ 'USING' oracle_key_management_value ]

private oracle_using_algorithm_clause ::= 'USING' 'ALGORITHM' oracle_key_management_value

private oracle_with_identifier_clause ::= 'WITH' 'IDENTIFIER' ( 'IN' oracle_identifier_list | oracle_key_management_value )

private oracle_identifier_list ::= oracle_key_management_value ( COMMA oracle_key_management_value ) *

private oracle_key_management_password ::= oracle_key_management_value

private oracle_key_identifier_value ::= {string_literal} | string

private oracle_key_management_value ::= {string_literal} | string | oracle_object_name_part

create_user_stmt ::= 'CREATE' 'USER' [ 'IF' 'NOT' 'EXISTS' ] oracle_object_name_part
  ( oracle_user_authentication | 'NO' 'AUTHENTICATION' ) oracle_user_clause * {
  pin = 2
}

alter_user_stmt ::= 'ALTER' 'USER' [ 'IF' 'EXISTS' ] (
  oracle_object_name_part oracle_alter_user_clause + |
  oracle_object_name_part ( COMMA oracle_object_name_part ) * oracle_proxy_clause
) {
  pin = 2
}

private oracle_user_authentication ::= 'IDENTIFIED' (
  'BY' oracle_authentication_value [ [ 'HTTP' ] 'DIGEST' ( 'ENABLE' | 'DISABLE' ) ] [ 'AND' 'FACTOR' {string_literal} 'AS' {string_literal} ] |
  'EXTERNALLY' [ 'AS' {string_literal} ] |
  'GLOBALLY' [ 'AS' {string_literal} ]
)

private oracle_alter_user_clause ::= (
  'IDENTIFIED' (
    'BY' oracle_authentication_value [ 'REPLACE' oracle_authentication_value ] |
    'EXTERNALLY' [ 'AS' {string_literal} ] |
    'GLOBALLY' [ 'AS' {string_literal} ]
  ) |
  'NO' 'AUTHENTICATION' |
  ( 'ADD' | 'UPDATE' ) LP 'FACTOR' {string_literal} 'AS' {string_literal} RP |
  'DROP' 'FACTOR' {string_literal} |
  'DEFAULT' 'ROLE' oracle_default_role_clause |
  'EXPIRE' 'PASSWORD' 'ROLLOVER' 'PERIOD' |
  oracle_container_data_clause |
  oracle_user_clause
)

private oracle_user_clause ::= (
  'DEFAULT' 'COLLATION' oracle_object_name_part |
  'DEFAULT' 'TABLESPACE' oracle_object_name_part |
  [ 'LOCAL' ] 'TEMPORARY' 'TABLESPACE' oracle_object_name_part |
  'QUOTA' ( oracle_size_clause | 'UNLIMITED' ) 'ON' oracle_object_name_part |
  'PROFILE' oracle_object_name_part |
  'PASSWORD' 'EXPIRE' |
  'ACCOUNT' ( 'LOCK' | 'UNLOCK' ) |
  'ENABLE' 'EDITIONS' [ 'FOR' oracle_object_name_part ( COMMA oracle_object_name_part ) * ] [ 'FORCE' ] |
  [ 'HTTP' ] 'DIGEST' ( 'ENABLE' | 'DISABLE' ) |
  oracle_container_clause |
  ( 'ENABLE' | 'DISABLE' ) 'DICTIONARY' 'PROTECTION' |
  'READ' ( 'ONLY' | 'WRITE' )
)

private oracle_default_role_clause ::= (
  oracle_object_name_part ( COMMA oracle_object_name_part ) * |
  'ALL' [ 'EXCEPT' oracle_object_name_part ( COMMA oracle_object_name_part ) * ] |
  'NONE'
)

private oracle_proxy_clause ::= (
  'GRANT' 'CONNECT' 'THROUGH' ( 'ENTERPRISE' 'USERS' | oracle_object_name_part oracle_db_user_proxy_clauses ) |
  'REVOKE' 'CONNECT' 'THROUGH' ( 'ENTERPRISE' 'USERS' | oracle_object_name_part )
)

private oracle_db_user_proxy_clauses ::= [ 'WITH' ( 'ROLE' oracle_proxy_role_clause | 'NO' 'ROLES' ) ] [ 'AUTHENTICATION' 'REQUIRED' ]

private oracle_proxy_role_clause ::= (
  oracle_object_name_part ( COMMA oracle_object_name_part ) * |
  'ALL' 'EXCEPT' oracle_object_name_part ( COMMA oracle_object_name_part ) *
)

private oracle_container_data_clause ::= (
  'SET' 'CONTAINER_DATA' EQ oracle_container_data_value |
  'ADD' 'CONTAINER_DATA' EQ oracle_container_name_list |
  'REMOVE' 'CONTAINER_DATA' EQ oracle_container_name_list
) [ 'FOR' oracle_schema_object_name ]

private oracle_container_data_value ::= 'ALL' | 'DEFAULT' | oracle_container_name_list

private oracle_container_name_list ::= LP oracle_object_name_part ( COMMA oracle_object_name_part ) * RP

private oracle_size_clause ::= {signed_number} [ oracle_object_name_part ]

private oracle_authentication_value ::= oracle_object_name_part | {string_literal}

create_role_stmt ::= 'CREATE' 'ROLE' [ 'IF' 'NOT' 'EXISTS' ] oracle_object_name_part
  [ oracle_role_identification ] [ oracle_container_clause ] {
  pin = 2
}

alter_role_stmt ::= 'ALTER' 'ROLE' [ 'IF' 'EXISTS' ] oracle_object_name_part
  oracle_role_identification [ oracle_container_clause ] {
  pin = 2
}

grant_stmt ::= 'GRANT' (
  oracle_grant_object_privileges |
  oracle_grant_roles_to_programs |
  oracle_grant_system_privileges
) [ oracle_container_clause ] {
  pin = 1
}

revoke_stmt ::= 'REVOKE' (
  oracle_revoke_roles_from_programs |
  oracle_revoke_object_privileges |
  oracle_revoke_system_privileges
) [ oracle_container_clause ] {
  pin = 1
}

drop_role_stmt ::= 'DROP' 'ROLE' [ 'IF' 'EXISTS' ] oracle_object_name_part {
  pin = 2
}

drop_user_stmt ::= 'DROP' 'USER' [ 'IF' 'EXISTS' ] oracle_object_name_part [ 'CASCADE' ] {
  pin = 2
}

private oracle_role_identification ::= (
  'NOT' 'IDENTIFIED' |
  'IDENTIFIED' (
    'BY' oracle_role_password |
    'USING' oracle_schema_object_name |
    'EXTERNALLY' |
    'GLOBALLY' 'AS' {string_literal}
  )
)

private oracle_grant_system_privileges ::= oracle_grant_system_privilege ( COMMA oracle_grant_system_privilege ) *
  'TO' ( oracle_grantee_identified_by | oracle_grantee_clause ) [ 'WITH' ( 'ADMIN' | 'DELEGATE' ) 'OPTION' ]

private oracle_revoke_system_privileges ::= oracle_grant_system_privilege ( COMMA oracle_grant_system_privilege ) *
  'FROM' oracle_grantee_clause

private oracle_grant_object_privileges ::= oracle_grant_object_privilege ( COMMA oracle_grant_object_privilege ) *
  oracle_on_object_clause 'TO' oracle_grantee_clause [ 'WITH' 'HIERARCHY' 'OPTION' ] [ 'WITH' 'GRANT' 'OPTION' ]

private oracle_revoke_object_privileges ::= oracle_revoke_object_privilege ( COMMA oracle_revoke_object_privilege ) *
  oracle_on_object_clause 'FROM' oracle_grantee_clause [ 'CASCADE' 'CONSTRAINTS' | 'FORCE' ]

private oracle_grant_roles_to_programs ::= oracle_object_name_part ( COMMA oracle_object_name_part ) *
  'TO' oracle_program_unit ( COMMA oracle_program_unit ) *

private oracle_revoke_roles_from_programs ::= ( oracle_object_name_part ( COMMA oracle_object_name_part ) * | 'ALL' )
  'FROM' oracle_program_unit ( COMMA oracle_program_unit ) *

private oracle_grantee_clause ::= oracle_grantee ( COMMA oracle_grantee ) *

private oracle_grantee ::= oracle_object_name_part | 'PUBLIC'

private oracle_grantee_identified_by ::= oracle_object_name_part ( COMMA oracle_object_name_part ) *
  'IDENTIFIED' 'BY' oracle_role_password ( COMMA oracle_role_password ) *

private oracle_grant_system_privilege ::= (
  'ALL' 'PRIVILEGES' |
  'UNLIMITED' 'TABLESPACE' |
  'CREATE' oracle_system_privilege_target |
  'ALTER' oracle_any_system_privilege_target |
  'DROP' oracle_any_system_privilege_target |
  'SELECT' oracle_any_system_privilege_target |
  'INSERT' oracle_any_system_privilege_target |
  'UPDATE' oracle_any_system_privilege_target |
  'DELETE' oracle_any_system_privilege_target |
  'EXECUTE' oracle_any_system_privilege_target |
  oracle_object_name_part
)

private oracle_system_privilege_target ::= (
  'SESSION' |
  'TABLE' |
  'VIEW' |
  'PROCEDURE' |
  'SEQUENCE' |
  'SYNONYM' |
  'TRIGGER' |
  'USER' |
  'ROLE' |
  oracle_any_system_privilege_target
)

private oracle_any_system_privilege_target ::= 'ANY' (
  'TABLE' |
  'VIEW' |
  'PROCEDURE' |
  'SEQUENCE' |
  'SYNONYM' |
  'TRIGGER' |
  'TYPE' |
  'DIRECTORY'
)

private oracle_grant_object_privilege ::= oracle_object_privilege [ LP oracle_object_name_part ( COMMA oracle_object_name_part ) * RP ]

private oracle_revoke_object_privilege ::= oracle_object_privilege

private oracle_object_privilege ::= (
  'ALL' [ 'PRIVILEGES' ] |
  'SELECT' |
  'INSERT' |
  'UPDATE' |
  'DELETE' |
  'REFERENCES' |
  'READ' |
  'WRITE' |
  'EXECUTE' |
  'DEBUG' |
  'FLASHBACK' |
  'ON' 'COMMIT' 'REFRESH'
)

private oracle_on_object_clause ::= 'ON' (
  oracle_schema_object_name |
  'USER' oracle_object_name_part ( COMMA oracle_object_name_part ) * |
  'DIRECTORY' oracle_object_name_part |
  'EDITION' oracle_object_name_part |
  'MINING' 'MODEL' oracle_schema_object_name |
  'JAVA' ( 'SOURCE' | 'RESOURCE' ) oracle_schema_object_name |
  'SQL' 'TRANSLATION' 'PROFILE' oracle_schema_object_name
)

private oracle_program_unit ::= ( 'FUNCTION' | 'PROCEDURE' | 'PACKAGE' ) oracle_schema_object_name

private oracle_container_clause ::= 'CONTAINER' EQ ( 'CURRENT' | 'ALL' )

analyze_stmt ::= 'ANALYZE' oracle_analyze_target oracle_analyze_action {
  extends = "com.alecstrong.sql.psi.core.psi.impl.SqlAnalyzeStmtImpl"
  implements = "com.alecstrong.sql.psi.core.psi.SqlAnalyzeStmt"
  override = true
  pin = 1
}

private oracle_analyze_target ::= (
  ( 'TABLE' | 'INDEX' ) oracle_schema_object_name [ oracle_partition_extension_clause ] |
  'CLUSTER' oracle_schema_object_name
)

private oracle_analyze_action ::= (
  oracle_validation_clause |
  'LIST' 'CHAINED' 'ROWS' [ oracle_into_clause ] |
  'DELETE' [ 'SYSTEM' ] 'STATISTICS'
)

private oracle_validation_clause ::= (
  'VALIDATE' 'REF' 'UPDATE' [ 'SET' 'DANGLING' 'TO' 'NULL' ] |
  'VALIDATE' 'STRUCTURE' [ 'CASCADE' [ 'FAST' | 'COMPLETE' ( 'OFFLINE' | 'ONLINE' ) [ oracle_into_clause ] ] ]
)

private oracle_into_clause ::= 'INTO' oracle_schema_object_name

associate_statistics_stmt ::= 'ASSOCIATE' 'STATISTICS' 'WITH'
  ( oracle_column_association | oracle_function_association ) [ oracle_storage_table_clause ] {
  pin = 2
}

private oracle_column_association ::= 'COLUMNS' oracle_column_reference ( COMMA oracle_column_reference ) * oracle_using_statistics_type

private oracle_function_association ::= oracle_association_kind oracle_schema_object_name ( COMMA oracle_schema_object_name ) *
  ( oracle_using_statistics_type | oracle_default_statistics_clause )

private oracle_association_kind ::= 'FUNCTIONS' | 'PACKAGES' | 'TYPES' | 'INDEXES' | 'INDEXTYPES'

private oracle_using_statistics_type ::= 'USING' ( oracle_schema_object_name | 'NULL' )

private oracle_default_statistics_clause ::= (
  oracle_default_cost_clause [ COMMA oracle_default_selectivity_clause ] |
  oracle_default_selectivity_clause [ COMMA oracle_default_cost_clause ]
)

private oracle_default_cost_clause ::= 'DEFAULT' 'COST' LP <<expr '-1'>> COMMA <<expr '-1'>> COMMA <<expr '-1'>> RP

private oracle_default_selectivity_clause ::= 'DEFAULT' 'SELECTIVITY' <<expr '-1'>>

private oracle_storage_table_clause ::= 'WITH' ( 'SYSTEM' | 'USER' ) 'MANAGED' 'STORAGE' 'TABLES'

disassociate_statistics_stmt ::= 'DISASSOCIATE' 'STATISTICS' 'FROM' oracle_statistics_association_target [ 'FORCE' ] {
  pin = 2
}

private oracle_statistics_association_target ::= (
  'COLUMNS' oracle_column_reference ( COMMA oracle_column_reference ) * |
  oracle_association_kind oracle_schema_object_name ( COMMA oracle_schema_object_name ) *
)

private oracle_column_reference ::= oracle_object_name_part DOT oracle_object_name_part [ DOT oracle_object_name_part ]

rename_stmt ::= 'RENAME' oracle_object_name_part 'TO' oracle_object_name_part {
  pin = 1
}

comment_on_stmt ::= 'COMMENT' 'ON' oracle_comment_target 'IS' {string_literal} {
  pin = 2
}

private oracle_comment_target ::= (
  'AUDIT' 'POLICY' oracle_object_name_part |
  'COLUMN' oracle_column_reference |
  'EDITION' oracle_object_name_part |
  'INDEXTYPE' oracle_schema_object_name |
  'MATERIALIZED' 'VIEW' oracle_schema_object_name |
  'MINING' 'MODEL' oracle_schema_object_name |
  'OPERATOR' oracle_schema_object_name |
  'TABLE' oracle_schema_object_name |
  'PROPERTY' 'GRAPH' oracle_schema_object_name
)

purge_stmt ::= 'PURGE' (
  ( 'TABLE' | 'INDEX' ) oracle_schema_object_name |
  'TABLESPACE' 'SET' oracle_object_name_part [ 'USER' oracle_object_name_part ] |
  'TABLESPACE' oracle_object_name_part [ 'USER' oracle_object_name_part ] |
  'RECYCLEBIN' |
  'DBA_RECYCLEBIN'
) {
  pin = 1
}

flashback_table_stmt ::= 'FLASHBACK' 'TABLE' oracle_schema_object_name ( COMMA oracle_schema_object_name ) *
  'TO' (
    oracle_flashback_target [ ( 'ENABLE' | 'DISABLE' ) 'TRIGGERS' ] |
    'BEFORE' 'DROP' [ 'RENAME' 'TO' oracle_object_name_part ]
  ) {
  pin = 2
}

private oracle_flashback_target ::= (
  ( 'SCN' | 'TIMESTAMP' ) <<expr '-1'>> |
  'RESTORE' 'POINT' oracle_object_name_part
)

flashback_database_stmt ::= 'FLASHBACK' [ 'STANDBY' ] [ 'PLUGGABLE' ] 'DATABASE' [ oracle_object_name_part ]
  ( 'TO' oracle_flashback_target | 'TO' 'BEFORE' oracle_flashback_before_target ) {
  pin = 1
}

private oracle_flashback_before_target ::= (
  ( 'SCN' | 'TIMESTAMP' ) <<expr '-1'>> |
  'RESETLOGS'
)

drop_trigger_stmt ::= 'DROP' 'TRIGGER' [ 'IF' 'EXISTS' ] oracle_schema_object_name {
  extends = "com.alecstrong.sql.psi.core.psi.impl.SqlDropTriggerStmtImpl"
  implements = "com.alecstrong.sql.psi.core.psi.SqlDropTriggerStmt"
  override = true
  pin = 2
}

alter_sequence_stmt ::= 'ALTER' 'SEQUENCE' [ 'IF' 'EXISTS' ] oracle_schema_object_name oracle_sequence_clause * {
  pin = 2
}

private oracle_schema_object_name ::= oracle_object_name_part [ DOT oracle_object_name_part ]

private oracle_object_name_part ::= <<identifierExt <<identifier_real>>>> | string

private oracle_sequence_clause ::= (
  'INCREMENT' 'BY' {signed_number} |
  'START' 'WITH' {signed_number} |
  'RESTART' |
  'MAXVALUE' {signed_number} |
  'NOMAXVALUE' |
  'MINVALUE' {signed_number} |
  'NOMINVALUE' |
  'CYCLE' |
  'NOCYCLE' |
  'CACHE' {signed_number} |
  'NOCACHE' |
  'ORDER' |
  'NOORDER' |
  'KEEP' |
  'NOKEEP' |
  'SCALE' [ 'EXTEND' | 'NOEXTEND' ] |
  'NOSCALE' |
  'SHARD' [ 'EXTEND' | 'NOEXTEND' ] |
  'NOSHARD' |
  'SESSION' |
  'GLOBAL'
)

merge_stmt ::= 'MERGE' [ oracle_hint ] 'INTO' oracle_merge_table_reference [ oracle_merge_using_clause ] 'ON' LP <<expr '-1'>> RP
  ( oracle_merge_update_clause | oracle_merge_insert_clause ) + [ oracle_error_logging_clause ] {
  pin = 1
}

private oracle_hint ::= comment

private oracle_merge_using_clause ::= 'USING' (
  oracle_merge_table_reference |
  LP {compound_select_stmt} RP [ {table_alias} ] |
  oracle_merge_values_clause [ {table_alias} ]
)

private oracle_merge_table_reference ::= oracle_schema_object_name [ {table_alias} ]

private oracle_merge_values_clause ::= 'VALUES' LP oracle_merge_value ( COMMA oracle_merge_value ) * RP

private oracle_merge_update_clause ::= 'WHEN' 'MATCHED' 'THEN' 'UPDATE' 'SET'
  oracle_merge_assignment ( COMMA oracle_merge_assignment ) * [ oracle_where_clause ] [ 'DELETE' oracle_where_clause ]

private oracle_merge_insert_clause ::= 'WHEN' 'NOT' 'MATCHED' 'THEN' 'INSERT' (
  [ LP oracle_schema_object_name ( COMMA oracle_schema_object_name ) * RP ] 'VALUES' LP oracle_merge_value ( COMMA oracle_merge_value ) * RP |
  'SET' oracle_merge_assignment ( COMMA oracle_merge_assignment ) *
) [ oracle_where_clause ]

private oracle_merge_assignment ::= oracle_schema_object_name EQ oracle_merge_value

private oracle_merge_value ::= 'DEFAULT' | <<expr '-1'>>

private oracle_where_clause ::= 'WHERE' <<expr '-1'>>

private oracle_error_logging_clause ::= 'LOG' 'ERRORS' [ 'INTO' oracle_schema_object_name ] [ LP <<expr '-1'>> RP ]
  [ 'REJECT' 'LIMIT' ( {signed_number} | 'UNLIMITED' ) ]

call_stmt ::= 'CALL' oracle_call_routine_name LP [ oracle_call_argument ( COMMA oracle_call_argument ) * ] RP {
  pin = 1
}

private oracle_call_routine_name ::= oracle_schema_object_name [ DOT ( <<identifierExt <<identifier_real>>>> | string ) ]

private oracle_call_argument ::= <<expr '-1'>>

lock_table_stmt ::= 'LOCK' 'TABLE' oracle_lock_table_reference ( COMMA oracle_lock_table_reference ) * 'IN' oracle_lock_mode 'MODE'
  [ 'NOWAIT' | 'WAIT' {signed_number} ] {
  pin = 2
}

private oracle_lock_table_reference ::= oracle_schema_object_name [ oracle_partition_extension_clause ]

private oracle_partition_extension_clause ::= (
  'PARTITION' LP oracle_partition_name RP |
  'PARTITION' 'FOR' LP oracle_partition_key_value ( COMMA oracle_partition_key_value ) * RP |
  'SUBPARTITION' LP oracle_partition_name RP |
  'SUBPARTITION' 'FOR' LP oracle_partition_key_value ( COMMA oracle_partition_key_value ) * RP
)

private oracle_partition_name ::= <<identifierExt <<identifier_real>>>> | string

private oracle_partition_key_value ::= <<expr '-1'>>

private oracle_lock_mode ::= (
  'ROW' 'SHARE' |
  'ROW' 'EXCLUSIVE' |
  'SHARE' 'UPDATE' |
  'SHARE' 'ROW' 'EXCLUSIVE' |
  'SHARE' |
  'EXCLUSIVE'
)

explain_plan_stmt ::= 'EXPLAIN' 'PLAN' [ 'SET' 'STATEMENT_ID' EQ <<expr '-1'>> ] [ 'INTO' oracle_schema_object_name ] 'FOR'
  oracle_explainable_stmt {
  pin = 2
}

private oracle_explainable_stmt ::= (
  {compound_select_stmt} |
  {insert_stmt} |
  {update_stmt} |
  {delete_stmt} |
  merge_stmt |
  create_table_stmt |
  create_index_stmt
)

truncate_table_stmt ::= 'TRUNCATE' 'TABLE' oracle_schema_object_name [ oracle_materialized_view_log_clause ] [ oracle_truncate_storage_clause ] [ 'CASCADE' ] {
  pin = 2
}

truncate_cluster_stmt ::= 'TRUNCATE' 'CLUSTER' oracle_schema_object_name [ oracle_truncate_storage_clause ] {
  pin = 2
}

private oracle_materialized_view_log_clause ::= ( 'PRESERVE' | 'PURGE' ) ( 'MATERIALIZED' 'VIEW' | 'SNAPSHOT' ) 'LOG'

private oracle_truncate_storage_clause ::= (
  'DROP' [ 'ALL' ] 'STORAGE' |
  'REUSE' 'STORAGE'
)
