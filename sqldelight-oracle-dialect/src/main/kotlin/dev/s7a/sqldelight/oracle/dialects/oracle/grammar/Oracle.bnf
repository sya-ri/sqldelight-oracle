  {string_literal} |
  DIGIT |
  {signed_number} |
  COMMA |
  DOT |
  EQ |
  'BUILD' |
  'BY' |
  'CACHE' |
  'COMMIT' |
  'COMPRESS' |
  'COMPLETE' |
  'DEFERRED' |
  'DEMAND' |
