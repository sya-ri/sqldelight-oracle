  'FORCE' |
  'ADD' oracle_mv_log_augmentation |
  ( 'INCLUDING' | 'EXCLUDING' ) 'NEW' 'VALUES' |
  'PURGE' oracle_mv_log_purge_clause |
  'FOR' ( 'FAST' | 'SYNCHRONOUS' ) 'REFRESH' |
  'MOVE' oracle_mv_log_boundary_token * |
  'ALLOCATE' 'EXTENT' [ oracle_parenthesized_clause ] |
  'DEALLOCATE' 'UNUSED' [ 'KEEP' oracle_size_value ] |
  'SHRINK' 'SPACE' [ 'COMPACT' ] |
  ( 'CACHE' | 'NOCACHE' ) |
  ( 'LOGGING' | 'NOLOGGING' | 'FILESYSTEM_LIKE_LOGGING' ) |
  'PARALLEL' [ DIGIT | oracle_object_name_part ] |
  'NOPARALLEL' |
  'PCTFREE' DIGIT |
  'PCTUSED' DIGIT |
  'INITRANS' DIGIT |
  'TABLESPACE' oracle_schema_object_name
)

private oracle_mv_log_augmentation ::= (
  'ROWID' |
  'SEQUENCE' |
  'OBJECT' 'ID' |
  'PRIMARY' 'KEY' |
  LP oracle_object_name_part ( COMMA oracle_object_name_part ) * RP
)

private oracle_mv_log_purge_clause ::= (
  ( 'IMMEDIATE' [ 'SYNCHRONOUS' | 'ASYNCHRONOUS' ] ) |
  ( 'START' 'WITH' oracle_mv_log_boundary_token + 'NEXT' oracle_mv_log_boundary_token + )
)

private oracle_zonemap_clause ::= (
  'TABLESPACE' oracle_schema_object_name |
  'SCALE' DIGIT |
  'PCTFREE' DIGIT |
  'PCTUSED' DIGIT |
  'CACHE' |
  'NOCACHE' |
  'REFRESH' oracle_zonemap_refresh_option + |
  ( 'ENABLE' | 'DISABLE' ) 'PRUNING' |
  'COMPILE' |
  'REBUILD' |
  'UNUSABLE'
)

private oracle_create_zonemap_clause ::= (
  oracle_zonemap_on_table_clause |
  oracle_zonemap_as_subquery_clause |
  oracle_zonemap_clause
)

private oracle_zonemap_on_table_clause ::= 'ON' oracle_schema_object_name
  LP oracle_object_name_part ( COMMA oracle_object_name_part ) * RP

private oracle_zonemap_as_subquery_clause ::= [ LP oracle_object_name_part ( COMMA oracle_object_name_part ) * RP ] 'AS' oracle_zonemap_query_token +

private oracle_zonemap_refresh_option ::= (
  'FAST' |
  'COMPLETE' |
  'FORCE' |
  'ON' ( 'DEMAND' | 'COMMIT' | 'LOAD' [ 'DATA' 'MOVEMENT' ] | 'DATA' 'MOVEMENT' )
)

private oracle_zonemap_query_token ::= (
  oracle_dimension_reference |
  oracle_plsql_source_token |
  oracle_parenthesized_clause |
  'BY' |
  'FROM' |
  'GROUP' |
  'JOIN' |
  'LEFT' |
  'MAX' |
  'MIN' |
  'ON' |
  'OUTER' |
  'ROWID' |
  'SELECT' |
  'SYS_OP_ZONE_ID' |
  'WHERE'
)

private oracle_size_value ::= DIGIT oracle_object_name_part

private oracle_mv_log_boundary_token ::= oracle_plsql_source_token | 'AT' | 'NEXT' | 'START' | 'WITH' | 'TABLESPACE'

create_analytic_view_stmt ::= 'CREATE' oracle_create_replace_clause * 'ANALYTIC' 'VIEW' [ 'IF' 'NOT' 'EXISTS' ]
  oracle_schema_object_name oracle_analytic_dimension_create_clause + {
  pin = 4
}

create_attribute_dimension_stmt ::= 'CREATE' oracle_create_replace_clause * 'ATTRIBUTE' 'DIMENSION' [ 'IF' 'NOT' 'EXISTS' ]
  oracle_schema_object_name oracle_analytic_dimension_create_clause + {
  pin = 4
}

create_hierarchy_stmt ::= 'CREATE' oracle_create_replace_clause * 'HIERARCHY' [ 'IF' 'NOT' 'EXISTS' ]
  oracle_schema_object_name oracle_analytic_dimension_create_clause + {
  pin = 3
}

create_dimension_stmt ::= 'CREATE' 'DIMENSION' [ 'IF' 'NOT' 'EXISTS' ] oracle_schema_object_name
  oracle_analytic_dimension_create_clause + {
  pin = 2
}

private oracle_create_replace_clause ::= 'OR' 'REPLACE' | 'FORCE' | 'NOFORCE' | 'NO' 'FORCE'

private oracle_analytic_dimension_create_clause ::= (
  'SHARING' EQ ( 'METADATA' | 'NONE' ) |
  'DIMENSION' 'TYPE' ( 'STANDARD' | 'TIME' ) |
  'USING' oracle_dimension_create_token + |
  'ATTRIBUTES' oracle_dimension_create_token + |
  'LEVEL' oracle_dimension_create_token + |
  'ALL' oracle_dimension_create_token + |
  'DIMENSION' 'BY' oracle_dimension_create_token + |
  'MEASURES' oracle_dimension_create_token + |
  'DEFAULT' ( 'MEASURE' | 'AGGREGATE' ) oracle_dimension_create_token + |
  'CACHE' oracle_dimension_create_token + |
  'FACT' 'COLUMNS' oracle_dimension_create_token + |
  'QUERY' 'TRANSFORMATION' oracle_dimension_create_token * |
  'HIERARCHIES' oracle_dimension_create_token + |
  'ATTRIBUTE' oracle_dimension_create_token + |
  oracle_dimension_create_token
)

private oracle_dimension_create_token ::= (
  oracle_dimension_reference |
  oracle_plsql_source_token |
  oracle_parenthesized_clause |
  'ACROSS' |
  'AGGREGATE' |
  'ALL' |
  'ALTERNATE' |
  'ANCESTOR' |
  'AT' |
  'ATTRIBUTE' |
  'ATTRIBUTES' |
  'BY' |
  'CACHE' |
  'CAPTION' |
  'CHILD' |
  'CLASSIFICATION' |
  'COLUMNS' |
  'DEFAULT' |
  'DESCRIPTION' |
  'DETERMINES' |
  'DIMENSION' |
  'DISTINCT' |
  'FACT' |
  'HIERARCHIES' |
  'HIERARCHY' |
  'KEY' |
  'LEVEL' |
  'LEVELS' |
  'MEASURE' |
  'MEASURES' |
  'MEMBER' |
  'OFFSET' |
  'OF' |
  'ORDER' |
  'OVER' |
  'QUERY' |
  'REFERENCES' |
  'RELY' |
  'REMOTE' |
  'SKIP' |
  'STANDARD' |
  'TIME' |
  'TRANSFORMATION' |
  'TYPE' |
  'USING' |
  'VALUE'
)

alter_analytic_view_stmt ::= 'ALTER' 'ANALYTIC' 'VIEW' [ 'IF' 'EXISTS' ] oracle_schema_object_name oracle_analytic_view_clause {
  pin = 3
}

alter_attribute_dimension_stmt ::= 'ALTER' 'ATTRIBUTE' 'DIMENSION' [ 'IF' 'EXISTS' ] oracle_schema_object_name oracle_rename_or_compile_clause {
  pin = 3
}

alter_hierarchy_stmt ::= 'ALTER' 'HIERARCHY' [ 'IF' 'EXISTS' ] oracle_schema_object_name oracle_rename_or_compile_clause {
  pin = 2
}

alter_dimension_stmt ::= 'ALTER' 'DIMENSION' oracle_schema_object_name oracle_dimension_clause + {
  pin = 2
}

private oracle_rename_or_compile_clause ::= 'RENAME' 'TO' oracle_object_name_part | 'COMPILE'

private oracle_analytic_view_clause ::= (
  oracle_rename_or_compile_clause |
  ( 'ADD' | 'DROP' ) 'CACHE' 'MEASURE' 'GROUP' LP oracle_object_name_part ( COMMA oracle_object_name_part ) * RP
    'LEVELS' LP oracle_dimension_reference ( COMMA oracle_dimension_reference ) * RP
)

private oracle_dimension_clause ::= (
  'COMPILE' |
  'ADD' oracle_dimension_boundary_token + |
  'DROP' oracle_dimension_boundary_token + [ 'CASCADE' | 'RESTRICT' ]
)

private oracle_dimension_reference ::= oracle_schema_object_name ( DOT oracle_object_name_part ) *

private oracle_dimension_boundary_token ::= (
  oracle_dimension_reference |
  oracle_plsql_source_token |
  'ATTRIBUTE' |
  'DETERMINES' |
  'HIERARCHY' |
  'LEVEL' |
  'CHILD' |
  'OF' |
  'JOIN' |
  'KEY' |
  'REFERENCES'
)

alter_cluster_stmt ::= 'ALTER' 'CLUSTER' [ 'IF' 'EXISTS' ] oracle_schema_object_name oracle_cluster_clause + {
  pin = 2
}

alter_database_link_stmt ::= 'ALTER' [ 'SHARED' ] [ 'PUBLIC' ] 'DATABASE' 'LINK' [ 'IF' 'EXISTS' ] oracle_database_link_name
  oracle_database_link_clause {
  pin = 5
}

alter_indextype_stmt ::= 'ALTER' 'INDEXTYPE' [ 'IF' 'EXISTS' ] oracle_schema_object_name oracle_indextype_clause + {
  pin = 2
}

alter_operator_stmt ::= 'ALTER' 'OPERATOR' [ 'IF' 'EXISTS' ] oracle_schema_object_name oracle_operator_clause {
  pin = 2
}

alter_outline_stmt ::= 'ALTER' [ 'PUBLIC' | 'PRIVATE' ] 'OUTLINE' oracle_schema_object_name oracle_outline_clause {
  pin = 3
}

create_operator_stmt ::= 'CREATE' [ 'OR' 'REPLACE' ] 'OPERATOR' [ 'IF' 'NOT' 'EXISTS' ]
  oracle_schema_object_name [ 'SHARING' EQ ( 'METADATA' | 'NONE' ) ] oracle_create_operator_clause + {
}

create_outline_stmt ::= 'CREATE' [ 'OR' 'REPLACE' ] [ 'PUBLIC' | 'PRIVATE' ] 'OUTLINE'
  [ oracle_schema_object_name ] oracle_create_outline_clause + {
}

create_profile_stmt ::= 'CREATE' [ 'MANDATORY' ] 'PROFILE' oracle_object_name_part 'LIMIT'
  oracle_profile_limit + [ oracle_container_clause ] {
}

create_schema_stmt ::= 'CREATE' 'SCHEMA' 'AUTHORIZATION' oracle_object_name_part oracle_schema_element + {
}

create_flashback_archive_stmt ::= 'CREATE' 'FLASHBACK' 'ARCHIVE' [ 'DEFAULT' ] oracle_object_name_part
  'TABLESPACE' oracle_object_name_part [ oracle_flashback_archive_quota ] [ 'RETENTION' oracle_flashback_archive_retention ]
  [ [ 'NO' ] 'OPTIMIZE' 'DATA' ] {
}

private oracle_cluster_clause ::= (
  'SIZE' oracle_size_clause |
  'CACHE' |
  'NOCACHE' |
  'ALLOCATE' 'EXTENT' oracle_cluster_boundary_token * |
  'DEALLOCATE' 'UNUSED' [ 'KEEP' oracle_size_clause ] |
  'MODIFY' 'PARTITION' oracle_object_name_part 'ALLOCATE' 'EXTENT' oracle_cluster_boundary_token * |
  oracle_cluster_boundary_token
)

private oracle_database_link_clause ::= (
  'CONNECT' (
    'TO' oracle_object_name_part 'IDENTIFIED' 'BY' oracle_authentication_value [ oracle_dblink_authentication ] |
    'WITH' oracle_object_name_part
  ) |
  oracle_dblink_authentication
)

private oracle_dblink_authentication ::= 'AUTHENTICATED' (
  'BY' oracle_object_name_part 'IDENTIFIED' 'BY' oracle_authentication_value |
  'WITH' oracle_object_name_part
)

private oracle_indextype_clause ::= (
  'COMPILE' |
  ( 'ADD' | 'DROP' ) 'OPERATOR' oracle_schema_object_name [ LP oracle_type_name ( COMMA oracle_type_name ) * RP ] |
  'USING' oracle_indextype_boundary_token + |
  'WITH' 'LOCAL' 'PARTITION' oracle_indextype_boundary_token *
)

private oracle_operator_clause ::= (
  'COMPILE' |
  'ADD' 'BINDING' oracle_operator_boundary_token + |
  'DROP' 'BINDING' oracle_operator_boundary_token + [ 'FORCE' ]
)

private oracle_outline_clause ::= (
  'REBUILD' |
  'RENAME' 'TO' oracle_object_name_part |
  'CHANGE' 'CATEGORY' 'TO' oracle_object_name_part |
  'ENABLE' |
  'DISABLE'
)

private oracle_create_operator_clause ::= (
  'BINDING' LP oracle_type_name ( COMMA oracle_type_name ) * RP 'RETURN' oracle_type_name oracle_operator_binding_clause * |
  oracle_operator_binding_clause
)

private oracle_operator_binding_clause ::= (
  'ANCILLARY' 'TO' oracle_schema_object_name [ LP oracle_type_name ( COMMA oracle_type_name ) * RP ] |
  'WITH' ( 'INDEX' | 'SCAN' | 'COLUMN' ) 'CONTEXT' |
  'COMPUTE' 'ANCILLARY' 'DATA' |
  'USING' oracle_schema_object_name
)

private oracle_create_outline_clause ::= (
  'FROM' [ 'PUBLIC' | 'PRIVATE' ] oracle_schema_object_name |
  'FOR' 'CATEGORY' oracle_object_name_part |
  'ON' oracle_outline_statement_token +
)

private oracle_schema_element ::= {create_table_stmt} | {create_view_stmt} | grant_stmt

private oracle_outline_statement_token ::= (
  oracle_dimension_reference |
  oracle_plsql_source_token |
  oracle_parenthesized_clause |
  'CREATE' |
  'DELETE' |
  'FROM' |
  'INSERT' |
  'INTO' |
  'SELECT' |
  'UPDATE' |
  'WHERE'
)

private oracle_cluster_boundary_token ::= (
  oracle_plsql_source_token |
  oracle_size_clause |
  'FREEPOOLS' |
  'INITRANS' |
  'MAXEXTENTS' |
  'MINEXTENTS' |
  'NEXT' |
  'PARALLEL' |
  'PCTFREE' |
  'PCTINCREASE' |
  'PCTUSED' |
  'STORAGE'
)

private oracle_indextype_boundary_token ::= (
  oracle_plsql_source_token |
  oracle_type_name |
  'ARRAY' |
  'DML' |
  'LOCAL' |
  'PARTITION' |
  'STORAGE' |
  'TABLE'
)

private oracle_operator_boundary_token ::= (
  oracle_plsql_source_token |
  oracle_type_name |
  'BINDING' |
  'CONTEXT' |
  'RETURN' |
  'USING'
)

drop_synonym_stmt ::= 'DROP' [ 'PUBLIC' ] 'SYNONYM' [ 'IF' 'EXISTS' ] oracle_schema_object_name [ 'FORCE' ] {
  pin = 2
}

drop_type_body_stmt ::= 'DROP' 'TYPE' 'BODY' [ 'IF' 'EXISTS' ] oracle_schema_object_name {
  pin = 3
}

drop_type_stmt ::= 'DROP' 'TYPE' [ 'IF' 'EXISTS' ] oracle_schema_object_name [ 'FORCE' | 'VALIDATE' ] {
  pin = 2
}

drop_function_stmt ::= 'DROP' 'FUNCTION' [ 'IF' 'EXISTS' ] oracle_schema_object_name {
  pin = 2
}

drop_procedure_stmt ::= 'DROP' 'PROCEDURE' [ 'IF' 'EXISTS' ] oracle_schema_object_name {
  pin = 2
}

drop_package_stmt ::= 'DROP' 'PACKAGE' [ 'BODY' ] [ 'IF' 'EXISTS' ] oracle_schema_object_name {
  pin = 2
}

drop_library_stmt ::= 'DROP' 'LIBRARY' [ 'IF' 'EXISTS' ] oracle_schema_object_name {
  pin = 2
}

drop_java_stmt ::= 'DROP' 'JAVA' ( 'SOURCE' | 'CLASS' | 'RESOURCE' ) [ 'IF' 'EXISTS' ] oracle_schema_object_name {
  pin = 3
}

drop_analytic_view_stmt ::= 'DROP' 'ANALYTIC' 'VIEW' [ 'IF' 'EXISTS' ] oracle_schema_object_name {
  pin = 3
}

drop_attribute_dimension_stmt ::= 'DROP' 'ATTRIBUTE' 'DIMENSION' [ 'IF' 'EXISTS' ] oracle_schema_object_name {
  pin = 3
}

drop_hierarchy_stmt ::= 'DROP' 'HIERARCHY' [ 'IF' 'EXISTS' ] oracle_schema_object_name {
  pin = 2
}

drop_dimension_stmt ::= 'DROP' 'DIMENSION' oracle_schema_object_name {
  pin = 2
}

drop_cluster_stmt ::= 'DROP' 'CLUSTER' [ 'IF' 'EXISTS' ] oracle_schema_object_name [ 'INCLUDING' 'TABLES' ] [ 'CASCADE' 'CONSTRAINTS' ] {
  pin = 2
}

drop_database_link_stmt ::= 'DROP' [ 'PUBLIC' ] 'DATABASE' 'LINK' [ 'IF' 'EXISTS' ] oracle_database_link_name {
  pin = 4
}

private oracle_database_link_name ::= oracle_schema_object_name [ DOT ( <<identifierExt <<identifier_real>>>> | string ) ]

drop_directory_stmt ::= 'DROP' 'DIRECTORY' [ 'IF' 'EXISTS' ] oracle_schema_object_name {
  pin = 2
}

drop_indextype_stmt ::= 'DROP' 'INDEXTYPE' [ 'IF' 'EXISTS' ] oracle_schema_object_name [ 'FORCE' ] {
  pin = 2
}

drop_operator_stmt ::= 'DROP' 'OPERATOR' [ 'IF' 'EXISTS' ] oracle_schema_object_name [ 'FORCE' ] {
  pin = 2
}

drop_outline_stmt ::= 'DROP' 'OUTLINE' oracle_schema_object_name {
  pin = 2
}

drop_property_graph_stmt ::= 'DROP' 'PROPERTY' 'GRAPH' [ 'IF' 'EXISTS' ] oracle_schema_object_name {
  pin = 3
}

create_property_graph_stmt ::= 'CREATE' [ 'OR' 'REPLACE' ] 'PROPERTY' 'GRAPH' [ 'IF' 'NOT' 'EXISTS' ]
  oracle_schema_object_name oracle_property_graph_clause + {
  pin = 4
}

alter_property_graph_stmt ::= 'ALTER' 'PROPERTY' 'GRAPH' [ 'IF' 'EXISTS' ] oracle_schema_object_name 'COMPILE' {
  pin = 3
}

private oracle_property_graph_clause ::= (
  'VERTEX' 'TABLES' oracle_property_graph_token + |
  'EDGE' 'TABLES' oracle_property_graph_token + |
  'OPTIONS' oracle_property_graph_token + |
  oracle_property_graph_token
)

private oracle_property_graph_token ::= (
  oracle_dimension_reference |
  oracle_plsql_source_token |
  oracle_parenthesized_clause |
  'ALLOW' |
  'ALL' |
  'ARE' |
  'COLUMNS' |
  'DEFAULT' |
  'DESTINATION' |
  'DISALLOW' |
  'EDGE' |
  'ENFORCED' |
  'EXCEPT' |
  'GRAPH' |
  'KEY' |
  'LABEL' |
  'MIXED' |
  'MODE' |
  'NO' |
  'OPTIONS' |
  'PROPERTIES' |
  'PROPERTY' |
  'REFERENCES' |
  'SOURCE' |
  'TABLES' |
  'TRUSTED' |
  'TYPES' |
  'VERTEX'
)

create_json_relational_duality_view_stmt ::= 'CREATE' oracle_json_duality_create_modifier * 'JSON' [ 'RELATIONAL' ]
  'DUALITY' 'VIEW' [ 'IF' 'NOT' 'EXISTS' ] oracle_schema_object_name
  [ oracle_json_duality_replication_clause ] 'AS' oracle_json_duality_definition_token + {
  pin = 5
}

private oracle_json_duality_create_modifier ::= 'OR' 'REPLACE' | 'FORCE' | 'NOFORCE' | 'NO' 'FORCE' | 'EDITIONABLE' | 'NONEDITIONABLE'

private oracle_json_duality_replication_clause ::= ( 'ENABLE' | 'DISABLE' ) 'LOGICAL' 'REPLICATION'

private oracle_json_duality_definition_token ::= (
  oracle_dimension_reference |
  oracle_plsql_source_token |
  oracle_parenthesized_clause |
  'CHECK' |
  'DELETE' |
  'DUALITY' |
  'ETAG' |
  'FORCE' |
  'FROM' |
  'INSERT' |
  'JSON' |
  'KEY' |
  'LOGICAL' |
  'NOCHECK' |
  'NODELETE' |
  'NOINSERT' |
  'NOUPDATE' |
  'RELATIONAL' |
  'REPLICATION' |
  'SELECT' |
  'UNNEST' |
  'UPDATE' |
  'VALUE' |
  'VIEW' |
  'WITH'
)

alter_json_relational_duality_view_stmt ::= 'ALTER' 'JSON' [ 'RELATIONAL' ] 'DUALITY' 'VIEW' [ 'IF' 'EXISTS' ]
  oracle_schema_object_name ( 'ENABLE' | 'DISABLE' ) 'LOGICAL' 'REPLICATION' {
  pin = 5
}

create_iceberg_table_stmt ::= 'CREATE' 'ICEBERG' 'TABLE' oracle_schema_object_name
  [ LP {column_def} ( COMMA {column_def} ) * RP ]
  'WITHIN' 'CATALOG' oracle_object_name_part 'STORAGE' 'LOCATION' ( string | {string_literal} ) {
  pin = 3
}

drop_iceberg_table_stmt ::= 'DROP' 'ICEBERG' 'TABLE' oracle_schema_object_name 'WITHIN' 'CATALOG' oracle_object_name_part [ 'PURGE' ] {
  pin = 3
}

drop_context_stmt ::= 'DROP' 'CONTEXT' oracle_object_name_part {
  pin = 2
}

create_context_stmt ::= 'CREATE' [ 'OR' 'REPLACE' ] 'CONTEXT' oracle_object_name_part 'USING'
  oracle_schema_object_name [ 'SHARING' EQ ( 'METADATA' | 'NONE' ) ] oracle_context_clause * {
  pin = 3
}

drop_mle_env_stmt ::= 'DROP' 'MLE' 'ENV' [ 'IF' 'EXISTS' ] oracle_schema_object_name {
  pin = 3
}

drop_mle_module_stmt ::= 'DROP' 'MLE' 'MODULE' [ 'IF' 'EXISTS' ] oracle_schema_object_name {
  pin = 3
}

create_mle_env_stmt ::= 'CREATE' [ 'OR' 'REPLACE' ] [ 'PURE' ] 'MLE' 'ENV'
  [ 'IF' 'NOT' 'EXISTS' ] oracle_schema_object_name oracle_mle_env_create_clause * {
  pin = 4
}

create_mle_module_stmt ::= 'CREATE' [ 'OR' 'REPLACE' ] 'MLE' 'MODULE'
  [ 'IF' 'NOT' 'EXISTS' ] oracle_schema_object_name oracle_mle_module_create_clause + {
  pin = 4
}

alter_mle_env_stmt ::= 'ALTER' 'MLE' 'ENV' [ 'IF' 'EXISTS' ] oracle_schema_object_name oracle_mle_env_clause {
  pin = 3
}

alter_mle_module_stmt ::= 'ALTER' 'MLE' 'MODULE' [ 'IF' 'EXISTS' ] oracle_schema_object_name oracle_mle_module_clause {
  pin = 3
}

private oracle_mle_env_clause ::= (
  ( 'ADD' | 'ALTER' ) 'IMPORTS' LP oracle_mle_import ( COMMA oracle_mle_import ) * RP |
  'DROP' 'IMPORTS' LP oracle_mle_import_name ( COMMA oracle_mle_import_name ) * RP |
  'SET' 'LANGUAGE' 'OPTIONS' {string_literal} |
  'COMPILE'
)

private oracle_context_clause ::= (
  'INITIALIZED' ( 'EXTERNALLY' | 'GLOBALLY' ) |
  'ACCESSED' 'GLOBALLY'
)

private oracle_mle_env_create_clause ::= (
  'CLONE' oracle_schema_object_name |
  'IMPORTS' LP oracle_mle_import ( COMMA oracle_mle_import ) * RP |
  'LANGUAGE' 'OPTIONS' {string_literal}
)

private oracle_mle_import ::= oracle_mle_import_name 'MODULE' oracle_schema_object_name

private oracle_mle_import_name ::= {string_literal} | string | oracle_object_name_part

private oracle_mle_module_create_clause ::= (
  'LANGUAGE' 'JAVASCRIPT' |
  'VERSION' ( {string_literal} | string | oracle_object_name_part ) |
  'USING' oracle_mle_module_source_clause |
  'AS' oracle_mle_module_source_token +
)

private oracle_mle_module_source_clause ::= (
  ( 'CLOB' | 'BLOB' ) LP oracle_mle_module_source_boundary_token * RP |
  'BFILE' oracle_mle_module_source_boundary_token +
)

private oracle_mle_module_clause ::= oracle_mle_module_boundary_token +

private oracle_mle_module_boundary_token ::= (
  oracle_plsql_source_token |
  oracle_parenthesized_clause |
  'SET' |
  'METADATA' |
  'USING' |
  'CLOB' |
  'SELECT' |
  'JSON'
)

private oracle_mle_module_source_token ::= (
  oracle_plsql_source_token |
  oracle_parenthesized_clause |
  'CONST' |
  'EXPORT' |
  'FUNCTION' |
  'IMPORT' |
  'LET' |
  'VAR'
)

private oracle_mle_module_source_boundary_token ::= (
  oracle_dimension_reference |
  oracle_object_name_part |
  {string_literal} |
  string |
  DIGIT |
  {signed_number} |
  COMMA |
  DOT |
  EQ |
  'BFILE' |
  'BLOB' |
  'CLOB' |
  'DIRECTORY' |
  'FROM' |
  'SELECT'
)

drop_assertion_stmt ::= 'DROP' 'ASSERTION' [ 'IF' 'EXISTS' ] oracle_schema_object_name {
  pin = 2
}

create_assertion_stmt ::= 'CREATE' 'ASSERTION' [ 'IF' 'NOT' 'EXISTS' ] oracle_schema_object_name
  'CHECK' oracle_assertion_expression oracle_assertion_constraint_state * {
}

alter_assertion_stmt ::= 'ALTER' 'ASSERTION' [ 'IF' 'EXISTS' ] oracle_schema_object_name
  ( 'ENABLE' | 'DISABLE' | 'VALIDATE' | 'NOVALIDATE' ) + {
  pin = 2
}

drop_directive_stmt ::= 'DROP' 'DIRECTIVE' oracle_object_name_part {
  pin = 2
}

create_directive_stmt ::= 'CREATE' 'DIRECTIVE' oracle_object_name_part oracle_directive_action
  ( COMMA oracle_directive_action ) * oracle_directive_processing_clause oracle_directive_enable_option *
  'USING' oracle_directive_using_token + {
}

alter_directive_stmt ::= 'ALTER' 'DIRECTIVE' oracle_object_name_part ( 'ENABLE' | 'DISABLE' ) {
  pin = 2
}

drop_edition_stmt ::= 'DROP' 'EDITION' oracle_object_name_part [ 'IF' 'EXISTS' ] [ 'CASCADE' ] {
  pin = 2
}

create_edition_stmt ::= 'CREATE' 'EDITION' [ 'IF' 'NOT' 'EXISTS' ] oracle_object_name_part
  [ 'AS' 'CHILD' 'OF' oracle_object_name_part ] {
}

drop_flashback_archive_stmt ::= 'DROP' 'FLASHBACK' 'ARCHIVE' oracle_object_name_part {
  pin = 3
}

alter_flashback_archive_stmt ::= 'ALTER' 'FLASHBACK' 'ARCHIVE' oracle_object_name_part oracle_flashback_archive_clause {
  pin = 3
}

drop_inmemory_join_group_stmt ::= 'DROP' 'INMEMORY' 'JOIN' 'GROUP' [ 'IF' 'EXISTS' ] oracle_schema_object_name {
  pin = 4
}

create_inmemory_join_group_stmt ::= 'CREATE' 'INMEMORY' 'JOIN' 'GROUP' [ 'IF' 'NOT' 'EXISTS' ]
  oracle_schema_object_name LP oracle_join_group_column ( COMMA oracle_join_group_column ) * RP {
}

alter_inmemory_join_group_stmt ::= 'ALTER' 'INMEMORY' 'JOIN' 'GROUP' [ 'IF' 'EXISTS' ] oracle_schema_object_name
  ( 'ADD' | 'REMOVE' ) LP oracle_join_group_column RP {
  pin = 4
}

create_java_stmt ::= 'CREATE' [ 'OR' 'REPLACE' ] [ 'AND' ( 'RESOLVE' | 'COMPILE' ) ] [ 'NOFORCE' ]
  'JAVA' ( 'SOURCE' | 'CLASS' | 'RESOURCE' ) [ 'IF' 'NOT' 'EXISTS' ] oracle_java_create_clause + {
}

create_logical_partition_tracking_stmt ::= 'CREATE' 'LOGICAL' 'PARTITION' 'TRACKING' 'ON'
  oracle_schema_object_name 'PARTITION' 'BY' 'RANGE' LP oracle_object_name_part RP
  [ 'INTERVAL' oracle_logical_partition_boundary ]
  LP oracle_logical_partition_definition ( COMMA oracle_logical_partition_definition ) * RP {
}

drop_lockdown_profile_stmt ::= 'DROP' 'LOCKDOWN' 'PROFILE' oracle_object_name_part {
  pin = 3
}

create_lockdown_profile_stmt ::= 'CREATE' 'LOCKDOWN' 'PROFILE' oracle_object_name_part
  [ ( 'INCLUDING' | 'FROM' ) oracle_object_name_part ] {
}

alter_lockdown_profile_stmt ::= 'ALTER' 'LOCKDOWN' 'PROFILE' oracle_object_name_part oracle_lockdown_profile_clause {
  pin = 3
}

drop_pmem_filestore_stmt ::= 'DROP' 'PMEM' 'FILESTORE' oracle_object_name_part [ oracle_pmem_filestore_contents_clause ] {
  pin = 3
}

create_pmem_filestore_stmt ::= 'CREATE' 'PMEM' 'FILESTORE' oracle_object_name_part
  oracle_pmem_filestore_boundary_token + {
}

alter_pmem_filestore_stmt ::= 'ALTER' 'PMEM' 'FILESTORE' oracle_object_name_part oracle_pmem_filestore_clause + {
  pin = 3
}

private oracle_flashback_archive_clause ::= (
  'SET' 'DEFAULT' |
  ( 'ADD' | 'MODIFY' | 'REMOVE' ) 'TABLESPACE' oracle_object_name_part [ oracle_flashback_archive_quota ] |
  'MODIFY' 'RETENTION' oracle_flashback_archive_retention |
  'PURGE' ( 'ALL' | 'BEFORE' ( 'SCN' | 'TIMESTAMP' ) oracle_flashback_archive_boundary_token + ) |
  [ 'NO' ] 'OPTIMIZE' 'DATA'
)

private oracle_flashback_archive_quota ::= 'QUOTA' ( oracle_size_clause | 'UNLIMITED' )

private oracle_flashback_archive_retention ::= {signed_number} ( 'DAY' | 'MONTH' | 'YEAR' )

private oracle_flashback_archive_boundary_token ::= oracle_plsql_source_token | 'SYSTIMESTAMP'

private oracle_join_group_column ::= oracle_schema_object_name LP oracle_object_name_part RP

private oracle_assertion_expression ::= LP oracle_assertion_token * RP

private oracle_assertion_token ::= (
  oracle_assertion_expression |
  oracle_dimension_reference |
  oracle_object_name_part |
  {string_literal} |
  string |
  DIGIT |
  {signed_number} |
  COMMA |
  DOT |
  EQ |
  'ALL' |
  'AND' |
  'BETWEEN' |
  'EXISTS' |
  'FROM' |
  'IN' |
  'IS' |
  'NOT' |
  'NULL' |
  'OR' |
  'SATISFY' |
  'SELECT' |
  'WHERE'
)

private oracle_assertion_constraint_state ::= (
  [ 'NOT' ] 'DEFERRABLE' |
  'INITIALLY' ( 'IMMEDIATE' | 'DEFERRED' ) |
  'ENABLE' |
  'DISABLE' |
  'VALIDATE' |
  'NOVALIDATE'
)

private oracle_directive_action ::= 'UPDATE' | 'INSERT' | 'SELECT'

private oracle_directive_processing_clause ::= (
  ( 'BEFORE' | 'AFTER' ) 'OBJECT' |
  'ON' 'COMMIT'
)

private oracle_directive_enable_option ::= 'ENABLE' | 'DISABLE' | 'VALIDATE' | 'NOVALIDATE'

private oracle_directive_using_token ::= (
  oracle_assertion_token |
  oracle_parenthesized_clause |
  'BEGIN' |
  'END' |
  'EXPRESSION' |
  'FUNCTION' |
  'JSON' |
  'SQL'
)

private oracle_java_create_clause ::= (
  'NAMED' ( string | {string_literal} ) |
  'SCHEMA' oracle_object_name_part |
  'SHARING' EQ ( 'METADATA' | 'NONE' ) |
  'AUTHID' ( 'CURRENT_USER' | 'DEFINER' ) |
  'RESOLVER' oracle_parenthesized_clause |
  'USING' oracle_java_using_clause |
  'AS' oracle_java_source_token +
)

private oracle_java_using_clause ::= (
  'BFILE' oracle_mle_module_source_boundary_token + |
  ( 'CLOB' | 'BLOB' ) LP oracle_mle_module_source_boundary_token * RP
)

private oracle_java_source_token ::= (
  oracle_mle_module_source_token |
  oracle_parenthesized_clause |
  'CLASS' |
  'PUBLIC' |
  'STATIC' |
  'VOID'
)

private oracle_logical_partition_definition ::= 'PARTITION' [ oracle_object_name_part ] 'VALUES' 'LESS' 'THAN'
  oracle_logical_partition_boundary

private oracle_logical_partition_boundary ::= LP oracle_logical_partition_token * RP

private oracle_logical_partition_token ::= (
  oracle_object_name_part |
  {string_literal} |
  string |
  DIGIT |
  {signed_number} |
  COMMA |
  DOT |
  'MAXVALUE'
)

private oracle_lockdown_profile_clause ::= ( 'ENABLE' | 'DISABLE' ) (
  'FEATURE' 'ALL' 'EXCEPT' EQ oracle_parenthesized_clause |
  'FEATURE' oracle_lockdown_target |
  'OPTION' oracle_lockdown_target |
  'STATEMENT' oracle_lockdown_assignment [ 'CLAUSE' oracle_lockdown_assignment ] [ 'OPTION' oracle_lockdown_assignment ] [ 'VALUE' oracle_lockdown_assignment ] |
  oracle_lockdown_boundary_token +
) [ 'USERS' EQ ( 'ALL' | 'COMMON' | 'LOCAL' ) ]

private oracle_lockdown_target ::= (
  'ALL' [ 'EXCEPT' EQ oracle_parenthesized_clause ] |
  EQ oracle_parenthesized_clause
)

private oracle_lockdown_assignment ::= EQ oracle_parenthesized_clause

private oracle_lockdown_boundary_token ::= (
  oracle_plsql_source_token |
  'ALL' |
  'CLAUSE' |
  'EXCEPT' |
  'FEATURE' |
  'MAXVALUE' |
  'MINVALUE' |
  'OPTION' |
  'STATEMENT' |
  'USERS' |
  'VALUE'
)

private oracle_pmem_filestore_contents_clause ::= (
  'FORCE' 'INCLUDING' 'CONTENTS' |
  ( 'INCLUDING' | 'EXCLUDING' ) 'CONTENTS'
)

drop_profile_stmt ::= 'DROP' 'PROFILE' oracle_object_name_part [ 'CASCADE' ] {
  pin = 2
}

alter_profile_stmt ::= 'ALTER' 'PROFILE' oracle_object_name_part 'LIMIT' oracle_profile_limit + [ oracle_container_clause ] {
  pin = 2
}

alter_resource_cost_stmt ::= 'ALTER' 'RESOURCE' 'COST' oracle_resource_cost + {
  pin = 3
}

drop_rollback_segment_stmt ::= 'DROP' 'ROLLBACK' 'SEGMENT' oracle_object_name_part {
  pin = 3
}

create_rollback_segment_stmt ::= 'CREATE' [ 'PUBLIC' ] 'ROLLBACK' 'SEGMENT' oracle_rollback_segment_name
  oracle_rollback_segment_create_token * {
}

alter_rollback_segment_stmt ::= 'ALTER' 'ROLLBACK' 'SEGMENT' oracle_object_name_part oracle_rollback_segment_clause {
  pin = 3
}

private oracle_rollback_segment_name ::= {identifier} | string

private oracle_rollback_segment_create_token ::= (
  oracle_rollback_segment_storage_token |
  oracle_rollback_segment_storage_clause |
  'PUBLIC' |
  'STORAGE' |
  'TABLESPACE'
)

private oracle_pmem_filestore_clause ::= (
  'ADD' oracle_pmem_filestore_boundary_token + |
  'DROP' oracle_pmem_filestore_boundary_token + |
  'RESIZE' oracle_pmem_filestore_boundary_token + |
  oracle_pmem_filestore_boundary_token
)

private oracle_pmem_filestore_boundary_token ::= (
  oracle_plsql_source_token |
  oracle_size_clause |
  'AUTOEXTEND' |
  'BACKINGFILE' |
  'BLOCKSIZE' |
  'MAXSIZE' |
  'MOUNTPOINT' |
  'NEXT' |
  'ON' |
  'SIZE'
)

private oracle_profile_limit ::= 'PRIVATE_SGA' oracle_private_sga_limit_value | oracle_profile_parameter oracle_profile_limit_value

private oracle_profile_parameter ::= (
  'COMPOSITE_LIMIT' |
  'SESSIONS_PER_USER' |
  'CPU_PER_SESSION' |
  'CPU_PER_CALL' |
  'LOGICAL_READS_PER_SESSION' |
  'LOGICAL_READS_PER_CALL' |
  'IDLE_TIME' |
  'CONNECT_TIME' |
  'FAILED_LOGIN_ATTEMPTS' |
  'PASSWORD_LIFE_TIME' |
  'PASSWORD_REUSE_TIME' |
  'PASSWORD_REUSE_MAX' |
  'PASSWORD_LOCK_TIME' |
  'PASSWORD_GRACE_TIME' |
  'PASSWORD_VERIFY_FUNCTION' |
  'PASSWORD_ROLLOVER_TIME' |
  'INACTIVE_ACCOUNT_TIME'
)

private oracle_profile_limit_value ::= (
  {signed_number} |
  oracle_size_clause |
  oracle_schema_object_name |
  'DEFAULT' |
  'UNLIMITED' |
  'NULL'
)

private oracle_private_sga_limit_value ::= (
  {signed_number} oracle_size_unit |
  oracle_size_clause |
  'DEFAULT' |
  'UNLIMITED'
)

private oracle_resource_cost ::= oracle_resource_cost_parameter {signed_number}

private oracle_resource_cost_parameter ::= (
  'CPU_PER_SESSION' |
  'CONNECT_TIME' |
  'LOGICAL_READS_PER_SESSION' |
  'PRIVATE_SGA'
)

private oracle_rollback_segment_clause ::= (
  'ONLINE' |
  'OFFLINE' |
  'SHRINK' [ 'TO' oracle_size_clause ] |
  oracle_rollback_segment_storage_keyword oracle_rollback_segment_storage_clause
)

private oracle_rollback_segment_storage_clause ::= LP oracle_rollback_segment_storage_token * RP

private oracle_rollback_segment_storage_keyword ::= 'STORAGE' | <<identifierExt identifier_real>>

private oracle_rollback_segment_storage_token ::= (
  oracle_plsql_source_token |
  oracle_size_clause |
  'BUFFER_POOL' |
  'CACHE' |
  'DEFAULT' |
  'FLASH_CACHE' |
  'FREELISTS' |
  'GROUPS' |
  'INITIAL' |
  'KEEP' |
  'MAXEXTENTS' |
  'MINEXTENTS' |
  'NEXT' |
  'NONE' |
  'OPTIMAL' |
  'PCTINCREASE' |
  'RECYCLE'
)

drop_database_stmt ::= 'DROP' 'DATABASE' {
  pin = 2
}

create_database_stmt ::= 'CREATE' 'DATABASE' [ oracle_object_name_part ] oracle_database_boundary_token * {
}

alter_database_dictionary_stmt ::= 'ALTER' 'DATABASE' 'DICTIONARY' oracle_database_dictionary_clause {
  pin = 3
}

alter_database_stmt ::= 'ALTER' 'DATABASE' oracle_database_clause + {
  pin = 2
}

drop_pluggable_database_stmt ::= 'DROP' 'PLUGGABLE' 'DATABASE' oracle_object_name_part [ 'FORCE' ]
  [ ( 'KEEP' | 'INCLUDING' ) 'DATAFILES' ] {
  pin = 3
}

create_pluggable_database_stmt ::= 'CREATE' 'PLUGGABLE' 'DATABASE' oracle_object_name_part
  oracle_database_boundary_token * {
}

alter_pluggable_database_stmt ::= 'ALTER' 'PLUGGABLE' 'DATABASE' [ oracle_pluggable_database_target ] oracle_pluggable_database_clause + {
  pin = 3
}

create_controlfile_stmt ::= 'CREATE' 'CONTROLFILE' [ 'REUSE' ] [ 'SET' ] 'DATABASE' oracle_object_name_part
  oracle_database_boundary_token + {
}

create_tablespace_set_stmt ::= 'CREATE' 'TABLESPACE' 'SET' oracle_object_name_part oracle_storage_admin_boundary_token * {
  pin = 3
}

drop_tablespace_set_stmt ::= 'DROP' 'TABLESPACE' 'SET' oracle_object_name_part [ oracle_quota_clause ]
  [ oracle_including_contents_clause ] {
  pin = 3
}

private oracle_database_dictionary_clause ::= (
  'ENCRYPT' 'CREDENTIALS' |
  'REKEY' 'CREDENTIALS' |
  'DELETE' 'CREDENTIALS' 'KEY'
)

private oracle_database_clause ::= (
  ( 'MOUNT' [ 'STANDBY' | 'CLONE' ] [ 'DATABASE' ] ) |
  ( 'OPEN' oracle_database_boundary_token * ) |
  ( 'CLOSE' oracle_database_boundary_token * ) |
  ( 'BACKUP' 'CONTROLFILE' oracle_database_boundary_token + ) |
  ( 'RENAME' 'GLOBAL_NAME' 'TO' oracle_database_boundary_token + ) |
  ( 'DEFAULT' oracle_database_boundary_token + ) |
  ( 'SET' oracle_database_boundary_token + ) |
  ( 'DATAFILE' oracle_database_boundary_token + ) |
  ( 'TEMPFILE' oracle_database_boundary_token + ) |
  ( 'ADD' oracle_database_boundary_token + ) |
  ( 'DROP' oracle_database_boundary_token + ) |
  ( 'ENABLE' oracle_database_boundary_token + ) |
  ( 'DISABLE' oracle_database_boundary_token + ) |
  ( 'ARCHIVELOG' | 'NOARCHIVELOG' ) |
  ( 'FLASHBACK' ( 'ON' | 'OFF' ) ) |
  ( 'RECOVER' oracle_database_boundary_token * ) |
  oracle_database_boundary_token
)

private oracle_pluggable_database_target ::= (
  'ALL' [ 'EXCEPT' oracle_object_name_part ( COMMA oracle_object_name_part ) * ] |
  oracle_schema_object_name ( COMMA oracle_schema_object_name ) *
)

private oracle_pluggable_database_clause ::= (
  ( 'OPEN' oracle_database_boundary_token * ) |
  ( 'CLOSE' oracle_database_boundary_token * ) |
  ( 'SAVE' 'STATE' [ oracle_database_boundary_token * ] ) |
  ( 'DISCARD' 'STATE' [ oracle_database_boundary_token * ] ) |
  ( 'UNPLUG' 'INTO' oracle_database_boundary_token + ) |
  ( 'RELOCATE' oracle_database_boundary_token + ) |
  ( 'REFRESH' oracle_database_boundary_token * ) |
  ( 'DEFAULT' oracle_database_boundary_token + ) |
  ( 'SET' oracle_database_boundary_token + ) |
  ( 'RENAME' 'GLOBAL_NAME' 'TO' oracle_database_boundary_token + ) |
  ( 'STORAGE' oracle_database_boundary_token + ) |
  ( 'DATAFILE' oracle_database_boundary_token + ) |
  ( 'TEMPFILE' oracle_database_boundary_token + ) |
  ( 'ADD' oracle_database_boundary_token + ) |
  ( 'DROP' oracle_database_boundary_token + ) |
  oracle_database_boundary_token
)

private oracle_database_boundary_token ::= (
  oracle_plsql_source_token |
  oracle_size_clause |
  oracle_parenthesized_clause |
  'ARCHIVELOG' |
  'AUTOEXTEND' |
  'BACKUP' |
  'BIGFILE' |
  'BLOCK' |
  'BY' |
  'CACHE' |
  'CHARACTER' |
  'CHANGE' |
  'CLOSE' |
  'CONTROLFILE' |
  'DATABASE' |
  'DATAFILE' |
  'DEFAULT' |
  'DISCARD' |
  'ENABLE' |
  'FLASHBACK' |
  'FOR' |
  'FORCE' |
  'FROM' |
  'GLOBAL_NAME' |
  'GROUP' |
  'IDENTIFIED' |
  'IMMEDIATE' |
  'KEEP' |
  'LOCAL' |
  'LOGFILE' |
  'MAXDATAFILES' |
  'MAXINSTANCES' |
  'MAXLOGFILES' |
  'MAXLOGHISTORY' |
  'MAXLOGMEMBERS' |
  'MAXSIZE' |
  'MOUNT' |
  'NATIONAL' |
  'NEXT' |
  'NOARCHIVELOG' |
  'NOREUSE' |
  'NORESETLOGS' |
  'OFF' |
  'ON' |
  'OPEN' |
  'PLUGGABLE' |
  'READ' |
  'RECOVER' |
  'RELOCATION' |
  'RENAME' |
  'REUSE' |
  'RESETLOGS' |
  'RESTRICTED' |
  'SAVE' |
  'SET' |
  'SMALLFILE' |
  'STANDBY' |
  'STATE' |
  'STORAGE' |
  'SUPPLEMENTAL' |
  'SWITCHOVER' |
  'TABLESPACE' |
  'TEMPFILE' |
  'TEMPORARY' |
  'TRACKING' |
  'TO' |
  'UNDO' |
  'UNPLUG' |
  'UPGRADE' |
  'USER' |
  'WRITE'
)

drop_tablespace_stmt ::= 'DROP' 'TABLESPACE' [ 'IF' 'EXISTS' ] oracle_object_name_part [ oracle_quota_clause ]
  [ oracle_including_contents_clause ] {
  pin = 2
}

create_tablespace_stmt ::= 'CREATE' [ 'BIGFILE' | 'SMALLFILE' | 'UNDO' | 'TEMPORARY' ] 'TABLESPACE'
  [ 'IF' 'NOT' 'EXISTS' ] oracle_object_name_part oracle_storage_admin_boundary_token * {
}

alter_tablespace_set_stmt ::= 'ALTER' 'TABLESPACE' 'SET' oracle_object_name_part oracle_storage_admin_clause + {
  pin = 3
}

alter_tablespace_stmt ::= 'ALTER' 'TABLESPACE' [ 'IF' 'EXISTS' ] oracle_object_name_part oracle_storage_admin_clause + {
  pin = 2
}

private oracle_quota_clause ::= ( 'DROP' | 'KEEP' ) 'QUOTA'

private oracle_including_contents_clause ::= 'INCLUDING' 'CONTENTS'
  [ ( 'AND' | 'KEEP' ) 'DATAFILES' ] [ 'CASCADE' 'CONSTRAINTS' ]

drop_diskgroup_stmt ::= 'DROP' 'DISKGROUP' oracle_object_name_part [ oracle_diskgroup_contents_clause ] {
  pin = 2
}

create_diskgroup_stmt ::= 'CREATE' 'DISKGROUP' oracle_object_name_part oracle_storage_admin_boundary_token + {
}

alter_diskgroup_stmt ::= 'ALTER' 'DISKGROUP' oracle_object_name_part oracle_storage_admin_clause + {
  pin = 2
}

create_spfile_stmt ::= 'CREATE' 'SPFILE' [ EQ oracle_parameter_file_value ] 'FROM'
  ( 'PFILE' | 'MEMORY' ) [ EQ oracle_parameter_file_value ] {
}

create_pfile_stmt ::= 'CREATE' 'PFILE' [ EQ oracle_parameter_file_value ] 'FROM'
  ( 'SPFILE' | 'MEMORY' ) [ EQ oracle_parameter_file_value ] {
}

create_true_cache_stmt ::= 'CREATE' 'TRUE' 'CACHE' oracle_database_boundary_token + {
}

private oracle_diskgroup_contents_clause ::= (
  'FORCE' 'INCLUDING' 'CONTENTS' |
  ( 'INCLUDING' | 'EXCLUDING' ) 'CONTENTS'
)

private oracle_parameter_file_value ::= oracle_schema_object_name | {string_literal} | string

private oracle_storage_admin_clause ::= (
  ( 'ADD' oracle_storage_admin_boundary_token + ) |
  ( 'DROP' oracle_storage_admin_boundary_token + ) |
  ( 'RENAME' oracle_storage_admin_boundary_token + ) |
  ( 'RESIZE' oracle_storage_admin_boundary_token + ) |
  ( 'ONLINE' [ oracle_storage_admin_boundary_token * ] ) |
  ( 'OFFLINE' [ oracle_storage_admin_boundary_token * ] ) |
  ( 'READ' ( 'ONLY' | 'WRITE' ) ) |
  ( 'BEGIN' 'BACKUP' ) |
  ( 'END' 'BACKUP' ) |
  ( 'COALESCE' ) |
  ( 'SHRINK' oracle_storage_admin_boundary_token * ) |
  ( 'LOGGING' | 'NOLOGGING' ) |
  ( [ 'NO' ] 'FORCE' 'LOGGING' ) |
  ( 'FLASHBACK' ( 'ON' | 'OFF' ) ) |
  ( 'RETENTION' ( 'GUARANTEE' | 'NOGUARANTEE' ) ) |
  ( 'MOUNT' oracle_storage_admin_boundary_token * ) |
  ( 'DISMOUNT' oracle_storage_admin_boundary_token * ) |
  ( 'REBALANCE' oracle_storage_admin_boundary_token * ) |
  ( 'CHECK' oracle_storage_admin_boundary_token * ) |
  ( 'REPAIR' oracle_storage_admin_boundary_token * ) |
  ( 'SCRUB' oracle_storage_admin_boundary_token * ) |
  ( 'SET' oracle_storage_admin_boundary_token + ) |
  oracle_storage_admin_boundary_token
)

private oracle_storage_admin_boundary_token ::= (
  oracle_database_boundary_token |
  'ATTRIBUTE' |
  'ATTRIBUTES' |
  'ALL' |
  'BACKUP' |
  'BLOCKSIZE' |
  'COALESCE' |
  'COMPATIBLE' |
  'CONTENTS' |
  'DATAFILE' |
  'DISK' |
  'DISKS' |
  'DISMOUNT' |
  'EXTENT' |
  'ENCRYPTION' |
  'FILE' |
  'FAILGROUP' |
  'FORCE' |
  'GROUP' |
  'HIGH' |
  'IN' |
  'INITIAL' |
  'KEEP' |
  'LIMIT' |
  'LOCAL' |
  'MANAGEMENT' |
  'NAME' |
  'NOFORCE' |
  'NORMAL' |
  'ONLINE' |
  'POWER' |
  'QUOTA' |
  'QUORUM' |
  'REBALANCE' |
  'REPAIR' |
  'RESTRICTED' |
  'SCRUB' |
  'SEGMENT' |
  'SHARDSPACE' |
  'SIZE' |
  'SPACE' |
  'TEMPLATE' |
  'TO' |
  'USING'
)

drop_restore_point_stmt ::= 'DROP' 'RESTORE' 'POINT' oracle_object_name_part [ 'FOR' 'PLUGGABLE' 'DATABASE' oracle_object_name_part ] {
  pin = 3
}

create_restore_point_stmt ::= 'CREATE' [ 'CLEAN' ] 'RESTORE' 'POINT' oracle_object_name_part
  [ 'FOR' 'PLUGGABLE' 'DATABASE' oracle_object_name_part ]
  [ 'AS' 'OF' ( 'SCN' | 'TIMESTAMP' ) oracle_database_boundary_token + ]
  [ 'PRESERVE' | 'GUARANTEE' 'FLASHBACK' 'DATABASE' ] {
}

commit_stmt ::= 'COMMIT' [ 'WORK' ] [ oracle_commit_option ] {
  extends = "com.alecstrong.sql.psi.core.psi.impl.SqlCommitStmtImpl"
  implements = "com.alecstrong.sql.psi.core.psi.SqlCommitStmt"
  override = true
  pin = 1
}

private oracle_commit_option ::= (
  'COMMENT' {string_literal} |
  'WRITE' [ 'WAIT' | 'NOWAIT' ] [ 'IMMEDIATE' | 'BATCH' ] |
  'FORCE' {string_literal} [ COMMA {signed_number} ]
)

rollback_stmt ::= 'ROLLBACK' [ 'WORK' ] [ 'TO' [ 'SAVEPOINT' ] {savepoint_name} | 'FORCE' {string_literal} ] {
  extends = "com.alecstrong.sql.psi.core.psi.impl.SqlRollbackStmtImpl"
  implements = "com.alecstrong.sql.psi.core.psi.SqlRollbackStmt"
  override = true
  pin = 1
}

savepoint_stmt ::= 'SAVEPOINT' {savepoint_name} {
  extends = "com.alecstrong.sql.psi.core.psi.impl.SqlSavepointStmtImpl"
  implements = "com.alecstrong.sql.psi.core.psi.SqlSavepointStmt"
  override = true
  pin = 1
}

set_transaction_stmt ::= 'SET' 'TRANSACTION' (
  oracle_transaction_mode [ 'NAME' {string_literal} ] |
  'NAME' {string_literal}
) {
  pin = 2
}

private oracle_transaction_mode ::= (
  'READ' ( 'ONLY' | 'WRITE' ) |
  'ISOLATION' 'LEVEL' ( 'SERIALIZABLE' | 'READ' 'COMMITTED' ) |
  'USE' 'ROLLBACK' 'SEGMENT' oracle_object_name_part
)

set_constraints_stmt ::= 'SET' ( 'CONSTRAINT' | 'CONSTRAINTS' )
  ( 'ALL' | oracle_schema_object_name ( COMMA oracle_schema_object_name ) * ) ( 'IMMEDIATE' | 'DEFERRED' ) {
  pin = 2
}

set_role_stmt ::= 'SET' 'ROLE' (
  oracle_role_setting ( COMMA oracle_role_setting ) * |
  'ALL' [ 'EXCEPT' oracle_object_name_part ( COMMA oracle_object_name_part ) * ] |
  'NONE'
) {
  pin = 2
}

private oracle_role_setting ::= oracle_object_name_part [ 'IDENTIFIED' 'BY' oracle_role_password ]

private oracle_role_password ::= oracle_object_name_part

set_use_data_grants_only_stmt ::= 'SET' 'USE' 'DATA' 'GRANTS' 'ONLY' 'ON' oracle_schema_object_name [ 'ENABLED' | 'DISABLED' ] {
  pin = 5
}

alter_session_stmt ::= 'ALTER' 'SESSION' oracle_alter_session_clause {
  pin = 2
}

private oracle_alter_session_clause ::= (
  'ADVISE' ( 'COMMIT' | 'ROLLBACK' | 'NOTHING' ) |
  'CLOSE' 'DATABASE' 'LINK' oracle_object_name_part |
  ( 'ENABLE' | 'DISABLE' ) 'COMMIT' 'IN' 'PROCEDURE' |
  ( 'ENABLE' | 'DISABLE' ) 'GUARD' |
  ( 'ENABLE' | 'DISABLE' | 'FORCE' ) 'PARALLEL' ( 'DML' | 'DDL' | 'QUERY' ) [ 'PARALLEL' {signed_number} ] |
  'ENABLE' 'RESUMABLE' [ 'TIMEOUT' {signed_number} ] [ 'NAME' {string_literal} ] |
  'DISABLE' 'RESUMABLE' |
  ( 'ENABLE' | 'DISABLE' ) 'SHARD' 'DDL' |
  'SYNC' 'WITH' 'PRIMARY' |
  oracle_alter_session_set_clause
)

private oracle_alter_session_set_clause ::= 'SET' (
  'EDITION' EQ oracle_object_name_part |
  'CONTAINER' EQ oracle_object_name_part [ 'SERVICE' EQ oracle_object_name_part ] |
  'ROW' 'ARCHIVAL' 'VISIBILITY' EQ ( 'ACTIVE' | 'ALL' ) |
  'DEFAULT' 'COLLATION' EQ ( oracle_object_name_part | 'NONE' ) |
  oracle_parameter_assignment +
)

alter_system_stmt ::= 'ALTER' 'SYSTEM' oracle_alter_system_clause {
  pin = 2
}

private oracle_alter_system_clause ::= (
  oracle_archive_log_clause |
  'CHECKPOINT' [ 'GLOBAL' | 'LOCAL' ] |
  'CHECK' 'DATAFILES' [ 'GLOBAL' | 'LOCAL' ] |
  ( 'ENABLE' | 'DISABLE' ) 'DISTRIBUTED' 'RECOVERY' |
  'FLUSH' oracle_flush_target |
  oracle_end_session_clause |
  'SWITCH' 'LOGFILE' |
  ( 'SUSPEND' | 'RESUME' ) |
  ( 'QUIESCE' 'RESTRICTED' | 'UNQUIESCE' ) |
  'START' 'ROLLING' ( 'MIGRATION' | 'PATCH' ) |
  'STOP' 'ROLLING' ( 'MIGRATION' | 'PATCH' ) |
  ( 'ENABLE' | 'DISABLE' ) 'RESTRICTED' 'SESSION' |
  'SHUTDOWN' 'DISPATCHER' oracle_object_name_part |
  'REGISTER' |
  'SET' oracle_alter_system_set_clause + |
  'RESET' oracle_alter_system_reset_clause + |
  'RELOCATE' 'CLIENT' {string_literal} |
  oracle_cancel_sql_clause
)

private oracle_archive_log_clause ::= 'ARCHIVE' 'LOG' (
  'ALL' |
  'CHANGE' {signed_number} |
  'CURRENT' |
  'GROUP' {signed_number} |
  'LOGFILE' {string_literal} [ 'TO' {string_literal} ] |
  'NEXT' |
  'SEQUENCE' {signed_number}
)

private oracle_flush_target ::= (
  'BUFFER_CACHE' |
  'FLASH_CACHE' |
  'GLOBAL' 'CONTEXT' |
  'REDO' |
  'SHARED_POOL'
)

private oracle_end_session_clause ::= (
  'DISCONNECT' 'SESSION' {string_literal} [ 'POST_TRANSACTION' ] |
  'KILL' 'SESSION' {string_literal}
) [ 'IMMEDIATE' | 'FORCE' | 'NOREPLAY' ] [ 'TIMEOUT' {signed_number} ]

private oracle_cancel_sql_clause ::= 'CANCEL' 'SQL' {string_literal}

private oracle_alter_system_set_clause ::= (
  oracle_parameter_assignment |
  'USE_STORED_OUTLINES' EQ ( 'TRUE' | 'FALSE' | oracle_object_name_part ) |
  'GLOBAL_TOPIC_ENABLED' EQ ( 'TRUE' | 'FALSE' )
)

private oracle_alter_system_reset_clause ::= oracle_object_name_part oracle_parameter_scope_clause *

private oracle_parameter_assignment ::= oracle_object_name_part EQ oracle_parameter_value ( COMMA oracle_parameter_value ) *
  [ 'COMMENT' EQ {string_literal} ] [ 'DEFERRED' ] [ oracle_container_clause ] oracle_parameter_scope_clause *

private oracle_parameter_scope_clause ::= (
  'SCOPE' EQ ( 'MEMORY' | 'SPFILE' | 'BOTH' ) |
  'SID' EQ ( {string_literal} | string )
)

private oracle_parameter_value ::= {string_literal} | {signed_number} | oracle_object_name_part | 'TRUE' | 'FALSE' | 'LOCAL' | 'DBTIMEZONE'

administer_key_management_stmt ::= 'ADMINISTER' 'KEY' 'MANAGEMENT' (
  oracle_administer_key_management_set_clause |
  oracle_keystore_management_clause |
  oracle_key_management_clause |
  oracle_secret_management_clause |
  oracle_zero_downtime_software_patching_clause
) {
  pin = 3
}

private oracle_keystore_management_clause ::= (
  'CREATE' [ 'LOCAL' ] [ 'AUTO_LOGIN' ] 'KEYSTORE' [ oracle_key_management_value ] [ 'FROM' 'KEYSTORE' oracle_key_management_value ] oracle_identified_by |
  'BACKUP' 'KEYSTORE' [ 'USING' oracle_key_management_value ] [ oracle_identified_by ] [ 'TO' oracle_key_management_value ] |
  'ALTER' 'KEYSTORE' 'PASSWORD' oracle_identified_by 'SET' oracle_key_management_password oracle_with_backup_clause |
  'MERGE' 'KEYSTORE' oracle_key_management_value 'AND' 'KEYSTORE' oracle_key_management_value oracle_identified_by
    'INTO' 'NEW' 'KEYSTORE' oracle_key_management_value oracle_identified_by |
  'MERGE' 'KEYSTORE' oracle_key_management_value 'INTO' 'EXISTING' 'KEYSTORE' oracle_key_management_value oracle_identified_by
    [ oracle_with_backup_clause ] |
  'ISOLATE' 'KEYSTORE' oracle_identified_by 'FROM' 'ROOT' 'KEYSTORE' [ 'FORCE' 'KEYSTORE' ] oracle_identified_by oracle_with_backup_clause |
  'UNITE' 'KEYSTORE' oracle_identified_by 'WITH' 'ROOT' 'KEYSTORE' [ 'FORCE' 'KEYSTORE' ] oracle_identified_by oracle_with_backup_clause
)

private oracle_administer_key_management_set_clause ::= 'SET' (
  'KEYSTORE' ( 'OPEN' | 'CLOSE' ) [ oracle_identified_by ] [ oracle_container_clause ] |
  [ 'ENCRYPTION' ] 'KEY' [ oracle_key_identifier_value ] [ 'USING' 'TAG' oracle_key_management_value ]
    [ oracle_using_algorithm_clause ] [ 'FORCE' 'KEYSTORE' ] oracle_identified_by
    [ ( 'MIGRATE' | 'REVERSE' 'MIGRATE' ) 'USING' oracle_key_management_password ] [ oracle_with_backup_clause ] [ oracle_container_clause ] |
  'TAG' oracle_key_management_value 'FOR' oracle_key_management_value [ 'FORCE' 'KEYSTORE' ] oracle_identified_by [ oracle_with_backup_clause ]
)

private oracle_key_management_clause ::= (
  'CREATE' 'KEY' [ 'USING' 'TAG' oracle_key_management_value ] oracle_identified_by [ oracle_with_backup_clause ] [ oracle_container_clause ] |
  'USE' 'KEY' oracle_key_management_value oracle_identified_by [ oracle_with_backup_clause ] [ oracle_container_clause ] |
  'EXPORT' 'KEYS' [ 'WITH' 'SECRET' oracle_key_management_value ] 'TO' oracle_key_management_value oracle_identified_by
    [ oracle_with_identifier_clause ] [ oracle_container_clause ] |
  'IMPORT' 'KEYS' [ 'WITH' 'SECRET' oracle_key_management_value ] 'FROM' oracle_key_management_value oracle_identified_by
    [ oracle_with_backup_clause ] [ oracle_container_clause ] |
  ( 'MOVE' | 'UPLOAD' | 'DOWNLOAD' ) 'KEYS' [ 'WITH' 'IDENTIFIER' oracle_identifier_list ] [ oracle_identified_by ] [ oracle_container_clause ]
)

private oracle_secret_management_clause ::= (
  ( 'ADD' | 'UPDATE' ) 'SECRET' oracle_key_management_value 'FOR' 'CLIENT' oracle_key_management_value
    [ 'USING' 'TAG' oracle_key_management_value ] oracle_identified_by [ oracle_with_backup_clause ] |
  'DELETE' 'SECRET' 'FOR' 'CLIENT' oracle_key_management_value oracle_identified_by [ oracle_with_backup_clause ] |
  ( 'ADD' | 'UPDATE' ) 'SECRET' 'SEPS' oracle_key_management_value 'FOR' 'CLIENT' oracle_key_management_value
    [ 'USING' 'TAG' oracle_key_management_value ] oracle_identified_by [ oracle_with_backup_clause ] |
  'DELETE' 'SECRET' 'SEPS' 'FOR' 'CLIENT' oracle_key_management_value oracle_identified_by [ oracle_with_backup_clause ]
)

private oracle_zero_downtime_software_patching_clause ::= 'SWITCHOVER' [ 'TO' ] 'LIBRARY' oracle_key_management_value 'FOR' 'ALL' 'CONTAINERS'

private oracle_identified_by ::= 'IDENTIFIED' 'BY' ( 'EXTERNAL' 'STORE' | oracle_key_management_password )

private oracle_with_backup_clause ::= 'WITH' 'BACKUP' [ 'USING' oracle_key_management_value ]

private oracle_using_algorithm_clause ::= 'USING' 'ALGORITHM' oracle_key_management_value

private oracle_with_identifier_clause ::= 'WITH' 'IDENTIFIER' ( 'IN' oracle_identifier_list | oracle_key_management_value )

private oracle_identifier_list ::= oracle_key_management_value ( COMMA oracle_key_management_value ) *

private oracle_key_management_password ::= oracle_key_management_value

private oracle_key_identifier_value ::= {string_literal} | string

private oracle_key_management_value ::= {string_literal} | string | oracle_object_name_part

alter_synonym_stmt ::= 'ALTER' [ 'PUBLIC' ] 'SYNONYM' [ 'IF' 'EXISTS' ] oracle_schema_object_name
  ( 'COMPILE' | 'EDITIONABLE' | 'NONEDITIONABLE' ) {
  pin = 3
}

alter_trigger_stmt ::= 'ALTER' 'TRIGGER' [ 'IF' 'EXISTS' ] oracle_schema_object_name oracle_alter_trigger_clause {
  pin = 2
}

alter_type_stmt ::= 'ALTER' 'TYPE' [ 'IF' 'EXISTS' ] oracle_schema_object_name oracle_alter_type_clause + {
  pin = 2
}

alter_function_stmt ::= 'ALTER' 'FUNCTION' [ 'IF' 'EXISTS' ] oracle_schema_object_name
  ( oracle_compile_clause | 'EDITIONABLE' | 'NONEDITIONABLE' ) {
  pin = 2
}

alter_procedure_stmt ::= 'ALTER' 'PROCEDURE' [ 'IF' 'EXISTS' ] oracle_schema_object_name
  ( oracle_compile_clause | 'EDITIONABLE' | 'NONEDITIONABLE' ) {
  pin = 2
}

alter_package_stmt ::= 'ALTER' 'PACKAGE' [ 'IF' 'EXISTS' ] oracle_schema_object_name
  ( oracle_package_compile_clause | 'EDITIONABLE' | 'NONEDITIONABLE' ) {
  pin = 2
}

alter_library_stmt ::= 'ALTER' 'LIBRARY' [ 'IF' 'EXISTS' ] oracle_schema_object_name
  ( oracle_compile_clause | 'EDITIONABLE' | 'NONEDITIONABLE' ) {
  pin = 2
}

alter_java_stmt ::= 'ALTER' 'JAVA' ( 'SOURCE' | 'CLASS' ) [ 'IF' 'EXISTS' ] oracle_object_name_part
  [ oracle_java_resolver_clause ] [ 'RESOLVE' | 'COMPILE' ] [ oracle_invoker_rights_clause ] {
  pin = 3
}

private oracle_alter_trigger_clause ::= (
  'ENABLE' |
  'DISABLE' |
  'RENAME' 'TO' oracle_object_name_part |
  oracle_compile_clause |
  'EDITIONABLE' |
  'NONEDITIONABLE'
)

private oracle_alter_type_clause ::= (
  oracle_type_compile_clause |
  'EDITIONABLE' |
  'NONEDITIONABLE' |
  ( 'ADD' | 'DROP' | 'MODIFY' ) oracle_plsql_source_token + |
  [ 'NOT' ] ( 'FINAL' | 'INSTANTIABLE' ) |
  'CASCADE' oracle_plsql_source_token *
)

private oracle_compile_clause ::= 'COMPILE' [ 'DEBUG' ] [ 'REUSE' 'SETTINGS' ]

private oracle_package_compile_clause ::= 'COMPILE' [ 'DEBUG' ] [ 'PACKAGE' | 'SPECIFICATION' | 'BODY' ] [ 'REUSE' 'SETTINGS' ]

private oracle_type_compile_clause ::= 'COMPILE' [ 'DEBUG' ] [ 'SPECIFICATION' | 'BODY' ] [ 'REUSE' 'SETTINGS' ]

private oracle_java_resolver_clause ::= 'RESOLVER' oracle_parenthesized_clause

private oracle_invoker_rights_clause ::= 'AUTHID' ( 'CURRENT_USER' | 'DEFINER' )

create_function_stmt ::= 'CREATE' oracle_create_replace_or_edition_clause * 'FUNCTION' [ 'IF' 'NOT' 'EXISTS' ] oracle_schema_object_name oracle_plsql_source_token + {
  pin = 3
}

create_package_body_stmt ::= 'CREATE' oracle_create_replace_or_edition_clause * 'PACKAGE' 'BODY' [ 'IF' 'NOT' 'EXISTS' ] oracle_schema_object_name oracle_plsql_source_token + {
  pin = 4
}

create_type_body_stmt ::= 'CREATE' oracle_create_replace_or_edition_clause * 'TYPE' 'BODY' [ 'IF' 'NOT' 'EXISTS' ] oracle_schema_object_name oracle_plsql_source_token + {
  pin = 4
}

create_library_stmt ::= 'CREATE' oracle_create_replace_or_edition_clause * 'LIBRARY' [ 'IF' 'NOT' 'EXISTS' ] oracle_schema_object_name oracle_plsql_source_token + {
  pin = 3
}

private oracle_create_replace_or_edition_clause ::= 'OR' 'REPLACE' | 'EDITIONABLE' | 'NONEDITIONABLE'

private oracle_plsql_source_token ::= (
  oracle_object_name_part |
  {string_literal} |
  string |
  DIGIT |
  {signed_number} |
  COMMA |
  DOT |
  EQ |
  LP |
  RP |
  'AS' |
  'IS' |
  'BEGIN' |
  'DATA' |
  'END' |
  'RETURN' |
  'INCLUDING' |
  'LANGUAGE' |
  'JAVA' |
  'JAVASCRIPT' |
  'NAME' |
  'EXTERNAL' |
  'TABLE' |
  'LIBRARY'
)

create_audit_policy_stmt ::= 'CREATE' 'AUDIT' 'POLICY' oracle_object_name_part
  oracle_audit_policy_clause_set [ oracle_audit_condition_clause ] [ 'ONLY' 'TOPLEVEL' ] [ oracle_container_clause ] {
  pin = 3
}

alter_audit_policy_stmt ::= 'ALTER' 'AUDIT' 'POLICY' oracle_object_name_part oracle_alter_audit_policy_clause + {
  pin = 3
}

drop_audit_policy_stmt ::= 'DROP' 'AUDIT' 'POLICY' oracle_object_name_part {
  pin = 3
}

audit_stmt ::= 'AUDIT' (
  'POLICY' oracle_object_name_part oracle_unified_audit_policy_tail |
  oracle_audit_context_clause
) {
  pin = 1
}

noaudit_stmt ::= 'NOAUDIT' (
  'POLICY' oracle_object_name_part oracle_unified_noaudit_policy_tail |
  oracle_audit_context_clause [ oracle_audit_success_clause ]
) {
  pin = 1
}

private oracle_alter_audit_policy_clause ::= (
  ( 'ADD' | 'DROP' ) [ oracle_audit_policy_clause_set ] [ 'ONLY' 'TOPLEVEL' ] |
  'CONDITION' ( 'DROP' | oracle_audit_condition_clause )
)

private oracle_audit_policy_clause_set ::= oracle_generic_audit_clause +

private oracle_generic_audit_clause ::= oracle_audit_clause_header oracle_audit_action_item ( COMMA oracle_audit_action_item ) *

private oracle_audit_clause_header ::= 'PRIVILEGES' | 'ACTIONS' | 'ROLES' | oracle_object_name_part

private oracle_audit_action_item ::= oracle_audit_item [ EQ oracle_object_name_part oracle_audit_item ]
  [ LP oracle_object_name_part ( COMMA oracle_object_name_part ) * RP ] [ 'ON' oracle_audit_object_target ]

private oracle_audit_item ::= oracle_audit_word ( oracle_audit_word ) *

private oracle_audit_word ::= (
  'ADMINISTER' |
  'ALL' |
  'ALTER' |
  'ANY' |
  'CREATE' |
  'DELETE' |
  'DROP' |
  'EXECUTE' |
  'EXPORT' |
  'GRANT' |
  'IMPORT' |
  'INSERT' |
  'KEY' |
  'LIBRARY' |
  'LOCK' |
  'MANAGEMENT' |
  'READ' |
  'SELECT' |
  'TABLE' |
  'UPDATE' |
  'WRITE' |
  EQ |
  oracle_object_name_part
)

private oracle_audit_object_target ::= (
  'DIRECTORY' oracle_object_name_part |
  oracle_schema_object_name
)

private oracle_audit_condition_clause ::= 'WHEN' {string_literal} 'EVALUATE' 'PER' ( 'STATEMENT' | 'SESSION' | 'INSTANCE' )

private oracle_unified_audit_policy_tail ::= [ oracle_audit_user_scope ] [ oracle_audit_success_clause ]

private oracle_unified_noaudit_policy_tail ::= [ oracle_noaudit_user_scope ]

private oracle_audit_user_scope ::= (
  oracle_by_users_with_roles_clause |
  ( 'BY' | 'EXCEPT' ) oracle_object_name_part ( COMMA oracle_object_name_part ) *
)

private oracle_noaudit_user_scope ::= (
  oracle_by_users_with_roles_clause |
  'BY' oracle_object_name_part ( COMMA oracle_object_name_part ) *
)

private oracle_by_users_with_roles_clause ::= 'BY' 'USERS' 'WITH' 'GRANTED' 'ROLES' oracle_object_name_part ( COMMA oracle_object_name_part ) *

private oracle_audit_success_clause ::= 'WHENEVER' [ 'NOT' ] 'SUCCESSFUL'

private oracle_audit_context_clause ::= oracle_audit_context_item ( COMMA oracle_audit_context_item ) * [ 'BY' oracle_object_name_part ( COMMA oracle_object_name_part ) * ]

private oracle_audit_context_item ::= 'CONTEXT' 'NAMESPACE' oracle_object_name_part
  'ATTRIBUTES' oracle_object_name_part ( COMMA oracle_object_name_part ) *

create_user_stmt ::= 'CREATE' 'USER' [ 'IF' 'NOT' 'EXISTS' ] oracle_object_name_part
  ( oracle_user_authentication | 'NO' 'AUTHENTICATION' ) oracle_user_clause * {
  pin = 2
}

alter_user_stmt ::= 'ALTER' 'USER' [ 'IF' 'EXISTS' ] (
  oracle_object_name_part oracle_alter_user_clause + |
  oracle_object_name_part ( COMMA oracle_object_name_part ) * oracle_proxy_clause
) {
  pin = 2
}

private oracle_user_authentication ::= 'IDENTIFIED' (
  'BY' oracle_authentication_value [ [ 'HTTP' ] 'DIGEST' ( 'ENABLE' | 'DISABLE' ) ] [ 'AND' 'FACTOR' {string_literal} 'AS' {string_literal} ] |
  'EXTERNALLY' [ 'AS' {string_literal} ] |
  'GLOBALLY' [ 'AS' {string_literal} ]
)

private oracle_alter_user_clause ::= (
  'IDENTIFIED' (
    'BY' oracle_authentication_value [ 'REPLACE' oracle_authentication_value ] |
    'EXTERNALLY' [ 'AS' {string_literal} ] |
    'GLOBALLY' [ 'AS' {string_literal} ]
  ) |
  'NO' 'AUTHENTICATION' |
  ( 'ADD' | 'UPDATE' ) LP 'FACTOR' {string_literal} 'AS' {string_literal} RP |
  'DROP' 'FACTOR' {string_literal} |
  'DEFAULT' 'ROLE' oracle_default_role_clause |
  'EXPIRE' 'PASSWORD' 'ROLLOVER' 'PERIOD' |
  oracle_container_data_clause |
  oracle_user_clause
)

private oracle_user_clause ::= (
  'DEFAULT' 'COLLATION' oracle_object_name_part |
  'DEFAULT' 'TABLESPACE' oracle_object_name_part |
  [ 'LOCAL' ] 'TEMPORARY' 'TABLESPACE' oracle_object_name_part |
  'QUOTA' ( oracle_size_clause | 'UNLIMITED' ) 'ON' oracle_object_name_part |
  'PROFILE' oracle_object_name_part |
  'PASSWORD' 'EXPIRE' |
  'ACCOUNT' ( 'LOCK' | 'UNLOCK' ) |
  'ENABLE' 'EDITIONS' [ 'FOR' oracle_object_name_part ( COMMA oracle_object_name_part ) * ] [ 'FORCE' ] |
  [ 'HTTP' ] 'DIGEST' ( 'ENABLE' | 'DISABLE' ) |
  oracle_container_clause |
  ( 'ENABLE' | 'DISABLE' ) 'DICTIONARY' 'PROTECTION' |
  'READ' ( 'ONLY' | 'WRITE' )
)

private oracle_default_role_clause ::= (
  oracle_object_name_part ( COMMA oracle_object_name_part ) * |
  'ALL' [ 'EXCEPT' oracle_object_name_part ( COMMA oracle_object_name_part ) * ] |
  'NONE'
)

private oracle_proxy_clause ::= (
  'GRANT' 'CONNECT' 'THROUGH' ( 'ENTERPRISE' 'USERS' | oracle_object_name_part oracle_db_user_proxy_clauses ) |
  'REVOKE' 'CONNECT' 'THROUGH' ( 'ENTERPRISE' 'USERS' | oracle_object_name_part )
)

private oracle_db_user_proxy_clauses ::= [ 'WITH' ( 'ROLE' oracle_proxy_role_clause | 'NO' 'ROLES' ) ] [ 'AUTHENTICATION' 'REQUIRED' ]

private oracle_proxy_role_clause ::= (
  oracle_object_name_part ( COMMA oracle_object_name_part ) * |
  'ALL' 'EXCEPT' oracle_object_name_part ( COMMA oracle_object_name_part ) *
)

private oracle_container_data_clause ::= (
  'SET' 'CONTAINER_DATA' EQ oracle_container_data_value |
  'ADD' 'CONTAINER_DATA' EQ oracle_container_name_list |
  'REMOVE' 'CONTAINER_DATA' EQ oracle_container_name_list
) [ 'FOR' oracle_schema_object_name ]

private oracle_container_data_value ::= 'ALL' | 'DEFAULT' | oracle_container_name_list

private oracle_container_name_list ::= LP oracle_object_name_part ( COMMA oracle_object_name_part ) * RP

private oracle_size_clause ::= {signed_number} [ oracle_size_unit | oracle_object_name_part ]

private oracle_size_unit ::= 'K' | 'M' | 'G' | 'T' | 'P' | 'E'

private oracle_authentication_value ::= oracle_object_name_part | {string_literal}

create_role_stmt ::= 'CREATE' 'ROLE' [ 'IF' 'NOT' 'EXISTS' ] oracle_object_name_part
  [ oracle_role_identification ] [ oracle_container_clause ] {
  pin = 2
}

alter_role_stmt ::= 'ALTER' 'ROLE' [ 'IF' 'EXISTS' ] oracle_object_name_part
  oracle_role_identification [ oracle_container_clause ] {
  pin = 2
}

grant_stmt ::= 'GRANT' (
  oracle_grant_object_privileges |
  oracle_grant_roles_to_programs |
  oracle_grant_system_privileges
) [ oracle_container_clause ] {
  pin = 1
}

revoke_stmt ::= 'REVOKE' (
  oracle_revoke_roles_from_programs |
  oracle_revoke_object_privileges |
  oracle_revoke_system_privileges
) [ oracle_container_clause ] {
  pin = 1
}

drop_role_stmt ::= 'DROP' 'ROLE' [ 'IF' 'EXISTS' ] oracle_object_name_part {
  pin = 2
}

drop_user_stmt ::= 'DROP' 'USER' [ 'IF' 'EXISTS' ] oracle_object_name_part [ 'CASCADE' ] {
  pin = 2
}

private oracle_role_identification ::= (
  'NOT' 'IDENTIFIED' |
  'IDENTIFIED' (
    'BY' oracle_role_password |
    'USING' oracle_schema_object_name |
    'EXTERNALLY' |
    'GLOBALLY' 'AS' {string_literal}
  )
)

private oracle_grant_system_privileges ::= oracle_grant_system_privilege ( COMMA oracle_grant_system_privilege ) *
  'TO' ( oracle_grantee_identified_by | oracle_grantee_clause ) [ 'WITH' ( 'ADMIN' | 'DELEGATE' ) 'OPTION' ]

private oracle_revoke_system_privileges ::= oracle_grant_system_privilege ( COMMA oracle_grant_system_privilege ) *
  'FROM' oracle_grantee_clause

private oracle_grant_object_privileges ::= oracle_grant_object_privilege ( COMMA oracle_grant_object_privilege ) *
  oracle_on_object_clause 'TO' oracle_grantee_clause [ 'WITH' 'HIERARCHY' 'OPTION' ] [ 'WITH' 'GRANT' 'OPTION' ]

private oracle_revoke_object_privileges ::= oracle_revoke_object_privilege ( COMMA oracle_revoke_object_privilege ) *
  oracle_on_object_clause 'FROM' oracle_grantee_clause [ 'CASCADE' 'CONSTRAINTS' | 'FORCE' ]

private oracle_grant_roles_to_programs ::= oracle_object_name_part ( COMMA oracle_object_name_part ) *
  'TO' oracle_program_unit ( COMMA oracle_program_unit ) *

private oracle_revoke_roles_from_programs ::= ( oracle_object_name_part ( COMMA oracle_object_name_part ) * | 'ALL' )
  'FROM' oracle_program_unit ( COMMA oracle_program_unit ) *

private oracle_grantee_clause ::= oracle_grantee ( COMMA oracle_grantee ) *

private oracle_grantee ::= oracle_object_name_part | 'PUBLIC'

private oracle_grantee_identified_by ::= oracle_object_name_part ( COMMA oracle_object_name_part ) *
  'IDENTIFIED' 'BY' oracle_role_password ( COMMA oracle_role_password ) *

private oracle_grant_system_privilege ::= (
  'ALL' 'PRIVILEGES' |
  'UNLIMITED' 'TABLESPACE' |
  'CREATE' oracle_system_privilege_target |
  'ALTER' oracle_any_system_privilege_target |
  'DROP' oracle_any_system_privilege_target |
  'SELECT' oracle_any_system_privilege_target |
  'INSERT' oracle_any_system_privilege_target |
  'UPDATE' oracle_any_system_privilege_target |
  'DELETE' oracle_any_system_privilege_target |
  'EXECUTE' oracle_any_system_privilege_target |
  oracle_object_name_part
)

private oracle_system_privilege_target ::= (
  'SESSION' |
  'TABLE' |
  'VIEW' |
  'PROCEDURE' |
  'SEQUENCE' |
  'SYNONYM' |
  'TRIGGER' |
  'USER' |
  'ROLE' |
  oracle_any_system_privilege_target
)

private oracle_any_system_privilege_target ::= 'ANY' (
  'TABLE' |
  'VIEW' |
  'PROCEDURE' |
  'SEQUENCE' |
  'SYNONYM' |
  'TRIGGER' |
  'TYPE' |
  'DIRECTORY'
)

private oracle_grant_object_privilege ::= oracle_object_privilege [ LP oracle_object_name_part ( COMMA oracle_object_name_part ) * RP ]

private oracle_revoke_object_privilege ::= oracle_object_privilege

private oracle_object_privilege ::= (
  'ALL' [ 'PRIVILEGES' ] |
  'SELECT' |
  'INSERT' |
  'UPDATE' |
  'DELETE' |
  'REFERENCES' |
  'READ' |
  'WRITE' |
  'EXECUTE' |
  'DEBUG' |
  'FLASHBACK' |
  'ON' 'COMMIT' 'REFRESH'
)

private oracle_on_object_clause ::= 'ON' (
  oracle_schema_object_name |
  'USER' oracle_object_name_part ( COMMA oracle_object_name_part ) * |
  'DIRECTORY' oracle_object_name_part |
  'EDITION' oracle_object_name_part |
  'MINING' 'MODEL' oracle_schema_object_name |
  'JAVA' ( 'SOURCE' | 'RESOURCE' ) oracle_schema_object_name |
  'SQL' 'TRANSLATION' 'PROFILE' oracle_schema_object_name
)

private oracle_program_unit ::= ( 'FUNCTION' | 'PROCEDURE' | 'PACKAGE' ) oracle_schema_object_name

private oracle_container_clause ::= 'CONTAINER' EQ ( 'CURRENT' | 'ALL' )

analyze_stmt ::= 'ANALYZE' oracle_analyze_target oracle_analyze_action {
  extends = "com.alecstrong.sql.psi.core.psi.impl.SqlAnalyzeStmtImpl"
  implements = "com.alecstrong.sql.psi.core.psi.SqlAnalyzeStmt"
  override = true
  pin = 1
}

private oracle_analyze_target ::= (
  ( 'TABLE' | 'INDEX' ) oracle_schema_object_name [ oracle_partition_extension_clause ] |
  'CLUSTER' oracle_schema_object_name
)

private oracle_analyze_action ::= (
  oracle_validation_clause |
  'LIST' 'CHAINED' 'ROWS' [ oracle_into_clause ] |
  'DELETE' [ 'SYSTEM' ] 'STATISTICS'
)

private oracle_validation_clause ::= (
  'VALIDATE' 'REF' 'UPDATE' [ 'SET' 'DANGLING' 'TO' 'NULL' ] |
  'VALIDATE' 'STRUCTURE' [ 'CASCADE' [ 'FAST' | 'COMPLETE' ( 'OFFLINE' | 'ONLINE' ) [ oracle_into_clause ] ] ]
)

private oracle_into_clause ::= 'INTO' oracle_schema_object_name

associate_statistics_stmt ::= 'ASSOCIATE' 'STATISTICS' 'WITH'
  ( oracle_column_association | oracle_function_association ) [ oracle_storage_table_clause ] {
  pin = 2
}

private oracle_column_association ::= 'COLUMNS' oracle_column_reference ( COMMA oracle_column_reference ) * oracle_using_statistics_type

private oracle_function_association ::= oracle_association_kind oracle_schema_object_name ( COMMA oracle_schema_object_name ) *
  ( oracle_using_statistics_type | oracle_default_statistics_clause )

private oracle_association_kind ::= 'FUNCTIONS' | 'PACKAGES' | 'TYPES' | 'INDEXES' | 'INDEXTYPES'

private oracle_using_statistics_type ::= 'USING' ( oracle_schema_object_name | 'NULL' )

private oracle_default_statistics_clause ::= (
  oracle_default_cost_clause [ COMMA oracle_default_selectivity_clause ] |
  oracle_default_selectivity_clause [ COMMA oracle_default_cost_clause ]
)

private oracle_default_cost_clause ::= 'DEFAULT' 'COST' LP <<expr '-1'>> COMMA <<expr '-1'>> COMMA <<expr '-1'>> RP

private oracle_default_selectivity_clause ::= 'DEFAULT' 'SELECTIVITY' <<expr '-1'>>

private oracle_storage_table_clause ::= 'WITH' ( 'SYSTEM' | 'USER' ) 'MANAGED' 'STORAGE' 'TABLES'

disassociate_statistics_stmt ::= 'DISASSOCIATE' 'STATISTICS' 'FROM' oracle_statistics_association_target [ 'FORCE' ] {
  pin = 2
}

private oracle_statistics_association_target ::= (
  'COLUMNS' oracle_column_reference ( COMMA oracle_column_reference ) * |
  oracle_association_kind oracle_schema_object_name ( COMMA oracle_schema_object_name ) *
)

private oracle_column_reference ::= oracle_object_name_part DOT oracle_object_name_part [ DOT oracle_object_name_part ]

rename_stmt ::= 'RENAME' oracle_object_name_part 'TO' oracle_object_name_part {
  pin = 1
}

comment_on_stmt ::= 'COMMENT' 'ON' oracle_comment_target 'IS' {string_literal} {
  pin = 2
}

private oracle_comment_target ::= (
  'AUDIT' 'POLICY' oracle_object_name_part |
  'COLUMN' oracle_column_reference |
  'EDITION' oracle_object_name_part |
  'INDEXTYPE' oracle_schema_object_name |
  'MATERIALIZED' 'VIEW' oracle_schema_object_name |
  'MINING' 'MODEL' oracle_schema_object_name |
  'OPERATOR' oracle_schema_object_name |
  'TABLE' oracle_schema_object_name |
  'PROPERTY' 'GRAPH' oracle_schema_object_name
)

purge_stmt ::= 'PURGE' (
  ( 'TABLE' | 'INDEX' ) oracle_schema_object_name |
  'TABLESPACE' 'SET' oracle_object_name_part [ 'USER' oracle_object_name_part ] |
  'TABLESPACE' oracle_object_name_part [ 'USER' oracle_object_name_part ] |
  'RECYCLEBIN' |
  'DBA_RECYCLEBIN'
) {
  pin = 1
}

flashback_table_stmt ::= 'FLASHBACK' 'TABLE' oracle_schema_object_name ( COMMA oracle_schema_object_name ) *
  'TO' (
    oracle_flashback_target [ ( 'ENABLE' | 'DISABLE' ) 'TRIGGERS' ] |
    'BEFORE' 'DROP' [ 'RENAME' 'TO' oracle_object_name_part ]
  ) {
  pin = 2
}

private oracle_flashback_target ::= (
  ( 'SCN' | 'TIMESTAMP' ) <<expr '-1'>> |
  'RESTORE' 'POINT' oracle_object_name_part
)

flashback_database_stmt ::= 'FLASHBACK' [ 'STANDBY' ] [ 'PLUGGABLE' ] 'DATABASE' [ oracle_object_name_part ]
  ( 'TO' oracle_flashback_target | 'TO' 'BEFORE' oracle_flashback_before_target ) {
  pin = 1
}

private oracle_flashback_before_target ::= (
  ( 'SCN' | 'TIMESTAMP' ) <<expr '-1'>> |
  'RESETLOGS'
)

drop_trigger_stmt ::= 'DROP' 'TRIGGER' [ 'IF' 'EXISTS' ] oracle_schema_object_name {
  extends = "com.alecstrong.sql.psi.core.psi.impl.SqlDropTriggerStmtImpl"
  implements = "com.alecstrong.sql.psi.core.psi.SqlDropTriggerStmt"
  override = true
  pin = 2
}

alter_sequence_stmt ::= 'ALTER' 'SEQUENCE' [ 'IF' 'EXISTS' ] oracle_schema_object_name oracle_sequence_clause * {
  pin = 2
}

private oracle_schema_object_name ::= oracle_object_name_part [ DOT oracle_object_name_part ]

private oracle_object_name_part ::= oracle_common_object_name_part | <<identifierExt <<identifier_real>>>> | string

private oracle_common_object_name_part ::= <<identifierExt <<identifier_real>>>> '#' '#' <<identifierExt <<identifier_real>>>>

private oracle_sequence_clause ::= (
  'INCREMENT' 'BY' {signed_number} |
  'START' 'WITH' {signed_number} |
  'RESTART' |
  'MAXVALUE' {signed_number} |
  'NOMAXVALUE' |
  'MINVALUE' {signed_number} |
  'NOMINVALUE' |
  'CYCLE' |
  'NOCYCLE' |
  'CACHE' {signed_number} |
  'NOCACHE' |
  'ORDER' |
  'NOORDER' |
  'KEEP' |
  'NOKEEP' |
  'SCALE' [ 'EXTEND' | 'NOEXTEND' ] |
  'NOSCALE' |
  'SHARD' [ 'EXTEND' | 'NOEXTEND' ] |
  'NOSHARD' |
  'SESSION' |
  'GLOBAL'
)

merge_stmt ::= 'MERGE' [ oracle_hint ] 'INTO' oracle_merge_table_reference [ oracle_merge_using_clause ] 'ON' LP <<expr '-1'>> RP
  ( oracle_merge_update_clause | oracle_merge_insert_clause ) + [ oracle_error_logging_clause ] {
  pin = 1
}

private oracle_hint ::= comment

private oracle_merge_using_clause ::= 'USING' (
  oracle_merge_table_reference |
  LP {compound_select_stmt} RP [ {table_alias} ] |
  oracle_merge_values_clause [ {table_alias} ]
)

private oracle_merge_table_reference ::= oracle_schema_object_name [ {table_alias} ]

private oracle_merge_values_clause ::= 'VALUES' LP oracle_merge_value ( COMMA oracle_merge_value ) * RP

private oracle_merge_update_clause ::= 'WHEN' 'MATCHED' 'THEN' 'UPDATE' 'SET'
  oracle_merge_assignment ( COMMA oracle_merge_assignment ) * [ oracle_where_clause ] [ 'DELETE' oracle_where_clause ]

private oracle_merge_insert_clause ::= 'WHEN' 'NOT' 'MATCHED' 'THEN' 'INSERT' (
  [ LP oracle_schema_object_name ( COMMA oracle_schema_object_name ) * RP ] 'VALUES' LP oracle_merge_value ( COMMA oracle_merge_value ) * RP |
  'SET' oracle_merge_assignment ( COMMA oracle_merge_assignment ) *
) [ oracle_where_clause ]

private oracle_merge_assignment ::= oracle_schema_object_name EQ oracle_merge_value

private oracle_merge_value ::= 'DEFAULT' | <<expr '-1'>>

private oracle_where_clause ::= 'WHERE' <<expr '-1'>>

private oracle_error_logging_clause ::= 'LOG' 'ERRORS' [ 'INTO' oracle_schema_object_name ] [ LP <<expr '-1'>> RP ]
  [ 'REJECT' 'LIMIT' ( {signed_number} | 'UNLIMITED' ) ]

call_stmt ::= 'CALL' oracle_call_routine_name LP [ oracle_call_argument ( COMMA oracle_call_argument ) * ] RP {
  pin = 1
}

private oracle_call_routine_name ::= oracle_schema_object_name [ DOT ( <<identifierExt <<identifier_real>>>> | string ) ]

private oracle_call_argument ::= <<expr '-1'>>

lock_table_stmt ::= 'LOCK' 'TABLE' oracle_lock_table_reference ( COMMA oracle_lock_table_reference ) * 'IN' oracle_lock_mode 'MODE'
  [ 'NOWAIT' | 'WAIT' {signed_number} ] {
  pin = 2
}

private oracle_lock_table_reference ::= oracle_schema_object_name [ oracle_partition_extension_clause ]

private oracle_partition_extension_clause ::= (
  'PARTITION' LP oracle_partition_name RP |
  'PARTITION' 'FOR' LP oracle_partition_key_value ( COMMA oracle_partition_key_value ) * RP |
  'SUBPARTITION' LP oracle_partition_name RP |
  'SUBPARTITION' 'FOR' LP oracle_partition_key_value ( COMMA oracle_partition_key_value ) * RP
)

private oracle_partition_name ::= <<identifierExt <<identifier_real>>>> | string

private oracle_partition_key_value ::= <<expr '-1'>>

private oracle_lock_mode ::= (
  'ROW' 'SHARE' |
  'ROW' 'EXCLUSIVE' |
  'SHARE' 'UPDATE' |
  'SHARE' 'ROW' 'EXCLUSIVE' |
  'SHARE' |
  'EXCLUSIVE'
)

explain_plan_stmt ::= 'EXPLAIN' 'PLAN' [ 'SET' 'STATEMENT_ID' EQ <<expr '-1'>> ] [ 'INTO' oracle_schema_object_name ] 'FOR'
  oracle_explainable_stmt {
  pin = 2
}

private oracle_explainable_stmt ::= (
  {compound_select_stmt} |
  {insert_stmt} |
  {update_stmt} |
  {delete_stmt} |
  merge_stmt |
  create_table_stmt |
  create_index_stmt
)

truncate_table_stmt ::= 'TRUNCATE' 'TABLE' oracle_schema_object_name [ oracle_materialized_view_log_clause ] [ oracle_truncate_storage_clause ] [ 'CASCADE' ] {
  pin = 2
}

truncate_cluster_stmt ::= 'TRUNCATE' 'CLUSTER' oracle_schema_object_name [ oracle_truncate_storage_clause ] {
  pin = 2
}

private oracle_materialized_view_log_clause ::= ( 'PRESERVE' | 'PURGE' ) ( 'MATERIALIZED' 'VIEW' | 'SNAPSHOT' ) 'LOG'

private oracle_truncate_storage_clause ::= (
  'DROP' [ 'ALL' ] 'STORAGE' |
  'REUSE' 'STORAGE'
)
